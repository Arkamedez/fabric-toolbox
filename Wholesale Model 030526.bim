          {
            "name": "Adjusted Fill Rate",
            "description": "Fill Rate excluding Ship Error Group Codes 4 and 6",
            "expression": "DIVIDE([Shipped Qty], [Adjusted Ordered Case Qty])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Fill Rate",
            "lineageTag": "f06c4ffe-b538-4edb-a153-82105e591b44"
          },
          {
            "name": "Adjusted Not Shipped Qty",
            "description": "Not Shipped Case Quantity excluding Ship Error Group Codes 4 and 6.",
            "expression": [
              "CALCULATE(sum('F_FD.Sales Outs'[Not Ship Case Qty]),  FILTER (",
              "        'D_Ship Error',",
              "        NOT ( 'D_Ship Error'[Ship Error Group Code] ) IN { \"6\",\"4\" }",
              "    ))"
            ],
            "formatString": "#,0",
            "displayFolder": "Fill Rate",
            "lineageTag": "104ba4e6-ba23-4c2b-a54f-cb858167988e"
          },
          {
            "name": "Adjusted Ordered Case Qty",
            "description": "Ordered Case Quantity excluding Ship Error Group Codes 4 and 6",
            "expression": "[Shipped Qty] + [Adjusted Not Shipped Qty]",
            "formatString": "#,0",
            "displayFolder": "Fill Rate",
            "lineageTag": "02329e43-2038-46fb-bd03-94fcf4c115c5"
          },
          {
            "name": "Military Fill Rate",
            "description": "Fill Rate with all Ship Error Group Codes",
