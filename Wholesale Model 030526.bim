                "    #\"Renamed Columns\" = Table.RenameColumns(DATE_DIM_VW_View,{{\"DAY_OF_MONTH\", \"Day of Month\"}, {\"DATE_NM\", \"Day Name\"}, {\"DAY_OF_PERIOD\", \"Day of Period\"}, {\"FULL_DATE\", \"Full Date\"}, {\"DATE_ID_LY\", \"Date ID LY\"}, {\"DATE_ID_LW\", \"Date ID LW\"}, {\"DATE_ID_L2Y\", \"Date ID L2Y\"}, {\"FISCAL_DAY\", \"Fiscal Day\"}, {\"DATE_PK\", \"Date Key\"}, {\"FISCAL_PERIOD_START_DT\", \"Fiscal Period Start Date\"}, {\"FISCAL_QUARTER_START_DT\", \"Fiscal Quarter Start Date\"}, {\"FISCAL_WEEK_START_DT\", \"Fiscal Week Start Date\"}, {\"FISCAL_PERIOD_END_DT\", \"Fiscal Period End Date\"}, {\"FISCAL_PERIOD\", \"Fiscal Period\"}, {\"FISCAL_PERIOD_L2Y\", \"Fiscal Period L2Y\"}, {\"FISCAL_PERIOD_LY\", \"Fiscal Period LY\"}, {\"FISCAL_QUARTER\", \"Fiscal Quarter\"}, {\"FISCAL_WEEK\", \"Fiscal Week\"}, {\"FISCAL_YEAR\", \"Fiscal Year\"}, {\"FISCAL_YEAR_START_DT\", \"Fiscal Year Start Date\"}, {\"FISCAL_YEAR_END_DT\", \"Fiscal Year End Date\"}, {\"FISCAL_WEEK_END_DT\", \"Fiscal Week End Date\"}, {\"FISCAL_QUARTER_END_DT\", \"Fiscal Quarter End Date\"}, {\"DAY_OF_QUARTER\", \"Day of Quarter\"}, {\"DAY_OF_WEEK\", \"Day of Week\"}, {\"DAY_OF_YEAR\", \"Day of Year\"}, {\"MONTH_NM\", \"Month Name\"}, {\"MONTH\", \"Month\"}, {\"MONTH_OF_PERIOD\", \"Month of Period\"}, {\"MONTH_OF_QUARTER\", \"Month of Quarter\"}, {\"MONTH_OF_YEAR\", \"Month of Year\"}, {\"QUARTER\", \"Quarter\"}, {\"QUARTER_ID_L2Y\", \"Quarter ID L2Y\"}, {\"QUARTER_ID_LY\", \"Quarter ID LY\"}, {\"QUARTER_NM\", \"Quarter Nbr\"}, {\"WEEK_OF_YEAR\", \"Week of Year\"}, {\"FIRSTDAYOFMONTH\", \"First Day of Month\"}, {\"FIRSTDAYOFQUARTER\", \"First Day of Quarter\"}, {\"FIRSTDAYOFYEAR\", \"First Day of Year\"}, {\"DAY_OF_WEEK_INMONTH\", \"Day of Week in Month\"}, {\"FISCAL_QUARTER_NM\", \"Fiscal Quarter Nbr\"}, {\"MONTH_NM_ABBRV\", \"Month Name Abbreviation\"}, {\"PREV_FISCAL_DAY\", \"Previous Fiscal Day\"}, {\"PREV_FISCAL_PERIOD\", \"Previous Fiscal Period\"}, {\"PREV_FISCAL_WEEK\", \"Previous Fiscal Week\"}, {\"PREV_FISCAL_QUARTER\", \"Previous Fiscal Quarter\"}, {\"PREV_FISCAL_YEAR\", \"Previous Fiscal Year\"}, {\"CAL_MONTH_OFFSET_NBR\", \"Cal Month Offset Nbr\"}, {\"CAL_QUARTER_OFFSET_NBR\", \"Cal Quarter Offset Nbr\"}, {\"CAL_WEEK_OFFSET_NBR\", \"Cal Week Offset Nbr\"}, {\"CAL_YEAR_OFFSET_NBR\", \"Cal Year Offset Nbr\"}, {\"DATE_OFFSET_NBR\", \"Date Offset Nbr\"}, {\"FISCAL_PERIOD_OFFSET_NBR\", \"Fiscal Period Offset Nbr\"}, {\"FISCAL_QUARTER_OFFSET_NBR\", \"Fiscal Quarter Offset Nbr\"}, {\"FISCAL_WEEK_OFFSET_NBR\", \"Fiscal Week Offset Nbr\"}, {\"FISCAL_YEAR_OFFSET_NBR\", \"Fiscal Year Offset Nbr\"}, {\"LASTDAYOFMONTH\", \"Last Day of Month\"}, {\"LASTDAYOFQUARTER\", \"Last Day of Quarter\"}, {\"LASTDAYOFYEAR\", \"Last Day of Year\"}, {\"HOLIDAY_NM\", \"Holiday Nbr\"}, {\"IS_HOLIDAY_FLG\", \"Is Holiday Flag\"}, {\"IS_WEEKDAY_FLG\", \"Is Weekday Flag\"}, {\"WEEK_ID_L2Y\", \"Week ID LY\"}, {\"WEEK_ID_LY\", \"Week ID\"}, {\"WEEK_OF_MONTH\", \"Week of Month\"}, {\"WEEK_OF_QUARTER\", \"Week of Quarter\"}, {\"YEAR\", \"Year\"}, {\"FISCAL_PERIOD_ENDING_DESC\", \"Fiscal Period with End Date\"}, {\"FISCAL_QUARTER_DESC\", \"Fiscal Quarter Detail\"}, {\"WEEK_ENDING_DESC\", \"Week Ending\"}}),",
                "    #\"Filtered Rows\" = Table.SelectRows(#\"Renamed Columns\", each [Date Key] >= #\"Start Date\"),",
