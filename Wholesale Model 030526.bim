            ]
          },
          {
            "name": "Not Shipped(Supply Chain)",
            "description": "Not shipped case quantity {Specific to ship error group supply chain} (date is less than today) (day level)",
            "expression": [
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales Outs'[Not Ship Case Qty] ),",
              "    FILTER ( 'D_Time Hierarchy', 'D_Time Hierarchy'[Full Date] <= TODAY () ),",
              "    FILTER (",
              "        'D_Ship Error',",
              "        'D_Ship Error'[Ship Error Group Code] = \"2\"",
              "    )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Ad-hoc Fill Rate Measures",
            "lineageTag": "372b1c00-3a7d-4df7-be81-3772dba09374",
            "changedProperties": [
