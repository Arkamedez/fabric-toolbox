            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database= Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    HR_Schema = EDW_Database{[Name=\"HR\",Kind=\"Schema\"]}[Data],",
                "    DC_DY_ALL_LABOR_FACT_Table = HR_Schema{[Name=\"DC_DY_ALL_LABOR_FACT\",Kind=\"Table\"]}[Data],",
                "    #\"Removed Columns\" = Table.RemoveColumns(DC_DY_ALL_LABOR_FACT_Table,{\"CREATE_USER_ID\", \"UPDATE_TMSP\", \"UPDATE_USER_ID\", \"ORIGIN\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Removed Columns\",{{\"ASSOCIATE_KEY\", \"Associate Key\"}, {\"BUSINESS_UNIT_KEY\", \"Business Unit Key\"}, {\"CONTRACTOR_KEY\", \"Contractor Key\"}, {\"DATE_KEY\", \"Date Key\"}, {\"DEPT_KEY\", \"Dept Key\"}, {\"EARN_CODE_KEY\", \"Earn Code Key\"}, {\"EXE_ASSOCIATE_KEY\", \"Exe Associate Key\"}, {\"FACILITY_KEY\", \"Facility Key\"}, {\"JOB_CODE_KEY\", \"Job Code Key\"}, {\"LOCATION_DEPT_KEY\", \"Location Dept Key\"}, {\"PAY_CALENDAR_KEY\", \"Pay Calendar Key\"}, {\"TRANSACTION_DT\", \"Transaction Dt\"}, {\"ASSOCIATE_ID\", \"Associate Id\"}, {\"BUSINESS_UNIT_ID\", \"Business Unit Id\"}, {\"DEPT_ID\", \"Dept Id\"}, {\"EARN_CODE_ID\", \"Earn Code Id\"}, {\"FACILITY_ID\", \"Facility Id\"}, {\"JOB_CODE_ID\", \"Job Code Id\"}, {\"LOCATION_ID\", \"Location Id\"}, {\"SUPERVISOR_ID\", \"Supervoisor Id\"}, {\"TEMPERATURE_CLASS_DESC\", \"Temarature Class Desc\"}, {\"WORKER_TYPE_DESC\", \"Worker Type Desc\"}, {\"DIVISION_CD\", \"Divison CD\"}, {\"ENTERPRISE_CD\", \"Enterprice Cd\"}, {\"DISTRICT_CD\", \"District Cd\"}, {\"REGION_CD\", \"Region Cd\"}, {\"EARNINGS_AMT\", \"Earnings Amt\"}, {\"WORK_HOURS_QTY\", \"Work Hours Qty\"}, {\"DELETE_FLG\", \"Delete Flg\"}, {\"CREATE_TMSP\", \"Create Tmsp\"}, {\"PAY_END_DATE_KEY\", \"Pay End Date Key\"}})",
                "in",
                "    #\"Renamed Columns\""
              ]
            }
          }
        ],
