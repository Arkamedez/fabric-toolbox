          {
            "name": "PO W/ Appointments",
            "expression": "CALCULATE(COUNT('F_PO Compliance'[Po Nbr]),'F_PO Compliance'[Po Appointment Flg]=\"Y\")",
            "formatString": "#,##0;(#,##0)",
