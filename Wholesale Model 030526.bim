          {
            "name": "Shipped Case Qty - Not Ship MK < today (Rolling YTW)",
            "description": "Shippped case quantity for not shipped markout rolling - year to week (date is less than today)",
            "expression": [
              "",
              "VAR startdate =",
              "    MAX ( 'D_Time Hierarchy'[Full Date] )",
              "VAR startOfWeek2 =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Week End Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR yy =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Year Start Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR y1 =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Year End Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR lasd1 =",
              "    CALCULATETABLE(DATESBETWEEN ( 'D_Time Hierarchy'[Full Date], yy, startOfWeek2), REMOVEFILTERS('D_Time Hierarchy'))",
              "VAR result1 =",
              "    CALCULATE (",
              "        [Shipped Qty Agg]-[Not Shipped (Markout) (<today)],",
              "        REMOVEFILTERS ( 'D_Time Hierarchy' ),",
              "        REMOVEFILTERS('D_Relative Time Slicer'),",
              "        KEEPFILTERS ( lasd1 )",
              "    )",
              "RETURN",
              "    result1"
            ],
            "formatString": "#,0",
            "displayFolder": "Aggregated Measures",
            "lineageTag": "3b14c4e8-5f7a-4de0-b7b9-d81aaf2e0c33",
            "changedProperties": [
