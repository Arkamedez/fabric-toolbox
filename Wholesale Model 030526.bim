                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "Not Shipped %(Supply Chain)",
            "description": "Not shipped case quantity % {Specific to ship error group supply chain} (date is less than today) (day level)",
            "expression": [
              "DIVIDE (",
              "    [Not Shipped(Supply Chain)],",
              "   [Ordered Case  Qty]",
              ")"
            ],
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Ad-hoc Fill Rate Measures",
