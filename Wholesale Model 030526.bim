          {
            "name": "Not Shipped(Buyer)",
            "description": "Not shipped case quantity {Specific to ship error group buyer} (date is less than today) (day level)",
            "expression": [
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales Outs'[Not Ship Case Qty] ),",
              "    FILTER ( 'D_Time Hierarchy', 'D_Time Hierarchy'[Full Date] <= TODAY () ),",
              "    FILTER ( 'D_Ship Error', 'D_Ship Error'[Ship Error Group Code] = \"1\" )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Ad-hoc Fill Rate Measures",
