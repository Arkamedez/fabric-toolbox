        "partitions": [
          {
            "name": "F_Inventory Adjustment Cost-3602006a-2633-48c2-aef3-67dfc894c48e",
            "mode": "directQuery",
            "queryGroup": "Fact Queries",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    INVENTORY_ADJUSTMENT_COST_VW_View = FD_Schema{[Name=\"INVENTORY_ADJUSTMENT_COST_VW\",Kind=\"View\"]}[Data],",
                "#\"Renamed Columns\" = Table.RenameColumns(INVENTORY_ADJUSTMENT_COST_VW_View,{{\"INVENTORY_ADJUSTMENT_ID\", \"Inventory Adjustment ID\"}, {\"ITEM_NBR\", \"Item Nbr\"}, {\"FACILITY_ID\", \"Facility ID\"}, {\"DC_ID\", \"DC ID\"}, {\"WHSE_ID\", \"WHSE ID\"}, {\"LOCATION_ID\", \"Location ID\"}, {\"PRODUCT_ID\", \"Product ID\"}, {\"INVENTORY_ADJUSTMENT_REASON_CD\", \"Inventory Adjustment Reason Code\"}, {\"BEFORE_INVENTORY_REDUCTION_CNT\", \"Before Inventory Reduction Count\"}, {\"ADJUSTMENT_CNT\", \"Adjustment Count\"}, {\"ADJUSTMENT_CASE_QTY\", \"Adjustment Case Quantity\"}, {\"LAYER_COST_AMT\", \"Layer Cost Amt\"}, {\"EXT_LAYER_COST_AMT\", \"Extended Layer Cost Amt\"}, {\"SELECTION_LOCATION_ID\", \"Selection Location ID\"}, {\"ROW_STATUS_CD\", \"Row Status Code\"}, {\"EXTRACTED_FLG\", \"Extracted Flag\"}, {\"EXTRACTED_DT\", \"Extracted Date\"}, {\"CATCH_WEIGHT_QTY\", \"Catch Weight Quantity\"}, {\"WHSE_GENERATED_FLOW_FLG\", \"WHSE Generated Flow Flag\"}, {\"LICENSE_PLATE_ID\", \"License Plate ID\"}, {\"ORIGIN\", \"Origin\"}, {\"SOURCE_CREATE_TMSP\", \"Source Create Timestamp\"}, {\"SOURCE_CREATE_USER_ID\", \"Source Create User ID\"}, {\"BILLING_DT\", \"Billing Date\"}, {\"PO_NBR\", \"PO Nbr\"}, {\"ORDERED_DT\", \"Ordered Date\"}, {\"PO_RECEIPT_DT\", \"PO Receipt Date\"}, {\"MDM_SITE_ID_ALT\", \"MDM SITE ID ALT\"}, {\"ITEM_KEY\", \"Item Key\"}, {\"FACILITY_SEGMT_ID\", \"Facility Segment ID\"}})",
                "in",
                "    #\"Renamed Columns\""
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
