          {
            "name": "Units Ordered",
            "expression": [
              "",
              "CALCULATE (",
              "    SUMX (",
              "        'F_FD.Sales',",
              "        'F_FD.Sales'[Total Qty Ordered] * 'F_FD.Sales'[Store Pack]",
              "    ),",
              "    USERELATIONSHIP ( 'F_FD.Sales'[Customer Full Key], D_Customer[Customer Full Key] )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Sales",
