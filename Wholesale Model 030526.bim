          {
            "name": "Caito Top Ten Customer %",
            "expression": [
              "",
              "VAR TopMasterCustomers =",
              "    TOPN(",
              "        10,",
              "        ADDCOLUMNS(",
              "            VALUES('D_Caito Customer'[Master Customer Name]),",
              "            \"TotalSales%\", ",
              "            CALCULATE([Caito % of Sales])",
              "        ),",
              "        [TotalSales%],",
              "        DESC",
              "    )",
              "RETURN",
              "    CALCULATE(",
              "        [Caito % of Sales],",
              "        KEEPFILTERS(TopMasterCustomers)",
              "    )"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Caito\\Sales\\Customer Ranking",
            "lineageTag": "0d5290d1-572a-4a9f-916f-5ed418507521"
