            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_UAT_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_UAT_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    WAREHOUSE_DEAL_VW_View = FD_Schema{[Name=\"WAREHOUSE_DEAL_VW\",Kind=\"View\"]}[Data]",
                "in",
                "    WAREHOUSE_DEAL_VW_View"
              ]
            }
          }
        ],
