          {
            "name": "% Adjusted On Time Arrival",
            "expression": "DIVIDE([Order Recieved Adjusted On Time Quantity],[Order Recieved Quantity])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement\\ASN",
            "lineageTag": "86b13835-3679-4ff1-8b0d-5762e873549c"
          },
          {
            "name": "COTC (Adjusted)",
            "expression": [
              "",
              "VAR OROTQ = SUM('F_PO Compliance'[Adjusted Po Ontime Received Qty]) ",
              "VAR POORQ = SUM('F_PO Compliance'[Po Original Order Qty])  ",
              "VAR EQ = IF(DIVIDE(OROTQ,POORQ,0)>1.0,1.0, DIVIDE(OROTQ,POORQ,0)) ",
              "VAR CODE = SELECTEDVALUE('F_PO Compliance'[Final COTC Code])  ",
              "VAR ORQ = SUM('F_PO Compliance'[Po Order Received Qty])  ",
              "VAR FILL_RATE =  IF(DIVIDE(ORQ,POORQ,0)>1.0,1.0, DIVIDE(ORQ,POORQ,0)) ",
              "RETURN SWITCH (TRUE(), CODE = \"Late\",0, CODE = \"OnTime\", FILL_RATE, EQ)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement\\COTC",
            "lineageTag": "52c586bb-6d24-4a98-8dd1-f8a3e813955a"
          },
          {
            "name": "COTC LY (Adjusted)",
            "expression": [
              "",
              "VAR LYOROTQ = CALCULATE(SUM('F_PO Compliance'[Adjusted Po Ontime Received Qty]), DATEADD('D_Time Hierarchy'[Full Date],-1,YEAR))  ",
              "VAR LYPOORQ = CALCULATE(SUM('F_PO Compliance'[Po Original Order Qty]), DATEADD('D_Time Hierarchy'[Full Date],-1,YEAR))  ",
              "VAR EQ = IF(DIVIDE(LYOROTQ,LYPOORQ,0)>1.0,1.0, DIVIDE(LYOROTQ,LYPOORQ,0))  ",
              "VAR CODE = SELECTEDVALUE('F_PO Compliance'[Final COTC Code])  ",
              "VAR LYORQ = CALCULATE(SUM('F_PO Compliance'[Po Order Received Qty]), DATEADD('D_Time Hierarchy'[Full Date], -1,YEAR))  ",
              "VAR FILL_RATE = IF(DIVIDE(LYORQ,LYPOORQ,0)>1.0,1.0, DIVIDE(LYORQ,LYPOORQ,0))  ",
              "RETURN  SWITCH (TRUE(), CODE = \"Late\",0, CODE = \"OnTime\", FILL_RATE, EQ)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement\\COTC",
            "lineageTag": "71e44583-ddce-4d02-be3c-f814da0239f7"
          },
          {
            "name": "COTC TY (Adjusted)",
            "expression": [
              "",
              "VAR TYOROTQ = CALCULATE(SUM('F_PO Compliance'[Adjusted Po Ontime Received Qty]))  ",
              "VAR TYPOORQ = CALCULATE(SUM('F_PO Compliance'[Po Original Order Qty]))  ",
              "VAR EQ = IF(DIVIDE(TYOROTQ, TYPOORQ, 0) > 1.0, 1.0, DIVIDE(TYOROTQ, TYPOORQ, 0))  ",
              "VAR CODE = SELECTEDVALUE('F_PO Compliance'[Final COTC Code])  ",
              "VAR TYORQ = CALCULATE(SUM('F_PO Compliance'[Po Order Received Qty]))  ",
              "VAR FILL_RATE = IF(DIVIDE(TYORQ,TYPOORQ,0)>1.0,1.0, DIVIDE(TYORQ,TYPOORQ,0))  ",
              "RETURN  SWITCH (TRUE(), CODE = \"Late\",0, CODE = \"OnTime\", FILL_RATE, EQ)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement\\COTC",
            "lineageTag": "72563646-300b-42fb-a28f-b447e2bd93c2"
          },
          {
            "name": "COTC(LY) (Adjusted)",
            "expression": "CALCULATE(IF((DIVIDE([Order Recieved Adjusted On Time Quantity],[PO Ordered Quantity]) > 1.0),1.0, (DIVIDE([Order Recieved Adjusted On Time Quantity], [PO Ordered Quantity]))), FILTER (ALL ( 'D_Time Hierarchy' ), 'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[Date ID LY] )), ALL ( 'D_Time Hierarchy'))",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement\\COTC",
            "lineageTag": "7b594064-6e74-402e-89b2-2647490e0fde"
          },
          {
            "name": "COTC(TY) (Adjusted)",
            "expression": "CALCULATE(IF((DIVIDE([Order Recieved Adjusted On Time Quantity], [PO Ordered Quantity]) > 1.0),1.0,(DIVIDE([Order Recieved Adjusted On Time Quantity], [PO Ordered Quantity]))), FILTER (ALL ( 'D_Time Hierarchy' ), 'D_Time Hierarchy'[Date Key] IN VALUES('D_Time Hierarchy'[Date Key])), ALL ( 'D_Time Hierarchy'))",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement\\COTC",
            "lineageTag": "1141def8-3253-47d6-910a-4be504d9bf44"
          },
          {
            "name": "Order Recieved Adjusted On Time Quantity",
            "expression": "SUM('F_PO Compliance'[Adjusted Po Ontime Received Qty])",
            "formatString": "#,0",
            "displayFolder": "Procurement\\ASN",
            "lineageTag": "cb640d29-5eca-45be-b506-99779e4ac702"
          },
          {
            "name": "PO Adjusted On time Received %",
            "expression": "DIVIDE([Order Recieved Adjusted On Time Quantity],[PO Recieved Quantity])",
