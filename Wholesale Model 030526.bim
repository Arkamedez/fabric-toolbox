        ],
        "partitions": [
          {
            "name": "O_CustomDateTable",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": [
                "",
                "VAR MinDate = MIN('F_Item Out of Stock'[TRANSACTION_DT])",
                "VAR MaxDate = MAX('F_Item Out of Stock'[TRANSACTION_DT])",
                "VAR Today = TODAY()",
                "VAR Yesterday = TODAY() - 1",
                "VAR CurrentWeekStart = ((TODAY()) - (WEEKDAY(TODAY())-1))",
                "VAR CurrentWeekEnd = CurrentWeekStart + 7",
                "VAR LastWeekStart = CurrentWeekStart - 7",
                "VAR LastWeekEnd = CurrentWeekEnd - 7",
                "RETURN",
                "ADDCOLUMNS(",
                "    CALENDAR(MinDate, MaxDate),",
                "    \"DateAsText\", FORMAT([Date], \"MM/DD/YYYY\"),",
                "    \"DateSelection\", ",
                "        IF([Date] = Today, \"Today\", ",
                "        IF([Date] = Yesterday, \"Yesterday\",",
                "        IF(AND([Date] >= CurrentWeekStart, [Date] <= CurrentWeekEnd), \"Current Week\", \"Last Week\"))))"
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_Id",
            "value": "9392e98eae38490ebd9103dd4c66c822"
          }
        ]
      },
