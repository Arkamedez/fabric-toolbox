          {
            "name": "PO Orig Ordered Qty",
            "expression": "SUM('F_PO Compliance'[Po Original Order Qty])",
            "formatString": "#,0",
            "displayFolder": "Procurement",
            "lineageTag": "34735a55-0059-4e38-b6ac-41a1444f318b"
          },
          {
            "name": "PO On time Received %",
            "expression": "DIVIDE([Order Recieved On Time Quantity],[PO Recieved Quantity])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement",
            "lineageTag": "498b6f08-b4c1-49a4-ac56-55b9a912427d"
          },
          {
            "name": "PO Count Late",
            "expression": "CALCULATE(COUNT('F_PO Compliance'[Po Nbr]),'F_PO Compliance'[Po Ontime Received Flg]=\"N\")",
            "formatString": "#,##0;(#,##0)",
            "displayFolder": "Procurement",
            "lineageTag": "a2936cc4-b5f4-48df-811e-f269b9ed8f12",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "COTC(TY)",
            "expression": [
              "CALCULATE(IF((DIVIDE([Order Recieved On Time Quantity],[PO Ordered Quantity]) > 1.0),1.0,(DIVIDE([Order Recieved On Time Quantity],[PO Ordered Quantity]))),FILTER (",
              "",
              "        ALL ( 'D_Time Hierarchy' ),",
              "",
              "        'D_Time Hierarchy'[Date Key] IN VALUES('D_Time Hierarchy'[Date Key])",
              "",
              "    ),",
              "",
              "    ALL ( 'D_Time Hierarchy'))"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
