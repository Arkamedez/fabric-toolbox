        "partitions": [
          {
            "name": "O_Version History-3876c859-c45e-464f-9d1f-3a52e912c2f7",
            "mode": "import",
            "queryGroup": "Others",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText(\"\", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [#\"Version Number\" = _t, #\"Version Update Date\" = _t, #\"Developer Name\" = _t, #\"Version Notes\" = _t]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"Version Number\", type number}, {\"Version Update Date\", type text}, {\"Developer Name\", type text}, {\"Version Notes\", type text}}),",
                "    #\"Sorted Rows\" = Table.Sort(#\"Changed Type\",{{\"Version Number\", Order.Ascending}})",
                "in",
                "    #\"Sorted Rows\""
              ]
            }
          }
        ],
