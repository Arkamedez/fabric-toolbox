                "    ASN_PO_HEADER_Table = FD_Schema{[Name=\"ASN_PO_HEADER\",Kind=\"Table\"]}[Data],",
                "    #\"Changed Type\" = Table.TransformColumnTypes(ASN_PO_HEADER_Table,{{\"LOAD_TMSP\", type date}}),",
                "    #\"Filtered Rows\" = Table.SelectRows(#\"Changed Type\", each [SCHEDULED_DELIVERY_DT] > #date(1900, 12, 15))",
