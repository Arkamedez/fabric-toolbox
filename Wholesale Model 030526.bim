          {
            "name": "ASN PO Count",
            "description": "Count of PO Nbr's from Purchase Header based on Arrival Date",
            "expression": [
              "CALCULATE(count('F_Purchase Header'[PO Nbr]), USERELATIONSHIP('F_Purchase Header'[Arrival Dt], 'D_Time Hierarchy'[Full Date]))",
              "--needed for some ASN reports. Unsure how to make name more unique"
            ],
            "formatString": "0",
