          },
          {
            "name": "Dollar Sales (PA Gross)",
            "expression": "SUM('F_FD.Sales'[Total Dollar Sales]) + sum('F_FD.Sales'[Extended Promotion Allowance Amt])",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "3465d638-f17f-454b-8e6e-3d154e3df965"
          },
          {
            "name": "Dollar Ship - CP (GR PA Gross)",
            "expression": [
              "VAR seleWeek =",
              "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
              "VAR selePeriod =",
              "    MIN ( 'D_Time Hierarchy'[Fiscal Period Start Date] )",
              "RETURN",
              "    CALCULATE (",
              "        [Dollar Ship (GR PA Gross)],",
              "        FILTER (",
              "            ALL ( 'D_Time Hierarchy' ),",
              "            'D_Time Hierarchy'[Fiscal Week Start Date] >= selePeriod",
              "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
              "        ),",
              "        ALL ( 'D_Relative Time Slicer' )",
              "    )"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "24098920-42e5-451a-9f34-5d066cd9ebb4"
          },
          {
            "name": "Dollar Ship - CY (GR PA Gross)",
            "expression": [
              "VAR seleWeek =",
              "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
              "VAR seleYear =",
              "    MIN ( 'D_Time Hierarchy'[Fiscal Year Start Date] )",
              "RETURN",
              "    CALCULATE (",
              "        [Dollar Ship (GR PA Gross)],",
              "        FILTER (",
              "            ALL ( 'D_Time Hierarchy' ),",
              "            'D_Time Hierarchy'[Fiscal Week Start Date] >= seleYear",
              "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
              "        ),",
              "        ALL ( 'D_Relative Time Slicer' )",
              "    )"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "29d39fdb-d751-430c-9b48-e0fd925b72c3"
          },
          {
            "name": "Dollar Ship (GR PA Gross)",
            "expression": [
              "",
              "VAR BaseSales = SUM('F_FD.Sales'[Extended Dollars Ship])",
              " ",
              "VAR PA_Adjustment = ",
              "    CALCULATE(",
              "        SUM('F_FD.Sales'[Extended Promotion Allowance Amt]),",
              "        'F_FD.Sales'[facility id] = 1,",
              "        'F_FD.Sales'[transaction date] >= DATE(2026, 2, 1)",
              "    )",
              " ",
              "RETURN",
              "BaseSales + COALESCE(PA_Adjustment, BLANK())"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "dd165287-ff51-4e02-891c-dbfb45685f7f"
          },
          {
            "name": "Dollar Ship (Gross PA)",
            "expression": "SUM ( 'F_FD.Sales'[Extended Dollars Ship] ) + sum('F_FD.Sales'[Extended Promotion Allowance Amt])",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "6b288bf4-6412-4136-8f07-4fa70da38af5"
          },
          {
            "name": "Dollar Ship CP Var % (GR PA Gross)",
            "expression": "DIVIDE ( [Dollar Ship - CP (GR PA Gross)] - [Dollar Ship - LY CP], [Dollar Ship - LY CP] )",
            "formatString": "0.00%;(0.00%)",
