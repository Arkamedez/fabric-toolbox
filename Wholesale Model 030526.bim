              }
            ]
          },
          {
            "name": "Vendor List Price Amt",
            "expression": [
              "",
              "var temp = SUMMARIZECOLUMNS('F_Layer History'[Item Nbr], 'F_Layer History'[PO Nbr], \"Price\", SELECTEDVALUE('F_Layer History'[Vendor List Price Amt]))",
              "return sumx(temp, [Price])"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Purchase Measures\\Inventory",
            "lineageTag": "f0c6d95b-096a-4ac0-9c91-7a35a7d970b7",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ]
          },
          {
            "name": "Compute Sales - Fees",
            "expression": "[Sales with Representatives] - [Ext Cust Fee Amt with Representatives]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "48238b62-919d-4851-b76c-79afdba803c1"
          },
          {
            "name": "Ext Cust Fee Amt with Representatives",
            "expression": [
              "",
              "VAR valid_types = {1,5,6,7,11,12,13,15}",
              "",
              "VAR cur_type = SELECTEDVALUE('D_Retail Representative Customer'[Retail Representative Type Nbr])",
              "",
              "VAR custs = CALCULATETABLE(DISTINCT('D_Retail Representative Customer'[Customer Nbr]))",
              "",
              "RETURN",
              "IF(cur_type in valid_types, CALCULATE([Ext Cust Fee Amt], D_Customer[Customer Nbr] in custs))"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "cf34f6fa-ce98-443e-b962-cb4d4032230d"
          },
          {
            "name": "LY Compute Sales - Fees",
            "expression": "[LY Sales with Representatives] - [LY Ext Cust Fee Amt with Representatives]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "9f9c82e1-8f57-43d5-8de4-af5afa43b1f3"
          },
          {
            "name": "LY Ext Cust Fee Amt with Representatives",
            "expression": [
              "",
              "CALCULATE (",
              "   [Ext Cust Fee Amt with Representatives],",
              "   FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[Date ID LY] )",
              "    ),",
              "    ALL('D_Relative Time Slicer')",
              "    )",
              "    "
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "44386269-daff-4ba7-9141-5acd90ab2484"
          },
          {
            "name": "LY Sales with Representatives",
            "expression": [
              "",
              "CALCULATE (",
              "    [Sales with Representatives],",
              "   FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[Date ID LY] )",
              "    ),",
              "    ALL('D_Relative Time Slicer')",
              "    )",
              "    "
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "780e0290-8d01-42f7-acda-a6e392d157dc"
          },
          {
            "name": "Total All Excise Taxes",
            "expression": "CALCULATE([Total Excise Taxes] + [Total Other Excise Taxes])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "d23efff3-d4dc-4447-9ffd-f716f04e2872"
          },
          {
            "name": "Total Excise Taxes",
            "expression": "CALCULATE([State Excise Tax.] + [County Excise Tax.] + [City Excise Tax.])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "f57300e8-5fda-45ed-8871-38880370dd1f"
          },
          {
            "name": "Total Other Excise Taxes",
            "expression": "CALCULATE([Other Excise Tax 01.] + [Other Excise Tax 02.] + [Other Excise Tax 03.])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "2a941848-984c-4300-87d7-1a422242bdcd"
          },
          {
            "name": "VAR LY % Compute Sales",
            "expression": "DIVIDE([Compute Sales - Fees] - [LY Compute Sales - Fees], [LY Compute Sales - Fees], 0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "6ae763cf-933d-46ac-ac52-9a73ccb3111d"
          },
          {
            "name": "Var LY % Total Sales Amount with Representatives",
            "expression": "DIVIDE([Sales with Representatives] - [LY Sales with Representatives], [LY Sales with Representatives], 0) ",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "60968f6f-2d0a-405f-856e-22ceb7c8ea7d"
          },
          {
            "name": "Total Ext Reflect Allows Amt",
            "expression": "sum('F_FD.Sales'[TOT_EXT_REFLECT_ALLOW_AMT])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "f1ccda31-87f3-438e-a6a3-23224ffd5929"
          },
          {
            "name": "% Financial Layer Gain",
            "expression": "CALCULATE((([Ext Pure Sell] - [Layer Extended Cost.]) + [Reflect RPA AMT Ext]) / [Ext Pure Sell])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "9203259f-4a2e-4e9b-8341-2872b9b3e7eb"
          },
          {
            "name": "Ext Case Label Charge",
            "expression": "[Qty For Extension] * sum('F_FD.Sales'[LBL Case Charge])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "f607e266-b202-4bbb-8233-078fb8a06b20"
          },
          {
            "name": "Ext Product Cube",
            "expression": "[Qty Shipped] * SUM('F_FD.Sales'[Cube Value])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "a458371f-bde6-4ce2-9e74-ab708cf67a3b"
          },
          {
            "name": "Extended City Excise Tax",
            "expression": "[Qty For Extension] * [City Excise Tax.]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "751fb24a-c402-4185-a7c2-f522cbaf7ce3"
          },
          {
            "name": "Extended County Excise Tax",
            "expression": "[County Excise Tax.] * [Qty For Extension]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "28658b51-8c9d-48f5-9925-fe5024f17661"
          },
          {
            "name": "Extended Excise Taxes",
            "expression": "[Qty For Extension] * [Total Excise Taxes]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "a8f49970-4da0-4a40-a48a-ca67ed0acda0"
          },
          {
            "name": "Extended Markup",
            "expression": "[Qty For Extension] * sum('F_FD.Sales'[Markup Dollars Per ship Unit])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "b69553a5-5166-4c02-9cde-1dc1b84dab93"
          },
          {
            "name": "Extended NSM Fee",
            "expression": "[Qty For Extension] * sum('F_FD.Sales'[Buyer Advantage Amt])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "49b61d14-ab23-42d3-8770-bd4e3ccc1cef"
          },
          {
            "name": "Extended NY Sales Tax",
            "expression": "[Qty For Extension] * [Other Excise Tax 02.]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "47e84352-c37e-4050-b193-2e8edd0a7a63"
          },
          {
            "name": "Extended Pure Sell Plus Markup",
            "expression": "[Ext Pure Sell] + [Extended Markup]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "8f9e36cd-b30e-4782-b217-dba5b39aeb64"
          },
          {
            "name": "Extended Stamp Tax",
            "expression": "[Total Stamp Taxes] * [Qty For Extension]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "b70041e0-eea8-472e-addb-cca99f7effda"
          },
          {
            "name": "Extended State Excise Taxes",
            "expression": "[State Excise Tax.] * [Qty For Extension]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "ec4af97b-4a07-454e-bace-d4ad4eb83526"
          },
          {
            "name": "Extended State Stamp Tax",
            "expression": "[State Stamp Tax.] * [Qty For Extension]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "116bd3e6-f4f8-480c-898e-aec1ec8bc559"
          },
          {
            "name": "Financial Layer Gain",
            "expression": "[Ext Pure Sell] - [Layer Extended Cost.] + [Reflect RPA AMT Ext]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "3ba2cf0b-f754-4c2b-a8a7-cb517afe3e5f",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ]
          },
          {
            "name": "Financial Markup",
            "expression": [
              "",
              "VAR OutReasonCode = SELECTEDVALUE('F_FD.Sales'[Out Reason Code])",
              "VAR NoChargeItemCode = SELECTEDVALUE('F_FD.Sales'[No Charge Item CDE])",
              "-- The multiplication for Markup is inside of the conditional statement and duplicated otherwise the summation does not work properly",
              "RETURN",
              "        IF(",
              "            OutReasonCode IN {\"004\", \"011\"},",
              "            0,",
              "             IF(",
              "                NoChargeItemCode = \"*\",",
              "                SUMX('F_FD.Sales',[Markup Dollars Per ship Unit]),",
              "                SUMX('F_FD.Sales', ('F_FD.Sales'[Quantity Sold] - 'F_FD.Sales'[Quantity Scratched]) * 'F_FD.Sales'[Markup Dollars Per ship Unit])))"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "1ef65aa7-bd8e-47c1-8d01-ce9456c7c0a6"
          },
          {
            "name": "Financial Pure Sell",
            "expression": [
              "",
              "-- please don't try to optimize this code. It either won't load or does not calculate properly if anything is changed",
              "sumx('F_FD.Sales',",
              "if(SELECTEDVALUE('F_FD.Sales'[Facility ID]) in {15, 61, 58, 71}, ",
              "    if(SELECTEDVALUE('F_FD.Sales'[Out Reason Code]) in {\"004\", \"011\"}, ",
              "        0, ",
              "        if(SELECTEDVALUE('F_FD.Sales'[No Charge Item CDE]) = \"*\", ",
              "            1, ",
              "           'F_FD.Sales'[Quantity Sold] - 'F_FD.Sales'[Quantity Scratched]) * ('F_FD.Sales'[Final Sell Amt] - 'F_FD.Sales'[LBL Case Charge] - 'F_FD.Sales'[Price Adjustment] - [Total All Excise Taxes] + 'F_FD.Sales'[Leakage Amt] - ",
              "            if(SELECTEDVALUE('F_FD.Sales'[Markup Spread Flag]) in {\"1\",\"2\"}, ",
              "                'F_FD.Sales'[Markup Dollars Per ship Unit], ",
              "                0) - ",
              "            if(SELECTEDVALUE('F_FD.Sales'[Markup Spread Flag]) in {\"2\"}, ",
              "                'F_FD.Sales'[Freight Amt], ",
              "                0))), ",
              "        if(SELECTEDVALUE('F_FD.Sales'[Out Reason Code]) in {\"004\", \"011\"}, ",
              "            0, ",
              "            if(SELECTEDVALUE('F_FD.Sales'[No Charge Item CDE]) = \"*\", ",
              "                1, ",
              "                'F_FD.Sales'[Quantity Sold] - 'F_FD.Sales'[Quantity Scratched]) * ('F_FD.Sales'[Final Sell Amt] - 'F_FD.Sales'[LBL Case Charge] - 'F_FD.Sales'[Freight Amt] - 'F_FD.Sales'[Markup Dollars Per ship Unit] - 'F_FD.Sales'[Fuel Charge Amt] - 'F_FD.Sales'[Price Adjustment] - [Total All Excise Taxes] + 'F_FD.Sales'[Leakage Amt] + 'F_FD.Sales'[Item Level Markup Amt 02] ))))"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "d8569fcb-5cce-4fc2-9f95-f042051f67d2"
          },
          {
            "name": "Layer Cost Less RPA",
            "expression": "[Layer Ext Cost] - [Reflect RPA AMT Ext]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "363a71d6-c2d6-4009-85bb-9ac63a102c04"
          },
          {
            "name": "Layer Gain",
            "expression": "[Ext Pure Sell] - [Layer Ext Cost]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "28b34ceb-df75-4a4f-a362-03731a764a51"
          },
          {
            "name": "Layer Gain %",
            "expression": "([Ext Pure Sell] - [Layer Ext Cost]) / [Ext Pure Sell]",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "a62e7554-e90b-4f50-8d9c-6230a11876ba"
          },
          {
            "name": "Layer Gain Net of RPA",
            "expression": "[Ext Pure Sell] - [Layer Ext Cost] - [Reflect RPA AMT Ext]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "d16e31bc-d659-4adf-8416-ad9bb922b30d"
          },
          {
            "name": "Layer Gain Plus Markup",
            "expression": "[Ext Pure Sell] - [Layer Ext Cost] + [Extended Markup]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "3ec17e41-d365-411a-b7c0-71e2e756d1df"
          },
          {
            "name": "Pure Sell",
            "expression": [
              "",
              "sumx('F_FD.Sales','F_FD.Sales'[Final Sell Amt] - ",
              "if(SELECTEDVALUE('F_FD.Sales'[Admin Allocation Flag]) = \"Y\", ",
              "    0, ",
              "    'F_FD.Sales'[LBL Case Charge]) ",
              "    + 'F_FD.Sales'[Price Adjustment] - 'F_FD.Sales'[Leakage Amt] - ",
              "    if(related(D_Item[Item Dept ID]) = \"050\", ",
              "        0, ",
              "        [Total All Excise Taxes]) - ",
              "    if(SELECTEDVALUE('F_FD.Sales'[Markup Spread Flag]) = \"2\", ",
              "        'F_FD.Sales'[Freight Amt], ",
              "        0) - ",
              "    if(SELECTEDVALUE('F_FD.Sales'[Markup Spread Flag]) in {\"1\", \"2\"}, ",
              "        'F_FD.Sales'[Markup Dollars Per ship Unit], ",
              "        0))"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "d102bc71-2446-417e-b984-8e6c1dd13417"
          },
          {
            "name": "Qty For Extension",
            "expression": [
              "",
              "VAR SOLD = SUM('F_FD.Sales'[Quantity Sold])",
              "VAR SHIPPED = SUM('F_FD.Sales'[Shipped Qty])",
              "VAR IsNoChargeItem = CALCULATE(COUNTROWS('F_FD.Sales'), 'F_FD.Sales'[No Charge Item CDE] = \"*\") > 0",
              "VAR IsInternalOrder = CALCULATE(COUNTROWS('F_FD.Sales'), 'F_FD.Sales'[Order Source] = \"I\") > 0",
              "VAR IsOutReasonCode000 = CALCULATE(COUNTROWS('F_FD.Sales'), 'F_FD.Sales'[Out Reason Code] = \"000\") > 0",
              "RETURN",
              "IF(",
              "    OR(IsNoChargeItem, IsInternalOrder),",
              "    1,",
              "    IF(",
              "        AND(SOLD = 0, IsOutReasonCode000),",
              "        0,",
              "        SHIPPED",
              "        )",
              ")"
            ],
            "formatString": "#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "d3b8d88d-c30b-4547-9c7c-0aef70909011"
          },
          {
            "name": "Reflect RPA AMT Ext",
            "expression": "sum('F_FD.Sales'[Total Ext Ad Allowance Amt])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "a6fc9aa3-364b-4c58-b885-9250a65c75f9"
          },
          {
            "name": "Total Allowance Amt",
            "expression": "sum('F_FD.Sales'[Reflect Allowance Amt]) + [Ad allow Amt]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "9bc50289-4e4f-4412-b7d0-45d26c9dadbc"
          },
          {
            "name": "Total Deal",
            "expression": "sum('F_Warehouse Deal'[BILLBACK_AMT]) + sum('F_Warehouse Deal'[OFF_INVOICE_AMT])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "a0971438-3037-41f3-9f65-6345b8e054d9"
          },
          {
            "name": "Total Extended Taxes",
            "expression": "[Total Taxes] * [Qty For Extension]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "6707d1ff-c887-494a-88f0-f77c0cc4dc24"
          },
          {
            "name": "Total Stamp Taxes",
            "expression": "CALCULATE([State Stamp Tax.] + [County Stamp Tax.] + [City Stamp Tax.])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "03d92ab1-3e99-4b4a-833f-2b13d2e6b44a"
          },
          {
            "name": "Total Taxes",
            "expression": "[City Stamp Tax.] + [Total All Excise Taxes]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "06a43502-fcf0-4302-9a8f-9393ff491b98"
          },
          {
            "name": "Credit % of Sales",
            "description": "% of credits to sales",
            "expression": [
              "",
              "var sales = CALCULATE([Total Sales Amount], all('D_Credit Code'))",
              "return",
              "DIVIDE( -1 * [Total Credits Amount], sales)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "11d2181a-4d0e-4968-902e-cdf4857f9306"
          },
          {
            "name": "LY Credit % of Sales",
            "description": "% of credits to sales for last year",
            "expression": [
              "CALCULATE (",
              "    [Credit % of Sales],",
              "    FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[DATE ID LY] )",
              "    ),",
              "    ALL('D_Relative Time Slicer')",
              ")"
            ],
            "formatString": "#,0.00%;-#,0.00%;#,0.00%",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "373febb3-6716-4651-8846-2b583cb9e665"
          },
          {
            "name": "LY Total Credits Amount",
            "description": "Total Credits Amount for last year",
            "expression": [
              "CALCULATE (",
              "    [Total Credits Amount],",
              "    FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[DATE ID LY] )",
              "    ),",
              "    ALL('D_Relative Time Slicer')",
              ")"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "d7bb4690-24f7-42ba-8e21-ea717acac52e"
          },
          {
            "name": "Total Credits Amount",
            "description": "Total Credits Amount for this year",
            "expression": "CALCULATE(sum('F_FD.Sales'[Total Sales Amt]), 'D_Order Type'[Order Type Code] = \"CR\")",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "d47bcc02-02f9-4ef6-8ac5-c801b0dd5d5b"
          },
          {
            "name": "VAR LY % Total Credits Amount",
            "description": "Total Credits Amount variance % to last year",
            "expression": "DIVIDE([LY Total Credits Amount] - [Total Credits Amount], [LY Total Credits Amount])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "844e430a-25ab-4329-a353-68fb4b8fb575"
          },
          {
            "name": "Var LY Total Credits Amount",
            "description": "Variance of credits from this year to last year",
            "expression": "[LY Total Credits Amount] - [Total Credits Amount]",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "e1b7ba6f-fb99-4753-96e8-18fbdfbbd0ab"
          },
