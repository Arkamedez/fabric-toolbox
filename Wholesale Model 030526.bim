          {
            "type": "calculated",
            "name": "Reflected Total Amount DC Sales",
            "dataType": "double",
            "isDataTypeInferred": true,
            "isHidden": true,
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    'F_FD.Sales'[Facility ID] = 1, 'F_FD.Sales'[Extended Promotion Allowance Amt],",
              "    'F_FD.Sales'[Facility ID] <> 1 && 'F_FD.Sales'[Random Weight Flag] = \"R\", 'F_FD.Sales'[Random Weight]*'F_FD.Sales'[AD Allowance Amt],",
              "    'F_FD.Sales'[Facility ID] <> 1 && 'F_FD.Sales'[Random Weight Flag] <> \"R\", 'F_FD.Sales'[Extended Promotion Allowance Amt]",
              ")"
            ],
            "lineageTag": "10ff614f-515f-4b2f-9ac0-af50d35c10ab",
            "summarizeBy": "sum",
            "changedProperties": [
              {
                "property": "IsHidden"
