        ],
        "measures": [
          {
            "name": "MAX_INVENTORY_CASES",
            "expression": [
              "sum('D_Item'[SAFETY_STOCK])+SUM('D_Item'[CYCLE_STOCK])+",
              "SUMX('D_Item', CEILING(IF('D_Item'[ORDER_INTERVAL_WEEKS]=0,1,'D_Item'[ORDER_INTERVAL_WEEKS])*",
              "IF(ISBLANK('D_Item'[Cases per week]),0,'D_Item'[Cases per week])/7,1))+SUM('D_Item'[Cases per week])",
              "+sum('D_Item'[IN_PROCESS_REG_AMT])+sum('D_Item'[IN_PROCESS_PROMO])+sum('D_Item'[Reserve Committed])+",
              "sum('D_Item'[Reserve Uncommitted])+sum('D_Item'[Storage Committed])+sum('D_Item'[Storage Uncommitted])+sum('F_Purchase Detail'[Purchase Qty])+sum('D_Item'[ORDER_POINT])+SUMX('D_Item',CEILING(IF(ISBLANK('D_Item'[Cases per week]),0,'D_Item'[Cases per week])*0.5,1))"
            ],
            "lineageTag": "e3a9e965-9f60-464e-9988-1f1c6c6e6b50",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "All Short date Estimated No.Of days Inv",
            "expression": [
              "",
              " ",
              "VAR Closed_date_qty =",
              "    IF(sum(D_Item[Store Pack Case])>0,",
              "DIVIDE(sum('F_Inventory Detail'[Prod Qty]),sum(D_Item[Store Pack Case]))",
              ")",
              "RETURN",
              "    IF(",
              "        sum(D_Item[Inventory Total])>0,",
              "        DIVIDE(",
              "            Closed_date_qty,",
              "            SUM(D_Item[Daily Forecast]),",
              "            0  -- Default value to replace division by zero (in this case, 0)",
              "       ",
              "    ))",
              ""
            ],
            "lineageTag": "3f48b6b8-cb32-4dd7-88a9-968156364d57",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Closed Date QTY",
            "expression": [
              "IF(sum(D_Item[Store Pack Case])>0,",
              "DIVIDE(sum('F_Inventory Detail'[Prod Qty]),sum(D_Item[Store Pack Case]))",
              ")",
              ""
            ],
            "formatString": "0",
            "lineageTag": "24854222-7b2c-4bb6-a745-23f7b48ab4be",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ]
          }
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          },
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          }
        ]
      },
