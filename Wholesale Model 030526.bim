          {
            "name": "PTD Shipped Qty (000's)",
            "description": "Shipped quantity - period to date (sales in thousands)",
            "expression": [
              "VAR seleWeek =",
              "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
              "VAR selePeriod =",
              "    MIN ( 'D_Time Hierarchy'[Fiscal Period Start Date] )",
              "RETURN",
              "    CALCULATE (",
              "        [Shipped Qty (000's)],",
              "        FILTER (",
              "            ALL ( 'D_Time Hierarchy' ),",
              "            'D_Time Hierarchy'[Fiscal Week Start Date] >= selePeriod",
              "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
              "        ),All('D_Relative Time Slicer')",
              "    )"
            ],
            "formatString": "#,0",
            "displayFolder": "Sales",
            "lineageTag": "ab937c0e-ef9e-4f09-8bd1-1a7d6959941c",
            "changedProperties": [
