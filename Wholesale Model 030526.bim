          {
            "name": "Selected Filters- Caito",
            "expression": [
              "",
              "VAR Caito = \"",
              "\"",
              "",
              "VAR FiscalYear = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Year]),",
              "                 \"Fiscal Year = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Year]), 'D_Time Hierarchy'[Fiscal Year], \", \") & Caito, \"\")",
              "",
              "VAR FiscalQuaterdetail = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Quarter Detail]),",
              "                 \"Fiscal Quarter Detail = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Quarter Detail]), 'D_Time Hierarchy'[Fiscal Quarter Detail], \", \") & Caito, \"\")",
              "",
              "",
              "VAR FiscalPeriodwithEndDate = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Period with End Date]),",
              "                 \"Fiscal Period with End Date = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Period with End Date]), 'D_Time Hierarchy'[Fiscal Period with End Date], \", \") & Caito, \"\")",
              "",
              "VAR Weekending = IF(ISFILTERED('D_Time Hierarchy'[Week Ending]),",
              "                 \"Week Ending = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Week Ending]), 'D_Time Hierarchy'[Week Ending], \", \") & Caito, \"\")",
              "",
              "VAR RelativeTimePrompt = IF(ISFILTERED('D_Relative Time Slicer'[Relative Time Prompt]),",
              "                 \"Relative Time Prompt = \" & CONCATENATEX(ALLSELECTED('D_Relative Time Slicer'[Relative Time Prompt]), 'D_Relative Time Slicer'[Relative Time Prompt], \", \") & Caito, \"\")",
              "VAR AccountManager = IF(ISFILTERED('D_Caito Customer'[Account Manager]),",
              "                \"Account Manager = \" & CONCATENATEX(ALLSELECTED('D_Caito Customer'[Account Manager]), 'D_Caito Customer'[Account Manager], \", \") & Caito, \"\")",
              "",
              "VAR FacilityID = IF(ISFILTERED('D_Item'[Facility Nbr Desc]),",
              "               \"Facility = \" & CONCATENATEX(ALLSELECTED('D_Item'[Facility Nbr Desc]), 'D_Item'[Facility Nbr Desc], \", \") & Caito, \"\")",
              "",
              "VAR Buyer = IF(ISFILTERED('D_Caito Address Book'[Buyer Desc]),",
              "              \"Buyer = \" & CONCATENATEX(ALLSELECTED('D_Caito Address Book'[Buyer Desc]), 'D_Caito Address Book'[Buyer Desc], \", \") & Caito, \"\")",
              "",
              "",
              "VAR MasterCustomer = IF(ISFILTERED('D_Caito Customer'[Master Customer Name]),",
              "              \"Master Customer = \" & CONCATENATEX(ALLSELECTED('D_Caito Customer'[Master Customer Name]), 'D_Caito Customer'[Master Customer Name], \", \") & Caito, \"\")",
              "",
              "",
              "VAR Customer = IF(ISFILTERED('D_Caito Customer'[Customer Description]),",
              "             \"Customer = \" & CONCATENATEX(ALLSELECTED('D_Caito Customer'[Customer Description]), 'D_Caito Customer'[Customer Description], \", \") & Caito, \"\")",
              "",
              "VAR OrderType = IF(ISFILTERED('D_Caito Sales Order Type'[Sales Order Type Description]),",
              "             \"Order Type = \" & CONCATENATEX(ALLSELECTED('D_Caito Sales Order Type'[Sales Order Type Description]), 'D_Caito Sales Order Type'[Sales Order Type Description], \", \") & Caito, \"\")",
              "",
              "VAR ItemDesc = IF(ISFILTERED('D_Caito Item'[Item Detail Description]),",
              "             \"Item = \" & CONCATENATEX(ALLSELECTED('D_Caito Item'[Item Detail Description]), 'D_Caito Item'[Item Detail Description], \", \") & Caito, \"\")",
              "",
              " RETURN",
              " FiscalYear&Fiscalquaterdetail&FiscalPeriodwithEndDate&Weekending&RelativeTimePrompt&AccountManager&FacilityID&Buyer&MasterCustomer&Customer&OrderType&ItemDesc"
            ],
            "displayFolder": "Caito\\Dimensions",
            "lineageTag": "a0434843-97fe-4d4f-b6af-25d6552987a9"
          },
          {
