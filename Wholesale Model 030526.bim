          {
            "name": "DC Labor Overtime % (DY)",
            "expression": "([DC Labor Overtime Hr (DY)] / [DC Labor Hr (DY)])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Labor",
            "lineageTag": "ec3fdb7a-dbb8-4b94-a874-a49a85a3b35f"
          },
          {
            "name": "DC Labor Amt (Wk)",
            "expression": "Sum('F_DC Day Labor'[Earnings Amt])",
            "formatString": "#,0.00",
            "displayFolder": "Labor",
            "lineageTag": "cf3455b2-2de8-404f-b787-810fb9807b83"
          },
          {
            "name": "DC Labor Hr (DY)",
            "expression": [
              "",
              "    CALCULATE(",
              "        SUM('F_DC Day Labor'[Work Hours Qty])",
              "        , NOT 'F_DC Week Labor'[Earn Code Id] IN {\"OT1\",\"OT2\",\"OT15\",\"15O\",\"1OT\"}",
              "    )"
            ],
            "formatString": "#,0",
            "displayFolder": "Labor",
            "lineageTag": "5e4f562e-bbde-44ae-a71a-35300a214eeb",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ]
          },
          {
            "name": "DC Labor Hr (Wk)",
            "expression": [
              "",
              "    CALCULATE(",
              "        SUM('F_DC Week Labor'[Work Hours Qty])",
              "        , NOT 'F_DC Week Labor'[Earn Code Id] IN {\"OT1\",\"OT2\",\"OT15\",\"15O\",\"1OT\"}",
              "    )"
            ],
            "formatString": "#,0",
            "displayFolder": "Labor",
            "lineageTag": "43715b25-e9d1-46df-a245-120cc2e3ce5b",
            "annotations": [
              {
