            "name": "LY Total Sales Amt 1",
            "description": "Total sales amount for last year",
            "expression": [
              "var eq = CALCULATE (",
              "    SUM ( 'F_FD.Sales'[Total Sales Amt] ),",
              "   FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[Date ID LY] )",
              "    ),all('D_Relative Time Slicer'))",
              "return",
              "IF(eq=0,BLANK(),eq)"
