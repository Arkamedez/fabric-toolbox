          {
            "name": "D_Facility Segment-c385f8a4-5e5c-4483-9e61-42a2e8a860f6",
            "mode": "dual",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    MDM_Schema = EDW_Database{[Name=\"MDM\",Kind=\"Schema\"]}[Data],",
                "    FACILITY_SEGMENT_VW_View = MDM_Schema{[Name=\"FACILITY_SEGMENT_VW\",Kind=\"View\"]}[Data],",
                "    #\"Removed Other Columns\" = Table.SelectColumns(FACILITY_SEGMENT_VW_View,{\"FACILITY_PK\", \"FACILITY_NBR\", \"FACILITY_DESC\", \"BUSINESS_UNIT\", \"OPERATING_UNIT\", \"BILLING_SYSTEM_CD\", \"PLATFORM_TYPE\", \"EXE_DIV_NUM\", \"ACNTG_UNIT\", \"DIV_PREFIX_1\", \"DIV_PREFIX_2\", \"DSTR_CUST_NUM\", \"ACTIVE_FLAG\", \"UPDATE_TYPE\", \"ACNTG_CO_DC\", \"MDV_DIV\", \"DUNS_NUMBER\", \"CITY\", \"STATE\", \"COUNTRY\", \"FEDERAL_ID\", \"PROCESS_ACTIVE_FLG\", \"OMS_DC\", \"UPSTREAM_DC_TYP_CD\", \"HANDHELD_STATUS_CD\", \"INSITE_STATUS_CD\", \"OMS_CODE_SCHEME_CD\", \"FACILITYID_UPSTREAM\", \"FACILITYID_HEADER\", \"ENTERPRISE_ID\", \"ENTERPRISE_DESC\", \"REGION_ID\", \"REGION_NM\", \"DIVISION_ID\", \"DIVISION_NAME\", \"FACILITY_SEGMT_PK\", \"FACILITY_SEGMT_NBR\", \"FACILITY_SEGMT_NM\", \"FACILITY_GROUP_CD\", \"FACILITY_NBR_DESC\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Removed Other Columns\",{{\"FACILITY_PK\", \"Facility Key\"}, {\"FACILITY_SEGMT_PK\", \"Facility Segment Key\"}, {\"MDV_DIV\", \"Military Division\"}, {\"FACILITY_NBR\", \"Facility Nbr\"}, {\"FACILITY_DESC\", \"Facility\"}, {\"BUSINESS_UNIT\", \"Business Unit\"}, {\"FACILITY_SEGMT_NM\", \"Facility Segment\"}, {\"FACILITY_SEGMT_NBR\", \"Facility Segment Nbr\"}, {\"DIVISION_NAME\", \"Division\"}, {\"DIVISION_ID\", \"Division ID\"}, {\"REGION_NM\", \"Region\"}, {\"REGION_ID\", \"Region ID\"}, {\"ENTERPRISE_DESC\", \"Enterprise\"}, {\"ENTERPRISE_ID\", \"Enterprise ID\"}, {\"FACILITYID_HEADER\", \"Facility Header ID\"}, {\"FACILITYID_UPSTREAM\", \"Facility Upstream ID\"}, {\"OMS_CODE_SCHEME_CD\", \"OMS Code Scheme Code\"}, {\"INSITE_STATUS_CD\", \"Insite Status Code\"}, {\"HANDHELD_STATUS_CD\", \"Handheld Status Code\"}, {\"UPSTREAM_DC_TYP_CD\", \"Upstream DC Type Code\"}, {\"OMS_DC\", \"OMS DC\"}, {\"PROCESS_ACTIVE_FLG\", \"Process Active Flag\"}, {\"FEDERAL_ID\", \"Federal ID\"}, {\"COUNTRY\", \"Country\"}, {\"STATE\", \"State\"}, {\"CITY\", \"City\"}, {\"OPERATING_UNIT\", \"Operating Unit\"}, {\"BILLING_SYSTEM_CD\", \"Billing System Code\"}, {\"PLATFORM_TYPE\", \"Platform Type\"}, {\"ACNTG_UNIT\", \"Accounting Unit\"}, {\"EXE_DIV_NUM\", \"EXE Division Nbr\"}, {\"DIV_PREFIX_1\", \"Division Prefix 1\"}, {\"DIV_PREFIX_2\", \"Division Prefix 2\"}, {\"DSTR_CUST_NUM\", \"Distribution Customer Nbr\"}, {\"ACTIVE_FLAG\", \"Active Flag\"}, {\"UPDATE_TYPE\", \"Update Type\"}, {\"ACNTG_CO_DC\", \"Accounting Code DC\"}, {\"DUNS_NUMBER\", \"DUNS Nbr\"}, {\"FACILITY_GROUP_CD\", \"Facility Group\"}, {\"FACILITY_NBR_DESC\", \"Facility Nbr Desc\"}}),",
                "    #\"Filtered Rows\" = Table.SelectRows(#\"Renamed Columns\", each ([Facility Segment Key] <> null))",
                "in",
                "    #\"Filtered Rows\""
              ]
            }
          }
