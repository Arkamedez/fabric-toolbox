            ]
          },
          {
            "name": "Not Shipped %(Buyer)",
            "description": "Not shipped case quantity % {Specific to ship error group buyer} (date is less than today) (day level)",
            "expression": "DIVIDE ( [Not Shipped(Buyer)], [Ordered Case  Qty] )",
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Ad-hoc Fill Rate Measures",
            "lineageTag": "6b8a4d8b-e40c-45f4-a728-6216abeeb8d0",
            "changedProperties": [
              {
                "property": "FormatString"
              },
