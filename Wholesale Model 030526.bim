          {
            "name": "O_Last Refreshed Date-3d49fe69-1e53-4661-a4b9-aa98f810b610",
            "mode": "import",
            "queryGroup": "Others",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Value.NativeQuery(Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\")",
                "    {[Name=EDW_Database]}[Data],",
                "     \"select max(CREATE_TMSP) as Created_TM,max(UPDT_TMSP) \"\"Date Last Refreshed\"\" from \"\"EDW\"\".\"\"FD\"\".\"\"DC_SALES_HST\"\"\",",
                "      null, [EnableFolding=true])",
                "in",
                "    Source"
              ]
            }
          }
        ],
        "changedProperties": [
