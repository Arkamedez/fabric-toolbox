                "    ITEM_SHELF_LIFE_CHANGE_VW_View = FD_Schema{[Name=\"ITEM_SHELF_LIFE_CHANGE_VW\",Kind=\"View\"]}[Data],",
                "    #\"Renamed Columns\" = Table.RenameColumns(ITEM_SHELF_LIFE_CHANGE_VW_View,{{\"CURRENT_FLG\", \"Current Flag\"}, {\"WAREHOUSE_CD\", \"WHSE Code\"}, {\"ITEM_KEY\", \"Item Key\"}, {\"ITEM_DESCRIP\", \"Item\"}, {\"UPC_UNIT\", \"UPC Unit\"}, {\"STOCK_FAC\", \"Stock Facility\"}, {\"ITEM_ADDED_DT\", \"Item Added Date\"}, {\"PRE_SHELL_LIFE\", \"Previous Shelf Life\"}, {\"FACILITY_ID\", \"Facility ID\"}, {\"ITEM_NBR_HS\", \"Item Nbr HS\"}, {\"START_DT\", \"Start Date\"}, {\"END_DT\", \"End Date\"}, {\"PRE_CODE_DT_MAX\", \"Previous Code Date Max\"}, {\"PRE_CODE_DT_FLG\", \"Previous Code Date Flag\"}, {\"PRE_CODE_DT_MIN\", \"Previous Code Date Min\"}, {\"ITEM_DEPT_ID\", \"Item Dept ID\"}, {\"LAST_MAINT_USER_ID\", \"Last Maint User ID\"}, {\"ITEM_NBR\", \"Item Nbr\"}, {\"CHANGE_DT\", \"Change Date\"}, {\"ROW_NBR\", \"Row Nbr\"}, {\"POST_CODE_DT_FLG\", \"Post Code Date Flag\"}, {\"POST_CODE_DT_MAX\", \"Post Code Date Max\"}, {\"POST_CODE_DT_MIN\", \"Post Code Date Min\"}, {\"POST_SHELF_LIFE\", \"Post Shelf Life\"}, {\"MERCH_CLASS\", \"Merch Class\"}, {\"DEPT_KEY\", \"Dept Key\"}})",
                "in",
                "    #\"Renamed Columns\""
              ]
            }
          }
        ],
