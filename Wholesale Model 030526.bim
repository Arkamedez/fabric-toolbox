              }
            ]
          },
          {
            "name": "Sales Var to LY % (F_FD.Sales)",
            "description": "Sales amount % variance to last (date is less than today)",
            "expression": [
              "DIVIDE (",
              "    ( [Total Sales Amt] - 'O_Report Measure'[LY Sales Amt (Sales Dt < Today)] ),",
              "    'O_Report Measure'[LY Sales Amt (Sales Dt < Today)]",
              ")"
            ],
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Sales",
            "lineageTag": "1bac7a82-cf63-4e16-8e3b-f708d49d85f4",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "LY Sales Amt (Sales Dt < Today)",
            "description": "Sales amount for last year (date is less than today)",
            "expression": [
              "",
              "CALCULATE (",
              "    [Total Sales Amt],",
              "    FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[Date ID LY] )",
              "    ),",
              "    ALL ( 'D_Relative Time Slicer' )",
              ")"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Sales",
            "lineageTag": "bcb3fab6-5e3c-4f2e-b063-e42fca2e913d",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "Var LY % Total Sales",
            "description": "Sales amount variance over prior year",
            "expression": "DIVIDE( ( [Total Sales Amt] - [LY Total Sales Amt] ) , [LY Total Sales Amt] ,0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Sales",
            "lineageTag": "9b1b6db3-57b9-46a5-a0fb-7c4ea08680c5",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
