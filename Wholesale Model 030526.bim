              "    CALCULATE(",
              "        SUM('F_DC Week Labor'[Work Hours Qty])",
              "        ,'F_DC Week Labor'[Earn Code Id] IN {\"OT1\",\"OT2\"}",
              "    )"
            ],
            "formatString": "#,0",
