            "expression": "Calculate(DIVIDE([Dollar Ship - CY]-[Dollar Ship - LY CY ],[Dollar Ship - LY CY ]),ALL('D_Facility'),ALL('D_MDSE Hierarchy'))",
            "formatString": "0.00%;-0.00%;0.00%",
