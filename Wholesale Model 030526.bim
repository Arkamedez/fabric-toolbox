          {
            "type": "calculated",
            "name": "Daily Sales Group",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              "SWITCH(",
              "\tTRUE,",
              "\tISBLANK('D_Caito Item'[Commodity Sub Class Name]),",
              "\t\"(Blank)\",",
              "\t'D_Caito Item'[Commodity Sub Class Name] IN {\"Floral\",",
              "\t\t\"Non-Perishable\"},",
              "\t\"Floral\",",
              "\t'D_Caito Item'[Commodity Sub Class Name] IN {\"Fruit\",",
              "\t\t\"Organic Fruit\"},",
              "\t\"Fruit\",",
              "\t'D_Caito Item'[Commodity Sub Class Name] IN {\"Garden Highway\"},",
              "\t\"Garden Highway\",",
              "\t'D_Caito Item'[Commodity Sub Class Name] IN {\"Dairy\",",
              "\t\t\"Deli\",",
              "\t\t\"Fees\",",
              "\t\t\"Healthy Alternatives\",",
              "\t\t\"Meat\",",
              "\t\t\"Other\",",
              "\t\t\"Services\",",
              "\t\t\"Supplies\",",
              "\t\t\"USDA\"},",
              "\t\"Other\",",
              "\t'D_Caito Item'[Commodity Sub Class Name] IN {\"Organic Veg\",",
              "\t\t\"Vegetable\"},",
              "\t\"Vegetable\",",
              "\t'D_Caito Item'[Commodity Sub Class Name]",
              ")"
            ],
            "sortByColumn": "Custom Group Sort",
            "lineageTag": "408025d2-c484-47d2-ac1b-cac7b715133a",
            "summarizeBy": "none",
            "extendedProperties": [
