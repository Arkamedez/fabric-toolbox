          {
            "name": "Average Total Quantity Shipped 12 Weeks(DG Tobacco)",
            "expression": [
              "VAR _FiscalWeekEndDate = SELECTEDVALUE('D_Time Hierarchy'[Fiscal Week End Date])",
              "VAR _Denominator = ",
              "CALCULATE(",
              "    DISTINCTCOUNT('F_DC Sales Tobacco'[FISCAL_WEEK_CUSTOMER_NBR_KEY]),",
              "    DATESINPERIOD('D_Time Hierarchy'[Full Date],_FiscalWeekEndDate, -84, DAY),",
              "    'F_DC Sales Tobacco'[CUSTOMER_PRESENT_IN_WEEK_FLG] = \"1\"",
              ")",
              "RETURN",
              "DIVIDE([Total Quantity Shipped 12 Weeks (DG Tobacco)],_Denominator,0)"
            ],
            "formatString": "#,0.00",
            "displayFolder": "DG Tobacco",
            "lineageTag": "c5db7b1c-9d67-4138-8ca5-afae9abaee03"
          },
          {
            "name": "Average Total Quantity Shipped(DG Tobacco)",
            "expression": "DIVIDE([Total Quantity Shipped(DG Tobacco)],[Customer Count(DG Tobacco)],0)",
            "formatString": "#,0.00",
            "displayFolder": "DG Tobacco",
            "lineageTag": "7c0c29d4-8f33-4f05-9b57-cac769f33416"
          },
          {
            "name": "Customer Count(DG Tobacco)",
            "expression": [
              "CALCULATE(",
              "    DISTINCTCOUNT('F_DC Sales Tobacco'[CUSTOMER_NBR]),",
              "    'F_DC Sales Tobacco'[CUSTOMER_PRESENT_IN_WEEK_FLG] = \"1\"",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "DG Tobacco",
            "lineageTag": "d15d4b1c-d1c1-4a44-a917-3f3ccf6b815f"
          },
          {
            "name": "Customers Count 12 Weeks(DG Tobacco)",
            "expression": [
              "VAR _FiscalWeekEndDate = SELECTEDVALUE('D_Time Hierarchy'[Fiscal Week End Date])",
              "RETURN",
              "CALCULATE(",
              "    [Customer Count(DG Tobacco)],",
              "    DATESINPERIOD('D_Time Hierarchy'[Full Date],_FiscalWeekEndDate, -84, DAY)",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "DG Tobacco",
            "lineageTag": "1274ad7c-164a-43e7-b952-8204fc09e323"
          },
