          {
            "name": "Caito % of GM",
            "expression": [
              "",
              " -- calculates percentage of total GM for each master customer",
              " divide([Caito Gross Margin],CALCULATE([Caito Gross Margin], all('D_Caito Customer'[Master Customer Name]), all('D_Caito Customer'[Master Customer Nbr])))"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
