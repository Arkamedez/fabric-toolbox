          {
            "name": "Item Count",
            "description": "Item count ",
            "expression": [
              "COUNTROWS (FILTER(",
              "            SUMMARIZE (",
              "                'F_FD.Sales',",
              "                'F_FD.Sales'[Commodity Code],",
              "                'F_FD.Sales'[Item Nbr],",
              "                'F_FD.Sales'[Facility ID],D_Item[Service Level Code]",
              "            ),D_Item[Service Level Code] <> BLANK()",
              "        ))"
            ],
            "formatString": "#,0",
            "displayFolder": "Sales",
            "lineageTag": "0a42e560-c52b-448b-a538-524711ea3837",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "Fill rate Var % Rank",
            "description": "Fill rate % variance to rank",
            "expression": [
              "",
              "VAR a =",
              "    DIVIDE (",
              "        'O_Report Measure'[Shipped Qty],",
              "        'O_Report Measure'[Ordered Case Quantity]",
              "    )",
              "VAR ordered1 =  [LY Shipped Qty] + [LY Not Shipped Case Qty] ",
              "VAR b =",
              "    DIVIDE ( [LY Shipped Qty], ordered1 )",
              "RETURN",
              "    a - b"
            ],
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Fill Rate",
            "lineageTag": "745273e3-c9ae-40af-85ed-ab69a93e79da",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "PTD Total Sales Amt",
            "description": "Evaluate sales for a specified period to date",
            "expression": [
              "VAR seleWeek =",
              "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
              "VAR selePeriod =",
              "    MIN ( 'D_Time Hierarchy'[Fiscal Period Start Date] )",
              "RETURN",
              "    CALCULATE (",
              "        [Total Sales Amt],",
              "        FILTER (",
              "            ALL ( 'D_Time Hierarchy' ),",
              "            'D_Time Hierarchy'[Fiscal Week Start Date] >= selePeriod",
              "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
              "        ),All('D_Relative Time Slicer')",
