          },
          {
            "name": "Caito Customer Sales Rank",
            "expression": [
              "--Ranks Caito Customers by their total sales. The isinscope is to prevent ranking at a level in heirarchy outside of customer  ",
              "if(AND(HASONEVALUE('D_Caito Customer'[Customer Description]), ISINSCOPE('D_Caito Customer'[Customer Description])) ,RANKX(ALLSELECTED('D_Caito Customer'), [Caito Sales Amount],,DESC,Dense))"
            ],
            "formatString": "0",
            "displayFolder": "Caito\\Sales\\Customer Ranking",
            "lineageTag": "3d28c725-c980-4198-8471-4afa41d6f8c5"
          },
          {
            "name": "Caito Fill Rate",
            "expression": "DIVIDE([Caito Cases Shipped Qty], [Caito Cases Ordered Qty])",
