                "    #\"Renamed Columns\" = Table.RenameColumns(DC_PRICE_GAIN_VW_View,{{\"FACILITY_ID\", \"Facility ID\"}, {\"STOCK_FACILITY_ID\", \"Stock Facility ID\"}, {\"INVOICE_DT\", \"Invoice Date\"}, {\"BUSINESS_LINE_DESC\", \"Business Line\"}, {\"INVOICE_NBR\", \"Invoice NBR\"}, {\"WHOLESALE_DEPT_ID\", \"Wholesale Department ID\"}, {\"WHOLESALE_DEPT_DESC\", \"Wholesale Department Description\"}, {\"MERCHANT_CATEGORY_CD\", \"Merchant Category Code\"}, {\"MERCHANT_CATEGORY_DESC\", \"Merchant Category Description\"}, {\"ITEM_WHOLESALE_CD\", \"Item Wholesale Code\"}, {\"ITEM_WHOLESALE_DESC\", \"Item Wholesale Description\"}, {\"PRIVATE_LABEL_FLG\", \"Private Label Flag\"}, {\"PRIVATE_LABEL_CATEGORY_DESC\", \"Private Label Category\"}, {\"MASTER_VENDOR_ID\", \"Master Vendor ID\"}, {\"MASTER_VENDOR_DESC\", \"Master Vendor Description\"}, {\"ITEM_NBR\", \"Item NBR\"}, {\"ITEM_DESC\", \"Item Description\"}, {\"CUSTOMER_NBR\", \"Customer NBR\"}, {\"CUSTOMER_NM\", \"Customer Name\"}, {\"CORPORATION_ID\", \"Corporation ID\"}, {\"CORPORATION_DESC\", \"Corporation Description\"}, {\"SHIPPED_CNT\", \"Shipped Count\"}, {\"ITEM_VENDOR_LIST_AMT\", \"Item Vendor List Amount\"}, {\"PO_VENDOR_LIST_AMT\", \"PO Vendor List Amount\"}, {\"PER_CASE_PRICE_GAIN_AMT\", \"Per Case Price gain Amount\"}, {\"EXTENDED_PRICE_GAIN_AMT\", \"Extended Price Gain Amount\"}, {\"UPDATE_TMSP\", \"Update TMSP\"}})",
                "in",
                "    #\"Renamed Columns\""
              ]
            }
          }
        ],
