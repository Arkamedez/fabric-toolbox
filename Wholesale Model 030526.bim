        "partitions": [
          {
            "name": "F_Layer History-4775e987-2c05-4721-98d1-989d18ffebea",
            "mode": "directQuery",
            "queryGroup": "Fact Queries",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    LAYER_HST_VW_View = FD_Schema{[Name=\"LAYER_HST_VW\",Kind=\"View\"]}[Data],",
                "    #\"Removed Other Columns\" = Table.SelectColumns(LAYER_HST_VW_View,{\"FACILITY_ID\", \"RECORD_FLG\", \"USER_ID\", \"STATUS_CD\", \"VENDOR_NBR\", \"AP_VENDOR_NBR\", \"AP_VENDOR_KEY\", \"BUYER_ID\", \"GL_ACCOUNT_NBR\", \"ITEM_NBR\", \"VENDOR_LIST_PRICE_AMT\", \"NET_COST_PER_CASE_AMT\", \"CORRECT_NET_COST_AMT\", \"ADJ_CNT\", \"INVENTORY_TURN_CNT\", \"TURN_SOLD_QTY\", \"TURN_SOLD_EXT_AMT\", \"TURN_COST_EXT_AMT\", \"TURN_LAST_BILL_DT\", \"TURN_FIRST_BILL_DT\", \"INVENTORY_PROMOTION_CNT\", \"PROMO_SOLD_QTY\", \"PROMO_SOLD_EXT_AMT\", \"PROMO_COST_EXT_AMT\", \"PROMO_LAST_BILL_DT\", \"PROMO_FIRST_BILL_DT\", \"INVENTORY_FWD_BUY_CNT\", \"FWD_BUY_SOLD_QTY\", \"FWD_BUY_SOLD_EXT_AMT\", \"FWD_BUY_COST_EXT_AMT\", \"FWD_BUY_LAST_BILL_DT\", \"FWD_BUY_FIRST_BILL_DT\", \"RECEIPT_NBR\", \"PO_RECEIPT_DT\", \"PO_NBR\", \"PO_SUFFIX_NBR\", \"EXPIRE_DT\", \"LAYER_CHANGE_DT\", \"CREATED_BY_FLG\", \"LAST_SHIP_DT\", \"LAYER_ID\", \"SHIPPING_CASE_WGT_QTY\", \"RAND_WGT_CD\", \"LAYER_FILE_DT\", \"PRICE_CHANGE_FLG\", \"VENDOR_HST_ID\", \"ITEM_HST_ID\", \"ORIGIN\", \"CREATE_TMSP\", \"UPDATE_TMSP\", \"LAYER_RECEIVED_TIME\", \"RECORD_CHANGE_TIME\", \"ITEM_KEY\", \"VENDOR_KEY\", \"ORDER_DT\", \"EXT_INVENTORY_QOH_CNT\", \"ITEM_DEPT_ID\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Removed Other Columns\",{{\"FACILITY_ID\", \"Facility ID\"}, {\"STATUS_CD\", \"Status Code\"}, {\"VENDOR_NBR\", \"Vendor Nbr\"}, {\"AP_VENDOR_NBR\", \"AP Vendor Nbr\"}, {\"AP_VENDOR_KEY\", \"AP Vendor Key\"}, {\"BUYER_ID\", \"Buyer ID\"}, {\"ITEM_NBR\", \"Item Nbr\"}, {\"PO_RECEIPT_DT\", \"PO Receipt Date\"}, {\"PO_NBR\", \"PO Nbr\"}, {\"LAYER_ID\", \"Layer ID\"}, {\"SHIPPING_CASE_WGT_QTY\", \"Shipping Case Weight Qty\"}, {\"RAND_WGT_CD\", \"Random Weight Code\"}, {\"LAYER_FILE_DT\", \"Layer File Date\"}, {\"ITEM_KEY\", \"Item Key\"}, {\"VENDOR_KEY\", \"Vendor Key\"}, {\"ORDER_DT\", \"Order Date\"}, {\"INVENTORY_TURN_CNT\", \"Inventory Turn Cnt\"}, {\"INVENTORY_PROMOTION_CNT\", \"Inventory Promotion Cnt\"}, {\"INVENTORY_FWD_BUY_CNT\", \"Inventory Forward Buy Cnt\"}, {\"NET_COST_PER_CASE_AMT\", \"Net Cost Per Case Amt\"}, {\"CORRECT_NET_COST_AMT\", \"Correct Net Cost Amt\"}, {\"EXT_INVENTORY_QOH_CNT\", \"Extended Inventory QOH Cnt\"}, {\"ITEM_DEPT_ID\", \"Item Dept ID\"}}),",
                "    #\"Removed Other Columns1\" = Table.SelectColumns(#\"Renamed Columns\",{\"Facility ID\", \"RECORD_FLG\", \"USER_ID\", \"Status Code\", \"Vendor Nbr\", \"AP Vendor Nbr\", \"AP Vendor Key\", \"Buyer ID\", \"GL_ACCOUNT_NBR\", \"Item Nbr\", \"VENDOR_LIST_PRICE_AMT\", \"Net Cost Per Case Amt\", \"Correct Net Cost Amt\", \"ADJ_CNT\", \"Inventory Turn Cnt\", \"TURN_SOLD_QTY\", \"TURN_SOLD_EXT_AMT\", \"TURN_COST_EXT_AMT\", \"TURN_LAST_BILL_DT\", \"TURN_FIRST_BILL_DT\", \"Inventory Promotion Cnt\", \"PROMO_SOLD_QTY\", \"PROMO_SOLD_EXT_AMT\", \"PROMO_COST_EXT_AMT\", \"PROMO_LAST_BILL_DT\", \"PROMO_FIRST_BILL_DT\", \"Inventory Forward Buy Cnt\", \"FWD_BUY_SOLD_QTY\", \"FWD_BUY_SOLD_EXT_AMT\", \"FWD_BUY_COST_EXT_AMT\", \"FWD_BUY_LAST_BILL_DT\", \"FWD_BUY_FIRST_BILL_DT\", \"RECEIPT_NBR\", \"PO Receipt Date\", \"PO Nbr\", \"PO_SUFFIX_NBR\", \"EXPIRE_DT\", \"LAYER_CHANGE_DT\", \"CREATED_BY_FLG\", \"LAST_SHIP_DT\", \"Layer ID\", \"Shipping Case Weight Qty\", \"Random Weight Code\", \"Layer File Date\", \"PRICE_CHANGE_FLG\", \"VENDOR_HST_ID\", \"ITEM_HST_ID\", \"ORIGIN\", \"CREATE_TMSP\", \"UPDATE_TMSP\", \"LAYER_RECEIVED_TIME\", \"RECORD_CHANGE_TIME\", \"Item Key\", \"Vendor Key\", \"Order Date\", \"Extended Inventory QOH Cnt\", \"Item Dept ID\"}),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Removed Other Columns1\",{{\"ADJ_CNT\", \"AdJ Cnt\"}, {\"CREATE_TMSP\", \"Create Tmsp\"}, {\"CREATED_BY_FLG\", \"Created By Flg\"}, {\"EXPIRE_DT\", \"Expire Dt\"}, {\"FWD_BUY_COST_EXT_AMT\", \"Fwd Buy Cost Ext Amt\"}, {\"FWD_BUY_FIRST_BILL_DT\", \"Fwd Buy First Bill Dt\"}, {\"FWD_BUY_LAST_BILL_DT\", \"Fwd Buy Last Bill Dt\"}, {\"FWD_BUY_SOLD_EXT_AMT\", \"Fwd Buy Sold Ext Amt\"}, {\"FWD_BUY_SOLD_QTY\", \"Fwd Buy Sold Qty\"}, {\"GL_ACCOUNT_NBR\", \"GL Account Nbr\"}, {\"ITEM_HST_ID\", \"Item Hst ID\"}, {\"LAST_SHIP_DT\", \"Last Ship Dt\"}, {\"LAYER_CHANGE_DT\", \"Layer Change Dt\"}, {\"LAYER_RECEIVED_TIME\", \"Layer Received Time\"}, {\"PO_SUFFIX_NBR\", \"PO Suffix Nbr\"}, {\"PRICE_CHANGE_FLG\", \"Price Change Flg\"}, {\"PROMO_COST_EXT_AMT\", \"Promo Cost Ext Amt\"}, {\"PROMO_FIRST_BILL_DT\", \"Promo First Bill Dt\"}, {\"PROMO_LAST_BILL_DT\", \"Promo Last Bill Dt\"}, {\"PROMO_SOLD_EXT_AMT\", \"Promo Sold Ext Amt\"}, {\"PROMO_SOLD_QTY\", \"Promo Sold Qty\"}, {\"RECEIPT_NBR\", \"Receipt Nbr\"}, {\"RECORD_CHANGE_TIME\", \"Record Change Time\"}, {\"RECORD_FLG\", \"Record Flg\"}, {\"TURN_COST_EXT_AMT\", \"Turn Cost Ext Amt\"}, {\"TURN_FIRST_BILL_DT\", \"Turn First Bill Dt\"}, {\"TURN_LAST_BILL_DT\", \"Turn Last Bill Dt\"}, {\"TURN_SOLD_EXT_AMT\", \"Turn Sold Ext Amt\"}, {\"TURN_SOLD_QTY\", \"Turn Sold Qty\"}, {\"UPDATE_TMSP\", \"Update Tmsp\"}, {\"USER_ID\", \"User ID\"}, {\"VENDOR_HST_ID\", \"Vendor Hst ID\"}, {\"VENDOR_LIST_PRICE_AMT\", \"Vendor List Price Amt\"}})",
                "in",
                "    #\"Renamed Columns1\""
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Selected Filters- Inventory",
            "expression": [
              "",
              "VAR Inventory = \"",
              "\"",
              "",
              "VAR FiscalYear = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Year]),",
              "                 \"Fiscal Year= \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Year]), 'D_Time Hierarchy'[Fiscal Year], \", \") & Inventory, \"\")",
              "",
              "VAR FiscalQuaterdetail = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Quarter Detail]),",
              "                 \"Fiscal Quarter Detail= \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Quarter Detail]), 'D_Time Hierarchy'[Fiscal Quarter Detail], \", \") & Inventory, \"\")",
              "",
              "",
              "VAR FiscalPeriodwithEndDate = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Period with End Date]),",
              "                 \"Fiscal Period with End Date= \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Period with End Date]), 'D_Time Hierarchy'[Fiscal Period with End Date], \", \") & Inventory, \"\")",
              "",
              "VAR Weekending = IF(ISFILTERED('D_Time Hierarchy'[Week Ending]),",
              "                 \"Week Ending= \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Week Ending]), 'D_Time Hierarchy'[Week Ending], \", \") & Inventory, \"\")",
              "",
              "VAR RelativeTimePrompt = IF(ISFILTERED('D_Relative Time Slicer'[Relative Time Prompt]),",
              "                 \"Relative Time Prompt= \" & CONCATENATEX(ALLSELECTED('D_Relative Time Slicer'[Relative Time Prompt]), 'D_Relative Time Slicer'[Relative Time Prompt], \", \") & Inventory, \"\")",
              "VAR LayerFileDate = IF(ISFILTERED('F_Layer History'[Layer File Date]),",
              "                \"Layer File Date = \" & CONCATENATEX(ALLSELECTED('F_Layer History'[Layer File Date]), 'F_Layer History'[Layer File Date], \", \") & Inventory, \"\")",
              "",
              "VAR FacilityID = IF(ISFILTERED('D_Item'[Facility Nbr Desc]),",
              "               \"Facility = \" & CONCATENATEX(ALLSELECTED('D_Item'[Facility Nbr Desc]), 'D_Item'[Facility Nbr Desc], \", \") & Inventory, \"\")",
              "",
              "VAR MasterVendor = IF(ISFILTERED('D_Item'[Master Vendor ID Desc]),",
              "              \"Master Vendor = \" & CONCATENATEX(ALLSELECTED('D_Item'[Master Vendor ID Desc]), 'D_Item'[Master Vendor ID Desc], \", \") & Inventory, \"\")",
              "",
              "",
              "VAR FacilityID2 = IF(ISFILTERED('D_Item'[Facility ID]),",
              "              \"Facility ID = \" & CONCATENATEX(ALLSELECTED('D_Item'[Facility ID]), 'D_Item'[Facility ID], \", \") & Inventory, \"\")",
              "",
              "",
              "VAR Vendor = IF(ISFILTERED('D_Item'[Vendor]),",
              "             \"Vendor = \" & CONCATENATEX(ALLSELECTED('D_Item'[Vendor]), 'D_Item'[Vendor], \", \") & Inventory, \"\")",
              "",
              "VAR BuyerNbr = IF(ISFILTERED('D_Item'[Buyer Nbr]),",
              "             \"Buyer Nbr= \" & CONCATENATEX(ALLSELECTED('D_Item'[Buyer Nbr]), 'D_Item'[Buyer Nbr], \", \") & Inventory, \"\")",
              "",
              "VAR UpcUnit = IF(ISFILTERED('D_Item'[UPC Unit]),",
              "             \"UPC Unit= \" & CONCATENATEX(ALLSELECTED('D_Item'[UPC Unit]), 'D_Item'[UPC Unit], \", \") & Inventory, \"\")",
              "",
              "VAR ItemNbr = IF(ISFILTERED('D_Item'[Item Nbr]),",
              "             \"Item Nbr= \" & CONCATENATEX(ALLSELECTED('D_Item'[Item  Nbr]), 'D_Item'[Item  Nbr], \", \") & Inventory, \"\")",
              "",
              " RETURN",
              " FiscalYear&Fiscalquaterdetail&FiscalPeriodwithEndDate&Weekending&RelativeTimePrompt&LayerFileDate&FacilityID&MasterVendor&FacilityID2&Vendor&BuyerNbr&UpcUnit&ItemNbr"
            ],
            "isHidden": true,
            "lineageTag": "c360ecbc-c693-4c1d-adfe-07fca4a88334",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          }
        ],
