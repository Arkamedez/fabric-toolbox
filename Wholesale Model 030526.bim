            "lineageTag": "bc30a263-4860-4c68-a2de-4be0d1e4cc32"
          },
          {
            "name": "Units Received",
            "expression": "SUMX('F_Purchase Detail', 'F_Purchase Detail'[Received Count] * RELATED(D_Item[Store Pack Case]))",
            "formatString": "#,0",
