          {
            "name": "TY Bill Out %",
            "description": "Bill out % variance to this year",
            "expression": [
              "",
              "CALCULATE(",
              "    var A1 = SUM('F_FD.Sales'[Extended Dollars Shipped])",
              "    var A2 = SUM('F_FD.Sales'[Total Ext Layer Cost])-SUM('F_FD.Sales'[Total Ext Ad Allowance Amt])",
              "    var A3 = A1 - A2",
              "    return",
              "    DIVIDE(A3,A1))"
            ],
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Sales",
            "lineageTag": "5cae27ec-aed3-47d5-8963-ec2ad1ba6d51",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
