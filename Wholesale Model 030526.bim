          {
            "name": "PTD Commodity Count",
            "description": "PTD commodity count",
            "expression": [
              "VAR seleWeek =",
              "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
              "VAR selePeriod =",
              "    MIN ( 'D_Time Hierarchy'[Fiscal Period Start Date] )",
              "RETURN",
              "    CALCULATE (",
              "        [Commodity Count],",
              "        FILTER (",
              "            ALL ( 'D_Time Hierarchy' ),",
              "            'D_Time Hierarchy'[Fiscal Week Start Date] >= selePeriod",
              "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
              "        ), all('D_Relative Time Slicer')",
              "    )"
            ],
            "formatString": "0",
            "displayFolder": "Sales",
            "lineageTag": "de4d6415-13ac-419b-b717-9fa6d81a584c",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "QTD Commodity Count",
            "description": "Commodity count - quarter to date",
            "expression": [
              "VAR seleWeek =",
              "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
              "VAR seleQuarter =",
              "    MIN ( 'D_Time Hierarchy'[Fiscal Quarter Start Date] )",
              "RETURN",
              "    CALCULATE (",
              "        [Commodity Count],",
              "        FILTER (",
              "            ALL ( 'D_Time Hierarchy' ),",
              "            'D_Time Hierarchy'[Fiscal Week Start Date] >= seleQuarter",
              "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
              "        )",
              "    )"
            ],
            "formatString": "#,0",
            "displayFolder": "Sales",
            "lineageTag": "0b8d2e4d-06cc-4a01-849b-447329effdd8",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
