        ],
        "measures": [
          {
            "name": "POQ_30",
            "expression": [
              "",
              "VAR Today = TODAY()",
              "VAR ThirtyDaysAhead = Today + 30",
              "",
              "RETURN",
              "    SUMX(",
              "        SUMMARIZE(",
              "            FILTER(",
              "                'F_Purchase Detail',",
              "                'F_Purchase Detail'[Purchase Qty] <> 0 &&",
              "                'F_Purchase Detail'[Arrival Date] + 2 >= Today &&",
              "                'F_Purchase Detail'[Arrival Date] + 2 <= ThirtyDaysAhead",
              "            ),",
              "            'F_Purchase Detail'[Facility ID],",
              "            'F_Purchase Detail'[Item Nbr],",
              "            \"Purchase Qty\", SUM('F_Purchase Detail'[Purchase Qty])",
              "        ),",
              "        [Purchase Qty]",
              "    )",
              ""
            ],
            "formatString": "0",
            "lineageTag": "7b224218-0e79-4b6c-9279-20dabd739069",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ]
          },
          {
            "name": "Selected Filters-PO Item Level",
            "expression": [
              "",
              "VAR PO_ItemLevel = \"",
              "\"",
              "VAR FiscalYear = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Year]),",
              "                 \"Fiscal Year = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Year]), 'D_Time Hierarchy'[Fiscal Year], \", \") & PO_ItemLevel, \"\")",
              "",
              "VAR FiscalQuaterdetail = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Quarter Detail]),",
              "                 \"Fiscal Quarter Detail = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Quarter Detail]), 'D_Time Hierarchy'[Fiscal Quarter Detail], \", \") & PO_ItemLevel, \"\")",
              "",
              "",
              "VAR FiscalPeriodwithEndDate = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Period with End Date]),",
              "                 \"Fiscal Period with End Date = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Period with End Date]), 'D_Time Hierarchy'[Fiscal Period with End Date], \", \") & PO_ItemLevel, \"\")",
              "",
              "VAR Weekending = IF(ISFILTERED('D_Time Hierarchy'[Week Ending]),",
              "                 \"Week Ending = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Week Ending]), 'D_Time Hierarchy'[Week Ending], \", \") & PO_ItemLevel, \"\")",
              "",
              "VAR RelativeTimePrompt = IF(ISFILTERED('D_Relative Time Slicer'[Relative Time Prompt]),",
              "                 \"Relative Time Prompt = \" & CONCATENATEX(ALLSELECTED('D_Relative Time Slicer'[Relative Time Prompt]), 'D_Relative Time Slicer'[Relative Time Prompt], \", \") & PO_ItemLevel, \"\")",
              "",
              "VAR DateOrdered = IF(ISFILTERED('F_Purchase Detail'[Ordered Date]),",
              "               \"Date Ordered = \" & CONCATENATEX(ALLSELECTED('F_Purchase Detail'[Ordered Date]), 'F_Purchase Detail'[Ordered Date], \", \") & PO_ItemLevel, \"\")",
              "",
              "VAR DateReceived = IF(ISFILTERED('F_Purchase Detail'[Received Date]),",
              "               \"Date Received = \" & CONCATENATEX(ALLSELECTED('F_Purchase Detail'[Received Date]), 'F_Purchase Detail'[Received Date], \", \") & PO_ItemLevel, \"\")",
              "",
              "VAR PONumber = IF(ISFILTERED('F_Purchase Detail'[PO Nbr]),",
              "             \"PO Number = \" & CONCATENATEX(ALLSELECTED('F_Purchase Detail'[PO Nbr]), 'F_Purchase Detail'[PO Nbr], \", \") & PO_ItemLevel, \"\")",
              "",
              "VAR FacilityID1 = IF(ISFILTERED('F_Purchase Detail'[Facility ID]),",
              "            \"Facility ID = \" & CONCATENATEX(ALLSELECTED('F_Purchase Detail'[Facility ID]), 'F_Purchase Detail'[Facility ID], \", \") & PO_ItemLevel, \"\")",
              "",
              "",
              "VAR MasterVendor = IF(ISFILTERED('D_Item'[Master Vendor ID Desc]),",
              "           \"Master Vendor = \" & CONCATENATEX(ALLSELECTED('D_Item'[Master Vendor ID Desc]), 'D_Item'[Master Vendor ID Desc], \", \") & PO_ItemLevel, \"\")",
              "",
              "VAR FacilityNbrDesc = IF(ISFILTERED('D_Item'[Facility Nbr Desc]),",
              "             \"Facility = \" & CONCATENATEX(ALLSELECTED('D_Item'[Facility Nbr Desc]), 'D_Item'[Facility Nbr Desc], \", \") & PO_ItemLevel, \"\")",
              "VAR VendorDetailNbr = IF(ISFILTERED('D_Item'[Vendor Detail Nbr]),",
              "            \"VendorDetailNbr = \" & CONCATENATEX(ALLSELECTED('D_Item'[Vendor Detail Nbr]), 'D_Item'[Vendor Detail Nbr], \", \") & PO_ItemLevel, \"\")",
              "",
              "VAR BuyerNbr = IF(ISFILTERED('F_Purchase Detail'[Buyer Nbr]),",
              "           \"Buyer Nbr = \" & CONCATENATEX(ALLSELECTED('F_Purchase Detail'[Buyer Nbr]), 'F_Purchase Detail'[Buyer Nbr], \", \") & PO_ItemLevel, \"\")",
              "",
              " VAR UPCUnit = IF(ISFILTERED('D_Item'[UPC Unit]),",
              "           \"UPCUnit = \" & CONCATENATEX(ALLSELECTED('D_Item'[UPC Unit]), 'D_Item'[UPC Unit], \", \") & PO_ItemLevel, \"\")",
              "",
              " VAR ItemNbr = IF(ISFILTERED('F_Purchase Detail'[Item Nbr]),",
              "           \"Item Nbr = \" & CONCATENATEX(ALLSELECTED('F_Purchase Detail'[Item Nbr]), 'F_Purchase Detail'[Item Nbr], \", \") & PO_ItemLevel, \"\")",
              "",
              "VAR StatusCode = IF(ISFILTERED('F_Purchase Detail'[Status Code]),",
              "             \"Status Code = \" & CONCATENATEX(ALLSELECTED('F_Purchase Detail'[Status Code]), 'F_Purchase Detail'[Status Code], \", \") & PO_ItemLevel, \"\")",
              "",
              " RETURN",
              " FiscalYear&FiscalQuaterdetail&FiscalPeriodwithEndDate&Weekending&RelativeTimePrompt&DateOrdered&DateReceived&PONumber&FacilityID1&MasterVendor&FacilityNbrDesc&VendorDetailNbr&BuyerNbr&UPCUnit&ItemNbr&StatusCode"
            ],
            "isHidden": true,
            "lineageTag": "470ad1c5-2d8f-49ae-9dae-c8ccc76ecb5a",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          }
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
