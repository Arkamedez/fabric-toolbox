          {
            "name": "F_Produce Order-75cd3093-ab55-4974-815b-42fdd3875718",
            "mode": "directQuery",
            "queryGroup": "Fact Queries",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    PRODUCE_ORDER_VW_View = FD_Schema{[Name=\"PRODUCE_ORDER_VW\",Kind=\"View\"]}[Data],",
                "    #\"Renamed Columns\" = Table.RenameColumns(PRODUCE_ORDER_VW_View,{{\"FACILITY_ID\", \"Facility ID\"}, {\"ITEM_DETAIL_DESC\", \"Item Detail\"}, {\"ITEM_KEY\", \"Item Key\"}, {\"ITEM_NBR_HS_NUM\", \"Item Nbr Hs\"}, {\"FISCAL_WEEK_END_DT\", \"Fiscal  Week End Date\"}, {\"PRODUCE_DT\", \"Produce Date\"}, {\"BOOKING_NBR\", \"Booking Nbr\"}, {\"ACTIVITY_FLAG\", \"Activity Flag\"}, {\"SOLD_QTY\", \"Sold Qty\"}, {\"TRANSFER_QTY\", \"Transfer Qty\"}, {\"ON_HAND_QTY\", \"On Hand Qty\"}, {\"ORDER_QTY\", \"Order Qty\"}, {\"OUT_QTY\", \"Out Qty\"}, {\"RESERVE_ORDER_QTY\", \"Reserve Order Qty\"}, {\"PURCHASE_QTY\", \"Purchase Qty\"}, {\"MDSE_GRP_NAME\", \"MDSE Group\"}, {\"MDSE_CLASS_NAME\", \"MDSE Class\"}, {\"MDSE_CATGY_NAME\", \"MDSE Category\"}, {\"DEPT_NAME\", \"MDSE Dept\"}, {\"DEPT_GRP_NAME\", \"MDSE Dept Group\"}, {\"CATALOG_ITEM\", \"Catalog Item\"}})",
                "in",
                "    #\"Renamed Columns\""
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Exception"
          }
        ]
