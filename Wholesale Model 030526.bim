            "mode": "directQuery",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    MDM_Schema = EDW_Database{[Name=\"MDM\",Kind=\"Schema\"]}[Data],",
                "    MASTER_VENDOR_DIM_Table = MDM_Schema{[Name=\"MASTER_VENDOR_DIM\",Kind=\"Table\"]}[Data],",
                "    #\"Removed Columns\" = Table.RemoveColumns(MASTER_VENDOR_DIM_Table,{\"CREATE_TMSP\", \"CREATE_USER_ID\", \"UPDATE_TMSP\", \"UPDATE_USER_ID\", \"ORIGIN\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Removed Columns\",{{\"MASTER_VENDOR_PK\", \"Master Vendor Pk\"}, {\"MASTER_VENDOR_ID\", \"Master Vendor Id\"}, {\"MASTER_VENDOR_EXTERNAL_ID\", \"Master Vendor External Id\"}, {\"MASTER_VENDOR_DESC\", \"Master Vendor Desc\"}, {\"MASTER_VENDOR_STATUS_CD\", \"Master Vendor Status Cd\"}, {\"MASTER_VENDOR_TYPE_CD\", \"Master Vendor Type Cd\"}, {\"CENTRALIZATION_IND\", \"Centralization Ind\"}, {\"MASTER_VENDOR_CATEGORY_CD\", \"Master Vendor catogory Cd\"}, {\"MASTER_VENDOR_LANGUAGE_CD\", \"Master Vendor Language Cd\"}, {\"MASTER_VENDOR_COUNTRY_CD\", \"Master Vendor Country Cd\"}, {\"STATISTICAL_CD\", \"Statistical Cd\"}, {\"PURCHASING_OFFICE_CD\", \"Purchasing Office Cd\"}, {\"TAX_SYSTEM_ID\", \"Tax System Id\"}, {\"VAT_GENERATION_CD\", \"Vat Generation Cd\"}, {\"ARTICLE_SORTING_CD\", \"Artical Sorting Cd\"}, {\"MASTER_VENDOR_TAX_1_CD\", \"Master Vendor Tax 1 Cd\"}, {\"MASTER_VENDOR_TAX_2_CD\", \"Master Vendor Tax 2 Cd\"}, {\"MASTER_VENDOR_COMMENT_TXT\", \"Master Vendor Comment Txt\"}, {\"MASTER_VENDOR_KEYWORD_CD\", \"Master Vendor Keyword Cd\"}, {\"MASTER_VENDOR_PRICE_CALCULATION_CD\", \"Master Vendor Calculation Cd\"}, {\"MASTER_VENDOR_MODIFICATION_CNT\", \"Master Vendor Modification Cnt\"}, {\"MASTER_VENDOR_LOGO_NM\", \"Master Vendor Logo Nm\"}, {\"LOCAL_SUPPLIER_IND\", \"Local Supplier Ind\"}, {\"ELECTRONIC_DEAL_FLOW_CD\", \"Electronic Deal Flow Cd\"}, {\"ECONOMIC_ACTIVITY_ID\", \"Econominc Activity Id\"}, {\"START_DT\", \"Start Dt\"}, {\"END_DT\", \"End Dt\"}, {\"CURRENT_FLG\", \"Current Flg\"}, {\"DELETE_FLG\", \"Delete Flg\"}}),",
                "    #\"Merged Queries\" = Table.NestedJoin(#\"Renamed Columns\", {\"Master Vendor Id\"}, #\"D_Master Vendor Contact\", {\"Master Vendor ID\"}, \"D_Master Vendor Contact\", JoinKind.LeftOuter),",
                "    #\"Expanded D_Master Vendor Contact\" = Table.ExpandTableColumn(#\"Merged Queries\", \"D_Master Vendor Contact\", {\"Master Vendor Contact PK\", \"Master Vendor ID\", \"Master Vendor Key\", \"Master Vendor Address Code\", \"Comment Contact ID\", \"Contact Name\", \"Title Name\", \"Contact Position Number\", \"Country Phone Prefix Code\", \"Telex Number\", \"IP Phone Number\", \"Fax Number\", \"Email Address\", \"Standard Phone Number\", \"Direct Phone Number\", \"Mobile Phone Number\", \"Modification Count\", \"Start Date\", \"End Date\", \"Current Flag\", \"Delete Flag\"}, {\"D_Master Vendor Contact.Master Vendor Contact PK\", \"D_Master Vendor Contact.Master Vendor ID\", \"D_Master Vendor Contact.Master Vendor Key\", \"D_Master Vendor Contact.Master Vendor Address Code\", \"D_Master Vendor Contact.Comment Contact ID\", \"D_Master Vendor Contact.Contact Name\", \"D_Master Vendor Contact.Title Name\", \"D_Master Vendor Contact.Contact Position Number\", \"D_Master Vendor Contact.Country Phone Prefix Code\", \"D_Master Vendor Contact.Telex Number\", \"D_Master Vendor Contact.IP Phone Number\", \"D_Master Vendor Contact.Fax Number\", \"D_Master Vendor Contact.Email Address\", \"D_Master Vendor Contact.Standard Phone Number\", \"D_Master Vendor Contact.Direct Phone Number\", \"D_Master Vendor Contact.Mobile Phone Number\", \"D_Master Vendor Contact.Modification Count\", \"D_Master Vendor Contact.Start Date\", \"D_Master Vendor Contact.End Date\", \"D_Master Vendor Contact.Current Flag\", \"D_Master Vendor Contact.Delete Flag\"}),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Expanded D_Master Vendor Contact\",{{\"D_Master Vendor Contact.Master Vendor Contact PK\", \"Master Vendor Contact PK\"}, {\"D_Master Vendor Contact.Master Vendor Key\", \"Master Vendor Key\"}, {\"D_Master Vendor Contact.Master Vendor Address Code\", \"Master Vendor Address Code\"}, {\"D_Master Vendor Contact.Comment Contact ID\", \"Comment Contact ID\"}, {\"D_Master Vendor Contact.Contact Name\", \"Contact Name\"}, {\"D_Master Vendor Contact.Title Name\", \"Title Name\"}, {\"D_Master Vendor Contact.Contact Position Number\", \"Contact Position Number\"}, {\"D_Master Vendor Contact.Country Phone Prefix Code\", \"Country Phone Prefix Code\"}, {\"D_Master Vendor Contact.Telex Number\", \"Telex Number\"}, {\"D_Master Vendor Contact.IP Phone Number\", \"IP Phone Number\"}, {\"D_Master Vendor Contact.Fax Number\", \"Fax Number\"}, {\"D_Master Vendor Contact.Email Address\", \"Email Address\"}, {\"D_Master Vendor Contact.Standard Phone Number\", \"Standard Phone Number\"}, {\"D_Master Vendor Contact.Direct Phone Number\", \"Direct Phone Number\"}, {\"D_Master Vendor Contact.Mobile Phone Number\", \"Mobile Phone Number\"}, {\"D_Master Vendor Contact.Modification Count\", \"Modification Count\"}, {\"D_Master Vendor Contact.Start Date\", \"Start Date\"}, {\"D_Master Vendor Contact.End Date\", \"End Date\"}, {\"D_Master Vendor Contact.Current Flag\", \"Current Flag\"}, {\"D_Master Vendor Contact.Delete Flag\", \"Delete Flag\"}}),",
