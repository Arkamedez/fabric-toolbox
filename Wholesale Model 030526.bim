      {
        "name": "Week Parameter",
        "lineageTag": "4d697b9f-5153-4168-b95b-f5da2da763a1",
        "columns": [
          {
            "type": "calculatedTableColumn",
            "name": "Week Parameter",
            "dataType": "string",
            "isNameInferred": false,
            "isDataTypeInferred": true,
            "sourceColumn": "[Value1]",
            "sortByColumn": "Week Parameter Order",
            "lineageTag": "24b20f1f-1569-4712-ba13-b74f83d2cd3a",
            "summarizeBy": "none",
            "relatedColumnDetails": {
              "groupByColumns": [
                {
                  "groupingColumn": "Week Parameter Fields"
                }
              ]
            },
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculatedTableColumn",
            "name": "Week Parameter Fields",
            "dataType": "string",
            "isNameInferred": false,
            "isDataTypeInferred": true,
            "isHidden": true,
            "sourceColumn": "[Value2]",
            "sortByColumn": "Week Parameter Order",
            "lineageTag": "b470aa31-0d7a-4dca-944e-5b435ff0c72b",
            "summarizeBy": "none",
            "extendedProperties": [
              {
                "type": "json",
                "name": "ParameterMetadata",
                "value": {
                  "kind": 2,
                  "version": 3
                }
              }
            ],
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculatedTableColumn",
            "name": "Week Parameter Order",
            "dataType": "int64",
            "isNameInferred": false,
            "isDataTypeInferred": true,
            "isHidden": true,
            "sourceColumn": "[Value3]",
            "formatString": "0",
            "lineageTag": "a4507306-19cf-4194-be08-68cbd75985d5",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          }
        ],
        "partitions": [
          {
            "name": "Week Parameter",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": [
                "",
                "",
                "var Demand_CW_TY=\"Demand TY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Fiscal Week]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Fiscal Week]), 4), 'D_Time Hierarchy'[Full Date] = TODAY())",
                "var Demand_CW_TY_1=\"Demand TY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Fiscal Week]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()-7) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Fiscal Week]), 4), 'D_Time Hierarchy'[Full Date] = TODAY()-7)",
                "var Demand_CW_TY_2=\"Demand TY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Fiscal Week]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()-14) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Fiscal Week]), 4), 'D_Time Hierarchy'[Full Date] = TODAY()-14)",
                "var Demand_CW_TY_3=\"Demand TY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Fiscal Week]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()-21) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Fiscal Week]), 4), 'D_Time Hierarchy'[Full Date] = TODAY()-21)",
                "",
                "var Sales_Demand_CW_LY=\"Sales LY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Week ID]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Week ID]), 4), 'D_Time Hierarchy'[Full Date] = TODAY())",
                "var Sales_Demand_CW_LY_forward_1=\"Sales LY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Week ID]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()+7) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Week ID]), 4), 'D_Time Hierarchy'[Full Date] = TODAY()+7)",
                "var Sales_Demand_CW_LY_forward_2=\"Sales LY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Week ID]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()+14) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Week ID]), 4), 'D_Time Hierarchy'[Full Date] = TODAY()+14)",
                "var Sales_Demand_CW_LY_forward_3=\"Sales LY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Week ID]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()+21) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Week ID]), 4), 'D_Time Hierarchy'[Full Date] = TODAY()+21)",
                "",
                "var Rate_CW_LY=\"Sell Price LY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Week ID]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Week ID]), 4), 'D_Time Hierarchy'[Full Date] = TODAY())",
                "var Rate_CW_LY_forwad_1=\"Sell Price LY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Week ID]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()+7) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Week ID]), 4), 'D_Time Hierarchy'[Full Date] = TODAY()+7)",
                "var Rate_CW_LY_forwad_2=\"Sell Price LY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Week ID]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()+14) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Week ID]), 4), 'D_Time Hierarchy'[Full Date] = TODAY()+14)",
                "var Rate_CW_LY_forwad_3=\"Sell Price LY:\" & \" Week \" & CALCULATE(RIGHT(MAX('D_Time Hierarchy'[Week ID]), 2), 'D_Time Hierarchy'[Full Date] = TODAY()+21) & \" \" &CALCULATE(LEFT(MAX('D_Time Hierarchy'[Week ID]), 4), 'D_Time Hierarchy'[Full Date] = TODAY()+21)",
                "",
                "return",
                "{",
                "    ",
                "    (Demand_CW_TY, NAMEOF('O_Report Measure'[Demand CY CW]), 0),",
                "    (Demand_CW_TY_1, NAMEOF('O_Report Measure'[Demand CY CW Minus 1]), 1),",
                "    (Demand_CW_TY_2, NAMEOF('O_Report Measure'[Demand CY CW Minus 2]), 2),",
                "    (Demand_CW_TY_3, NAMEOF('O_Report Measure'[Demand CY CW Minus 3]), 3),",
                "    (Sales_Demand_CW_LY, NAMEOF('O_Report Measure'[Demand LY CW]), 4),",
                "    (Sales_Demand_CW_LY_forward_1, NAMEOF('O_Report Measure'[Demand LY CW Plus 1]), 5),",
                "    (Sales_Demand_CW_LY_forward_2, NAMEOF('O_Report Measure'[Demand LY CW Plus 2]), 6),",
                "    (Sales_Demand_CW_LY_forward_3, NAMEOF('O_Report Measure'[Demand LY CW Plus 3]), 7),",
                "    (Rate_CW_LY, NAMEOF('O_Report Measure'[Rate LY CW]), 8),",
                "    (Rate_CW_LY_forwad_1, NAMEOF('O_Report Measure'[Rate LY CW Plus 1]), 9),",
                "    (Rate_CW_LY_forwad_2, NAMEOF('O_Report Measure'[Rate LY CW Plus 2]), 10),",
                "    (Rate_CW_LY_forwad_3, NAMEOF('O_Report Measure'[Rate LY CW Plus 3]), 11)",
                "}"
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_Id",
            "value": "55906e89a641405d9c7170521c73b27f"
          }
        ]
      },
