              }
            ]
          },
          {
            "name": "Units Shipped",
            "description": "Total units shipped",
            "expression": [
              "",
              "CALCULATE (",
              "    SUMX (",
              "        'F_FD.Sales',",
              "        'F_FD.Sales'[Total Quantity Shipped] * 'F_FD.Sales'[Store Pack]",
              "    ),",
              "    USERELATIONSHIP ( 'F_FD.Sales'[Customer Full Key], D_Customer[Customer Full Key] )",
              ")"
            ],
            "formatString": "#,###;(#,###)",
            "displayFolder": "Sales",
            "lineageTag": "b0ea906b-735e-4591-802e-5aa006429884",
