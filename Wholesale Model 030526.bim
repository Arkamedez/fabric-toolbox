            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    PURCHASE_DTL_VW_View = FD_Schema{[Name=\"PURCHASE_DTL_VW\",Kind=\"View\"]}[Data],",
                "    #\"Renamed Columns\" = Table.RenameColumns(PURCHASE_DTL_VW_View,{{\"BUYER_NBR\", \"Buyer Nbr\"}, {\"CASE_UPC_CD\", \"Case UPC code\"}, {\"FACILITY_ID\", \"Facility ID\"}, {\"ITEM_NBR\", \"Item Nbr\"}, {\"ORDERED_DT\", \"Ordered Date\"}, {\"PURCHASE_QTY\", \"Purchase Qty\"}, {\"RECEIVED_CNT\", \"Received Count\"}, {\"RECEIVED_DT\", \"Received Date\"}, {\"WAREHOUSE_ID\", \"Warehouse ID\"}, {\"WEIGHT_QTY\", \"Weight Qty\"}, {\"WEIGHT_RECEIVED_CNT\", \"Weight Received Count\"}, {\"ITEM_KEY\", \"Item Key\"}, {\"ORIGIN\", \"Origin\"}, {\"PURCHASE_ORDER_CNT\", \"Purchase Order Cnt\"}, {\"ARRIVAL_DT\", \"Arrival Date\"}, {\"ORDER_ARRIVAL_DT\", \"Order Arrival Date\"}, {\"STATUS_CD\", \"Status Code\"}}),",
                "    #\"Removed Other Columns\" = Table.SelectColumns(#\"Renamed Columns\",{\"PURCHASE_DTL_PK\", \"PURCHASE_HDR_KEY\", \"Buyer Nbr\", \"Case UPC code\", \"Facility ID\", \"Item Nbr\", \"Ordered Date\", \"Purchase Qty\", \"Received Count\", \"Received Date\", \"Warehouse ID\", \"Weight Qty\", \"Weight Received Count\", \"Item Key\", \"Origin\", \"CREATE_TMSP\", \"UPDATE_TMSP\", \"PO_NBR\", \"Purchase Order Cnt\", \"Arrival Date\", \"Order Arrival Date\", \"Status Code\", \"TURN_CNT\", \"PROMOTION_CNT\", \"FORWARD_BUY_CNT\", \"ACTIVE_DEAL_FLG\", \"AUTHORIZED_FOR_PAYMENT_CD\", \"BACKHAUL_AMT\", \"BACKHAUL_EX_FLG\", \"BACKORDER_FLG\", \"BB_FLAT_ITEM_AVAIL_AMT\", \"BILLBACK_AMT\", \"BREAKDOWN_CNT\", \"CASH_DISCOUNT_AMT\", \"CORRECTED_BILLBACK_AMT\", \"CORRECTED_LAST_COST_AMT\", \"CORRECTED_LIST_COST_AMT\", \"CORRECTED_OFF_INVOICE_AMT\", \"CUBE_AMT\", \"DELETE_FLG\", \"EXE_FIRST_RECEIVE_DT\", \"EXE_FIRST_RECEIVE_TMSP\", \"EXE_LAST_RECEIVE_DT\", \"EXE_LAST_RECEIVE_TMSP\", \"FACTOR_2_AMT\", \"FIRST_RECEIPT_NBR\", \"FREIGHT_ALLOW_AMT\", \"FREIGHT_ALLOW_EX_FLG\", \"FREIGHT_BILL_AMT\", \"FREIGHT_BILL_EX_FLG\", \"INCENTIVE_BILLBACK_AMT\", \"INCENTIVE_OFF_INVOICE_AMT\", \"ITEM_UP_DOWN_AMT\", \"ITEM_UP_DOWN_CD\", \"ITEM_UP_DOWN_DESC\", \"ITEM_UP_DOWN_RATE_CD\", \"ITRADE_VENDOR_ADDR\", \"ITRADE_VENDOR_CITY\", \"ITRADE_VENDOR_DUNS_ID\", \"ITRADE_VENDOR_NM\", \"ITRADE_VENDOR_STATE\", \"ITRADE_VENDOR_ZIP_CD\", \"LAST_COST_AMT\", \"LINE_STATUS\", \"LIST_COST_AMT\", \"LIST_COST_FUTURE_AMT\", \"NEW_ITEM_FLG\", \"OFF_INVOICE_AMT\", \"OI_FLAT_ITEM_AVAIL_AMT\", \"ORDER_UNIT_CD\", \"ORIGINAL_CNT\", \"OVERRIDE_WHSE_SELL_AMT\", \"PACK_CNT\", \"PACK_SIZE\", \"PALLET_CNT\", \"PREPAY_ADD_AMT\", \"PREPAY_ADD_EX_FLG\", \"PROMOTION_FROM_DEAL_FLG\", \"RESERVE_BUY_CNT\", \"TRANSFER_ITEM_FACILITY_ID\", \"TRANSFER_ITEM_NBR\", \"VARIABLE_WEIGHT_FLG\", \"VENDOR_UP_DOWN_AMT\", \"WHSE_DISCOUNT_AMT\"}),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Removed Other Columns\",{{\"PACK_CNT\", \"Pack Cnt\"}, {\"ACTIVE_DEAL_FLG\", \"Active Deal Flg\"}, {\"AUTHORIZED_FOR_PAYMENT_CD\", \"Authorized For Payment Cd\"}, {\"BACKHAUL_AMT\", \"Backhaul Amt\"}, {\"BACKHAUL_EX_FLG\", \"Backhaul Ex Flg\"}, {\"BACKORDER_FLG\", \"Backorder Flg\"}, {\"BB_FLAT_ITEM_AVAIL_AMT\", \"BB Flat Item Avail Amt\"}, {\"BILLBACK_AMT\", \"Billback Amt\"}, {\"BREAKDOWN_CNT\", \"Breakdown Cnt\"}, {\"CASH_DISCOUNT_AMT\", \"Cash Discount Amt\"}, {\"CORRECTED_BILLBACK_AMT\", \"Corrected Billback Amt\"}, {\"CORRECTED_LAST_COST_AMT\", \"Corrected Last Cost Amt\"}, {\"CORRECTED_LIST_COST_AMT\", \"Corrected List Cost Amt\"}, {\"CORRECTED_OFF_INVOICE_AMT\", \"Corrected Off Invoice Amt\"}, {\"CREATE_TMSP\", \"Create Tmsp\"}, {\"CUBE_AMT\", \"Cube Amt\"}, {\"DELETE_FLG\", \"Delete Flg\"}, {\"EXE_FIRST_RECEIVE_DT\", \"Exe First Receive Dt\"}, {\"EXE_FIRST_RECEIVE_TMSP\", \"Exe First Receive Tmsp\"}, {\"EXE_LAST_RECEIVE_DT\", \"Exe Last Receive Dt\"}, {\"EXE_LAST_RECEIVE_TMSP\", \"Exe Last Receive Tmsp\"}, {\"FACTOR_2_AMT\", \"Factor 2 Amt\"}, {\"FIRST_RECEIPT_NBR\", \"First Receipt Nbr\"}, {\"FORWARD_BUY_CNT\", \"Forward Buy Cnt\"}, {\"FREIGHT_ALLOW_AMT\", \"Freight Allow Amt\"}, {\"FREIGHT_ALLOW_EX_FLG\", \"Freight Allow Ex Flg\"}, {\"FREIGHT_BILL_AMT\", \"Freight Bill Amt\"}, {\"FREIGHT_BILL_EX_FLG\", \"Freight Bill Ex Flg\"}, {\"INCENTIVE_BILLBACK_AMT\", \"Incentive Billback Amt\"}, {\"INCENTIVE_OFF_INVOICE_AMT\", \"Incentive Off Invoice Amt\"}, {\"ITEM_UP_DOWN_AMT\", \"Item Up Down Amt\"}, {\"ITEM_UP_DOWN_CD\", \"Item Up Down Cd\"}, {\"ITEM_UP_DOWN_DESC\", \"Item Up Down Desc\"}, {\"ITEM_UP_DOWN_RATE_CD\", \"Item Up Down Rate Cd\"}, {\"ITRADE_VENDOR_ADDR\", \"Itrade Vendor Addr\"}, {\"ITRADE_VENDOR_CITY\", \"Itrade Vendor City\"}, {\"ITRADE_VENDOR_DUNS_ID\", \"Itrade Vendor Duns Id\"}, {\"ITRADE_VENDOR_NM\", \"Itrade Vendor Nm\"}, {\"ITRADE_VENDOR_STATE\", \"Itrade Vendor State\"}, {\"ITRADE_VENDOR_ZIP_CD\", \"Itrade Vendor Zip Cd\"}, {\"LAST_COST_AMT\", \"Last Cost Amt\"}, {\"LINE_STATUS\", \"Line Status\"}, {\"LIST_COST_AMT\", \"List Cost Amt\"}, {\"LIST_COST_FUTURE_AMT\", \"List Cost Future Amt\"}, {\"NEW_ITEM_FLG\", \"New Item Flg\"}, {\"OFF_INVOICE_AMT\", \"Off Invoice Amt\"}, {\"OI_FLAT_ITEM_AVAIL_AMT\", \"OI Flat Item Avail Amt\"}, {\"ORDER_UNIT_CD\", \"Order Unit Cd\"}, {\"ORIGINAL_CNT\", \"Original Cnt\"}, {\"OVERRIDE_WHSE_SELL_AMT\", \"Override Whse Sell Amt\"}, {\"PACK_SIZE\", \"Pack Size\"}, {\"PALLET_CNT\", \"Pallet Cnt\"}, {\"PO_NBR\", \"PO Nbr\"}, {\"PREPAY_ADD_AMT\", \"Prepay Add Amt\"}, {\"PREPAY_ADD_EX_FLG\", \"Prepay Add Ex Flg\"}, {\"PROMOTION_CNT\", \"Promotion Cnt\"}, {\"PROMOTION_FROM_DEAL_FLG\", \"Promotion From Deal Flg\"}, {\"PURCHASE_DTL_PK\", \"Purchase Dtl Pk\"}, {\"PURCHASE_HDR_KEY\", \"Purchase Hdr Key\"}, {\"RESERVE_BUY_CNT\", \"Reserve Buy Cnt\"}, {\"TRANSFER_ITEM_FACILITY_ID\", \"Transfer Item Facility Id\"}, {\"TRANSFER_ITEM_NBR\", \"Transfer Item Nbr\"}, {\"TURN_CNT\", \"Turn Cnt\"}, {\"UPDATE_TMSP\", \"Update Tmsp\"}, {\"VARIABLE_WEIGHT_FLG\", \"Variable Weight Flg\"}, {\"VENDOR_UP_DOWN_AMT\", \"Vendor Up Down Amt\"}, {\"WHSE_DISCOUNT_AMT\", \"Whse Discount Amt\"}})",
