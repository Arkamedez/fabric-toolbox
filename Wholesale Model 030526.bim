          },
          {
            "name": "Caito Not Top Ten Customer %",
            "expression": [
              "",
              "VAR AllMasterCustomers =",
              "    VALUES('D_Caito Customer'[Master Customer Name])",
              "",
              "VAR TopMasterCustomers =",
              "    TOPN(",
              "        10,",
              "        ADDCOLUMNS(",
              "            AllMasterCustomers,",
              "            \"TotalSales%\", CALCULATE([Caito % of Sales])",
              "        ),",
              "        [TotalSales%],",
              "        DESC",
              "    )",
              "",
              "VAR TopMasterCustomerNames =",
              "    SELECTCOLUMNS(TopMasterCustomers, \"MasterCustomerName\", [Master Customer Name])    ",
              "",
              "VAR OtherMasterCustomers =",
              "    EXCEPT(AllMasterCustomers, TopMasterCustomerNames)",
              "",
              "RETURN",
              "    CALCULATE(",
              "        [Caito % of Sales],",
              "        KEEPFILTERS(OtherMasterCustomers)",
              "    )"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Caito\\Sales\\Customer Ranking",
            "lineageTag": "a5c105ed-eb90-4006-84d7-d331a0fa4b7f"
          },
          {
            "name": "Caito Not Top Ten Customer % of GM",
            "expression": [
              "",
              "VAR AllMasterCustomers =",
              "    VALUES('D_Caito Customer'[Master Customer Name])",
              "",
              "VAR TopMasterCustomers =",
              "    TOPN(",
              "        10,",
              "        ADDCOLUMNS(",
              "            AllMasterCustomers,",
              "            \"TotalGM%\", CALCULATE([Caito % of GM])",
              "        ),",
              "        [TotalGM%],",
              "        DESC",
              "    )",
              "",
              "VAR TopMasterCustomerNames =",
              "    SELECTCOLUMNS(TopMasterCustomers, \"MasterCustomerName\", [Master Customer Name])    ",
              "",
              "VAR OtherMasterCustomers =",
              "    EXCEPT(AllMasterCustomers, TopMasterCustomerNames)",
              "",
              "RETURN",
              "    CALCULATE(",
              "        [Caito % of GM],",
              "        KEEPFILTERS(OtherMasterCustomers)",
              "    )"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Caito\\Sales\\Customer Ranking",
            "lineageTag": "a55a4686-4825-414b-bb9a-d3aefe76f3bc"
          },
          {
            "name": "Caito Not Top Ten Customer GM",
            "expression": [
              "",
              "VAR AllMasterCustomers =",
              "    VALUES('D_Caito Customer'[Master Customer Name])",
              "",
              "VAR TopMasterCustomers =",
              "    TOPN(",
              "        10,",
              "        ADDCOLUMNS(",
              "            AllMasterCustomers,",
              "            \"TotalGM\", CALCULATE([Caito Gross Margin])",
              "        ),",
              "        [TotalGM],",
              "        DESC",
              "    )",
              "",
              "VAR TopMasterCustomerNames =",
              "    SELECTCOLUMNS(TopMasterCustomers, \"MasterCustomerName\", [Master Customer Name])    ",
              "",
              "VAR OtherMasterCustomers =",
              "    EXCEPT(AllMasterCustomers, TopMasterCustomerNames)",
              "",
              "RETURN",
              "    CALCULATE(",
              "        [Caito Gross Margin],",
              "        KEEPFILTERS(OtherMasterCustomers)",
              "    )"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Caito\\Sales\\Customer Ranking",
            "lineageTag": "1d511982-33df-4009-b8b7-9d8197597fa6"
          },
          {
            "name": "Caito Not Top Ten Customer Sales",
            "expression": [
              "",
              "VAR AllMasterCustomers =",
              "    VALUES('D_Caito Customer'[Master Customer Name])",
              "",
              "VAR TopMasterCustomers =",
              "    TOPN(",
              "        10,",
              "        ADDCOLUMNS(",
              "            AllMasterCustomers,",
              "            \"TotalSales\", CALCULATE([Caito Sales Amount])",
              "        ),",
              "        [TotalSales],",
              "        DESC",
              "    )",
              "",
              "VAR TopMasterCustomerNames =",
              "    SELECTCOLUMNS(TopMasterCustomers, \"MasterCustomerName\", [Master Customer Name])    ",
              "",
              "VAR OtherMasterCustomers =",
              "    EXCEPT(AllMasterCustomers, TopMasterCustomerNames)",
              "",
              "RETURN",
              "    CALCULATE(",
