          {
            "name": "LY Dollar Shipped",
            "description": "Dollar shipped for last year",
            "expression": [
              "CALCULATE (",
              "    [Dollars Shipped],",
              "   FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[Date ID LY] )",
              "    ),ALL('D_Relative Time Slicer'))"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Sales",
