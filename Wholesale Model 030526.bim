            ]
          },
          {
            "name": "Dollar ship CY Var%(MDSE Total)",
            "description": "Dollar ship CY % variance to MDSE total",
            "expression": "Calculate(DIVIDE([Dollar Ship - CY]-[Dollar Ship - LY CY ],[Dollar Ship - LY CY ]),ALL('D_Item'[MDSE Group]))",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Sales",
            "lineageTag": "3aa3f3a9-8931-4c6f-b638-f1e30a467b74",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "Gap to Comp-MDSE Group",
            "description": "Dollar ship CY for MDSE group {can be used for comp reporting}",
            "expression": "([Dollar ship CY Var%]-[Dollar ship CY Var%(MDSE Total)])*[Dollar Ship - CY]",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Sales",
            "lineageTag": "fe457dd1-f5b5-4b32-a045-2a0b5f15a6af",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ]
          },
          {
            "name": "Adjustment Cnt",
            "description": "Adjustment Count",
            "expression": "SELECTEDVALUE('F_Inventory Adjustment Cost'[Adjustment Count])",
            "formatString": "##,###;(##,###)",
            "displayFolder": "Inventory",
            "lineageTag": "77f5d705-21fb-47c4-bc09-cae632093e53",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "Total Qty Out",
            "description": "Total quantity",
            "expression": [
              "var sold = CALCULATE(SUM('F_FD.Sales'[Quantity Sold]),DATEADD('D_Time Hierarchy'[Full Date],1,DAY))",
              "VAR Sratced = CALCULATE(SUM('F_FD.Sales'[Quantity Scratched]),DATEADD('D_Time Hierarchy'[Full Date],1,DAY))",
              "var qtysold = CALCULATE(sold-Sratced,FILTER('F_FD.Sales','F_FD.Sales'[Quantity Sold]<>0 || 'F_FD.Sales'[Order Type Code]=\"GB\" || 'F_FD.Sales'[PLATFORM TYPE]=\"LEGACY\"))",
              "VAR adjst = CALCULATE(SUM('F_FD.Sales'[Adjusted Quantity]),DATEADD('D_Time Hierarchy'[Full Date],1,DAY))",
              "RETURN",
              "CALCULATE(adjst-qtysold)"
            ],
            "formatString": "##,###;(##,###)",
            "displayFolder": "Sales",
            "lineageTag": "87470fc8-4966-464e-9843-49645b569311",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "Nbr Items",
            "description": "Number of items grouped by facility",
            "expression": "CALCULATE(countx(distinct(D_Item[Item Nbr HS]),1),GROUPBY('D_Vendor',D_Vendor[Facility ID]),FILTER('D_Vendor Broker','D_Vendor Broker'[Master Broker Nbr]),FILTER('D_AP Vendor','D_AP Vendor'[AP Vendor Nbr]))",
            "formatString": "#,0",
            "displayFolder": "Sales",
            "lineageTag": "15712612-dde6-481b-828b-cbb0bce3ae4e",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "AllowanceType Code",
            "description": "Allowance Type Code change from 'RPA' to 'PA'",
            "expression": [
              "VAR a = \"RPA\"",
              "            VAR c = \"PA\"",
              "            VAR d =",
              "                SELECTEDVALUE ( F_Allowance[Allowance Type Code] )",
              "            VAR b =",
              "                IF ( d = a, c,d)",
              "            RETURN",
              "                b"
            ],
            "displayFolder": "Sales",
            "lineageTag": "73c10c9e-ec84-4ba4-860d-546f46717baa",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "Corp Auth Flag",
            "description": "Corporate authorised flag",
            "expression": [
              "CALCULATE (",
              "    IF (",
              "        SUM ( D_Item[Corporate Restriction] )",
              "            IN { SUM ( D_Customer[Customer Corporation] ), 0 },",
              "        \"Y\",",
              "        \"N\"",
              "    ),",
              "    ALL ( D_Customer[Customer Corporation] ),",
              "    ALL ( D_Item[Corporate Restriction] )",
              ")"
            ],
            "formatString": "Text",
            "displayFolder": "Sales",
            "lineageTag": "3e53feb6-1687-418b-a1fd-bafc2eaf8309",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "Twelve Week Layer Cost TOT",
            "description": "12 week layer cost total",
            "expression": [
              "",
              "CALCULATE(var dd = MAX('D_Time Hierarchy'[Full Date])",
              "var lkp = LOOKUPVALUE('D_Time Hierarchy'[Day of Week],'D_Time Hierarchy'[Full Date],dd)",
              "var c = SUM('F_FD.Sales'[Extended Dollars Shipped])/12",
              "var d = 52/16",
              "var e = c*d",
              "var a = CALCULATE(SUM('F_FD.Sales'[Extended Dollars Shipped]),DATESBETWEEN('D_Time Hierarchy'[Full Date], MAX('D_Time Hierarchy'[Full Date])-77, MAX('D_Time Hierarchy'[Full Date])))",
              "var b = CALCULATE(sum('F_FD.Sales'[Extended Dollars Shipped]),DATESBETWEEN('D_Time Hierarchy'[Full Date], MAX('D_Time Hierarchy'[Full Date])-84, MAX('D_Time Hierarchy'[Full Date])))",
              "return  if(lkp =7, a,IF(lkp < 7,b,e)",
              "))"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Sales",
            "lineageTag": "3152b314-b6da-40ee-80fa-e381e2c9aadc",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "Qty on hand",
            "description": "Product quantity %",
            "expression": "SUMX('F_Inventory Detail',CALCULATE( DIVIDE(SUM('F_Inventory Detail'[Prod Qty]),SUM(D_Item[Store Pack Case]))))",
            "formatString": "##,###;(##,###)",
            "displayFolder": "Inventory",
            "lineageTag": "9d3d811c-4b2b-43ba-ab37-63cbbb632042",
            "changedProperties": [
