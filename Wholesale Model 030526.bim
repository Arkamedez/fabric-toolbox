          {
            "name": "Total Sales Amt (Rolling YTW)",
            "description": "Total sales amount for rolling - year to week",
            "expression": [
              "",
              "VAR startdate =",
              "    MAX ( 'D_Time Hierarchy'[Full Date] )",
              "VAR startOfWeek2 =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Week End Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR yy =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Year Start Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR lasd1 =",
              "    CALCULATETABLE(DATESBETWEEN ( 'D_Time Hierarchy'[Full Date], yy, startOfWeek2), REMOVEFILTERS('D_Time Hierarchy'))",
              "VAR result1 =",
              "    CALCULATE (",
              "        [Total Sales Amt Agg],",
              "        REMOVEFILTERS ( 'D_Time Hierarchy' ),",
              "        REMOVEFILTERS('D_Relative Time Slicer'),",
              "        KEEPFILTERS ( lasd1 )",
              "    )",
              "RETURN",
              "    result1",
              ""
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Aggregated Measures",
            "lineageTag": "6ad62664-2693-4b6e-bd81-fdd924d5a114",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "LY Total Sales Amt (Rolling YTW)",
            "description": "Not shipped case quantity rolling - year to week (date is less than today)",
            "expression": [
