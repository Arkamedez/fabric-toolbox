          {
            "type": "calculated",
            "name": "ReceivedCountLessThanTotalCount",
            "dataType": "boolean",
            "isDataTypeInferred": true,
            "expression": [
              "",
              "",
              "  IF(",
              "",
              "    'F_Purchase Detail'[Received Count] < ('F_Purchase Detail'[Turn Cnt] + 'F_Purchase Detail'[Promotion Cnt] + 'F_Purchase Detail'[Forward Buy Cnt]),",
              "",
              "    True,",
              "",
              "    False",
              "",
              "  )"
            ],
            "formatString": "\"TRUE\";\"TRUE\";\"FALSE\"",
            "lineageTag": "c0c7cabb-d85f-44e3-b296-a9193fb1ebf2",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "ReceivedWeightNotEqualToTotalWeight",
            "dataType": "boolean",
            "isDataTypeInferred": true,
            "expression": [
              "",
              "",
              "  IF(",
              "",
              "    'F_Purchase Detail'[Received Count] * 'F_Purchase Detail'[Weight Received Count] <> (('F_Purchase Detail'[Turn Cnt] + 'F_Purchase Detail'[Promotion Cnt]) + 'F_Purchase Detail'[Forward Buy Cnt]) * ('F_Purchase Detail'[Weight Received Count] * (('F_Purchase Detail'[Turn Cnt] + 'F_Purchase Detail'[Promotion Cnt]) + 'F_Purchase Detail'[Forward Buy Cnt])),",
              "",
              "    True,",
              "",
              "    False",
              "",
              "  )"
            ],
            "formatString": "\"TRUE\";\"TRUE\";\"FALSE\"",
            "lineageTag": "7e22b700-456d-46b3-a190-f4bba7d3a223",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "SevenDayAgo",
            "dataType": "dateTime",
            "isDataTypeInferred": true,
            "expression": "IF('F_Purchase Detail'[Received Date] >= TODAY()-7,'F_Purchase Detail'[Received Date])",
            "formatString": "General Date",
            "lineageTag": "b9b66d45-72ea-4ce1-a716-23aea55265e3",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "Order Arrival Dates",
            "dataType": "dateTime",
            "isDataTypeInferred": true,
            "expression": [
              "",
              "    IF(",
              "        ISBLANK('F_Purchase Detail'[Received Date]),",
              "        'F_Purchase Detail'[Arrival Date],",
              "        'F_Purchase Detail'[Received Date]",
              "    )"
            ],
            "formatString": "Short Date",
            "lineageTag": "46deb920-35a7-4807-8f38-ab2f2a877009",
            "summarizeBy": "none",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ],
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
