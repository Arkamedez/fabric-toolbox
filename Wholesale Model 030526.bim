          {
            "name": "Allowance Expiry Date",
            "description": "Allowance expiry date (date is less than today)",
            "expression": "If(Max(F_Allowance[Allowance Exp Date])> TODAY(),Max(F_Allowance[Allowance Exp Date]))",
