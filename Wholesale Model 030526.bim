          {
            "name": "Quantity Shipped",
            "description": "Total quantity shipped",
            "expression": [
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales'[Total Quantity Shipped] ),",
              "    USERELATIONSHIP ( 'F_FD.Sales'[Customer Full Key], D_Customer[Customer Full Key] )",
              ")"
            ],
            "formatString": "#,###;(#,###)",
            "displayFolder": "Sales",
            "lineageTag": "c8d71a8f-f251-4dae-a4df-5c9a1df97c7b",
            "changedProperties": [
              {
