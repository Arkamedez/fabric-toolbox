          {
            "name": "Sales Less Ext Cust Fees",
            "expression": "[Total Sales Amt] - [Ext Cust Fee  Amt]",
            "displayFolder": "Sales",
            "lineageTag": "04c0a2da-d71f-483d-a3fd-db19c77f7f9c",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Actual Weight",
            "expression": "if([Ext Price Weight Measure] <= 0, [Ext  Weight], [Ext Price Weight Measure])",
            "formatString": "#,0.00",
            "displayFolder": "Sales",
            "lineageTag": "f7bbc965-9461-4093-8429-923f5a818b50"
          },
          {
            "name": "Cents per lb",
            "expression": [
              "",
              "DIVIDE([Total Sales Amount] - [Cost of Sales], [Ext Price Weight Measure])"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Sales",
            "lineageTag": "ce079b59-43f3-4b02-9e50-37f87298ee64"
          },
          {
            "name": "Cost of Sales",
            "expression": [
              "",
              "SUMX('F_FD.Sales',",
              "IF([Ext Price Weight Measure] <= 0, RELATED(D_Item[List Cost]) * [Ext  Weight] - [Ext Pa Amt], related(D_Item[List Cost]) * [Shipped  Qty] - [Ext Pa Amt]))"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Sales",
            "lineageTag": "a15bda41-b64b-47e0-84d3-12774120883e"
          },
          {
            "name": "Ext Pa Amt",
            "expression": "sum('F_FD.Sales'[Extended Promotion Allowance Amt])",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Sales",
            "lineageTag": "a6e74d2b-9a0c-4928-bf8a-9b477997ccc3"
          },
          {
            "name": "Ext Price Weight Measure",
            "expression": "sumx('F_FD.Sales', 'F_FD.Sales'[Shipped Qty] * related(D_Item[price weight measure]))",
            "formatString": "#,0.00",
            "displayFolder": "Sales",
            "lineageTag": "42654a4b-c0e6-47c7-a94b-ae2ff378298e"
          },
          {
            "name": "List Cost",
            "expression": "sum(D_Item[List Cost])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Inventory",
            "lineageTag": "e4e88883-c5a8-4ce7-8bfe-1f1f43bd762b"
          },
          {
            "name": "Profit",
            "expression": [
              "sumx('F_FD.Sales',",
              "'F_FD.Sales'[Total Sales Amt] + 'F_FD.Sales'[Extended Promotion Allowance Amt] + related(D_Item[Meat Swell Amount]) - related(D_Item[List Cost]))"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Sales",
            "lineageTag": "9d94f325-7797-44d2-99e4-2ae14fb540a2"
          },
          {
            "name": "Sales Profit %",
            "expression": "DIVIDE([Profit], [Total Sales Amount], 0) ",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Sales",
            "lineageTag": "6281371a-5ffc-4e28-864a-fb2428e5a759"
          },
          {
            "name": "Total Inventory Value",
            "expression": [
              "",
              "var eq = sum(D_Item[Inventory Total]) * sum(D_Item[List Cost])",
              "return if(SELECTEDVALUE(D_Item[Average Weight]) <= 0, eq,eq * round(sum(D_Item[Average Weight]),2))"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Inventory",
            "lineageTag": "42ea3208-1889-4d1b-8e38-d8f34271edee"
          },
          {
            "name": "Out of Stock Raw",
            "expression": "sum('F_FD.Sales'[Ordered Qty]) - sum('F_FD.Sales'[Shipped Qty])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Fill Rate",
            "lineageTag": "831ae90c-80fd-473a-9f7d-6e64987284d0"
          },
          {
            "name": "Catch Weight Qty",
            "expression": "sum('F_Inventory Detail'[Catch Weight Qty])",
            "formatString": "0.00",
            "displayFolder": "Inventory",
            "lineageTag": "b87c628b-d171-49c7-a600-434b898138a2"
          }
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
