        "measures": [
          {
            "name": "Selected Filters-PO Level",
            "expression": [
              "",
              "VAR PO_Level = \"",
              "\"",
              "VAR FiscalYear = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Year]),",
              "                 \"Fiscal Year = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Year]), 'D_Time Hierarchy'[Fiscal Year], \", \") & PO_Level, \"\")",
              "",
              "VAR FiscalQuaterdetail = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Quarter Detail]),",
              "                 \"Fiscal Quarter Detail = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Quarter Detail]), 'D_Time Hierarchy'[Fiscal Quarter Detail], \", \") & PO_Level, \"\")",
              "",
              "",
              "VAR FiscalPeriodwithEndDate = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Period with End Date]),",
              "                 \"Fiscal Period with End Date = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Period with End Date]), 'D_Time Hierarchy'[Fiscal Period with End Date], \", \") & PO_Level, \"\")",
              "",
              "VAR Weekending = IF(ISFILTERED('D_Time Hierarchy'[Week Ending]),",
              "                 \"Week Ending = \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Week Ending]), 'D_Time Hierarchy'[Week Ending], \", \") & PO_Level, \"\")",
              "",
              "VAR RelativeTimePrompt = IF(ISFILTERED('D_Relative Time Slicer'[Relative Time Prompt]),",
              "                 \"Relative Time Prompt = \" & CONCATENATEX(ALLSELECTED('D_Relative Time Slicer'[Relative Time Prompt]), 'D_Relative Time Slicer'[Relative Time Prompt], \", \") & PO_Level, \"\")",
              "",
              "VAR DateOrdered = IF(ISFILTERED('F_Purchase Header'[Ordered Date]),",
              "                 \"Date Ordered = \" & CONCATENATEX(ALLSELECTED('F_Purchase Header'[Ordered Date]), 'F_Purchase Header'[Ordered Date], \", \") & PO_Level, \"\")",
              "",
              "VAR DateReceived = IF(ISFILTERED('F_Purchase Header'[Received Dt]),",
              "                 \"Date Received = \" & CONCATENATEX(ALLSELECTED('F_Purchase Header'[Received Dt]), 'F_Purchase Header'[Received Dt], \", \") & PO_Level, \"\")",
              "",
              "VAR PONumber = IF(ISFILTERED('F_Purchase Header'[PO Nbr]),",
              "                 \"PO Number = \" & CONCATENATEX(ALLSELECTED('F_Purchase Header'[PO Nbr]), 'F_Purchase Header'[PO Nbr], \", \") & PO_Level, \"\")",
              "",
              "VAR FacilityID1 = IF(ISFILTERED('F_Purchase Header'[Facility ID]),",
              "                 \"Facility ID = \" & CONCATENATEX(ALLSELECTED('F_Purchase Header'[Facility ID]), 'F_Purchase Header'[Facility ID], \", \") & PO_Level, \"\")",
              "",
              "VAR MasterVendor = IF(ISFILTERED('D_PO Vendor'[Master Vendor Detail]),",
              "                 \"Master Vendor = \" & CONCATENATEX(ALLSELECTED('D_PO Vendor'[Master Vendor Detail]), 'D_PO Vendor'[Master Vendor Detail], \", \") & PO_Level, \"\")",
              "",
              "VAR FacilityNbrdes = IF(ISFILTERED('D_PO Vendor'[Facility Nbr Desc]),",
              "              \"Facility = \" & CONCATENATEX(ALLSELECTED('D_PO Vendor'[Facility Nbr Desc]), 'D_PO Vendor'[Facility Nbr Desc], \", \") & PO_Level, \"\")",
              "VAR VendorDetailNbr = IF(ISFILTERED('D_PO Vendor'[Vendor Detail Nbr]),",
              "             \"VendorDetailNbr = \" & CONCATENATEX(ALLSELECTED('D_PO Vendor'[Vendor Detail Nbr]), 'D_PO Vendor'[Vendor Detail Nbr], \", \") & PO_Level, \"\")",
              "",
              "VAR BuyerID = IF(ISFILTERED('F_Purchase Header'[Buyer Id]),",
              "             \"Buyer ID = \" & CONCATENATEX(ALLSELECTED('F_Purchase Header'[Buyer Id]), 'F_Purchase Header'[Buyer Id], \", \") & PO_Level, \"\")",
              "",
              "VAR BuyerNM = IF(ISFILTERED('F_Purchase Header'[Buyer Nm]),",
              "             \"Buyer Name = \" & CONCATENATEX(ALLSELECTED('F_Purchase Header'[Buyer Nm]), 'F_Purchase Header'[Buyer Nm], \", \") & PO_Level, \"\")",
              "",
              "VAR StatusCode = IF(ISFILTERED('F_Purchase Header'[Status Code]),",
              "             \"Status Code = \" & CONCATENATEX(ALLSELECTED('F_Purchase Header'[Status Code]), 'F_Purchase Header'[Status Code], \", \") & PO_Level, \"\")",
              "",
              " RETURN",
              " FiscalYear&FiscalQuaterdetail&FiscalPeriodwithEndDate&Weekending&RelativeTimePrompt&DateOrdered&DateReceived&PONumber&FacilityID1&MasterVendor&FacilityNbrdes&VendorDetailNbr&BuyerID&BuyerNM&StatusCode",
              ""
            ],
            "isHidden": true,
            "lineageTag": "02636a29-50f0-420d-b985-8727b5cf820f",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          }
        ],
