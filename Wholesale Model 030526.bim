        "partitions": [
          {
            "name": "D_Facility-16e69de7-272d-4def-af2e-143b9521726e",
            "mode": "dual",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    FD_FACILITY_VW_View = FD_Schema{[Name=\"FD_FACILITY_VW\",Kind=\"View\"]}[Data],",
                "    #\"Removed Other Columns\" = Table.SelectColumns(FD_FACILITY_VW_View,{\"FACILITY_PK\", \"FACILITY_NBR\", \"FACILITY_DESC\", \"BUSINESS_UNIT\", \"OPERATING_UNIT\", \"BILLING_SYSTEM_CD\", \"PLATFORM_TYPE\", \"DIV_PREFIX_1\", \"DIV_PREFIX_2\", \"ACTIVE_FLAG\", \"UPDATE_TYPE\", \"ENTERPRISE_ID\", \"ENTERPRISE_DESC\", \"REGION_ID\", \"REGION_NM\", \"DIVISION_ID\", \"DIVISION_NAME\", \"FACILITY_DIV_GRP\", \"FACILITY_NBR_DESC\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Removed Other Columns\",{{\"ACTIVE_FLAG\", \"Active Flag\"}, {\"BILLING_SYSTEM_CD\", \"Billing System Code\"}, {\"DIVISION_ID\", \"Division ID\"}, {\"DIVISION_NAME\", \"Division\"}, {\"ENTERPRISE_DESC\", \"Enterprise\"}, {\"ENTERPRISE_ID\", \"Enterprise ID\"}, {\"FACILITY_DESC\", \"Facility\"}, {\"FACILITY_NBR\", \"Facility Nbr\"}, {\"FACILITY_PK\", \"Facility Key\"}, {\"PLATFORM_TYPE\", \"Platform Type\"}, {\"REGION_ID\", \"Region ID\"}, {\"REGION_NM\", \"Region\"}, {\"UPDATE_TYPE\", \"Update Type\"}, {\"BUSINESS_UNIT\", \"Business Unit\"}, {\"OPERATING_UNIT\", \"Operating unit\"}, {\"FACILITY_DIV_GRP\", \"Facility Division Group\"}, {\"DIV_PREFIX_1\", \"Division Prefix 1\"}, {\"DIV_PREFIX_2\", \"Division Prefix 2\"}, {\"FACILITY_NBR_DESC\", \"Facility Nbr Desc\"}})",
                "in",
                "    #\"Renamed Columns\""
              ]
            }
          }
        ],
