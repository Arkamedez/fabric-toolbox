        "partitions": [
          {
            "name": "D_Relative Time Slicer-76267d3f-f001-4320-8505-5da993321647",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": [
                "",
                "VAR curDay = TODAY()",
                "VAR startOfWeek = LOOKUPVALUE('D_Time Hierarchy'[Fiscal Week Start Date], 'D_Time Hierarchy'[Full Date], curDay)",
                "VAR startOfPeriod = LOOKUPVALUE('D_Time Hierarchy'[Fiscal Period Start Date], 'D_Time Hierarchy'[Full Date], curDay)",
                "VAR _startOfQuarter = LOOKUPVALUE('D_Time Hierarchy'[Fiscal Quarter Start Date], 'D_Time Hierarchy'[Full Date], curDay)",
                "VAR _startOfYear = LOOKUPVALUE('D_Time Hierarchy'[Fiscal Year Start Date], 'D_Time Hierarchy'[Full Date], curDay)",
                "VAR previousPeriod = LOOKUPVALUE('D_Time Hierarchy'[Previous Fiscal Period], 'D_Time Hierarchy'[Full Date], curDay)",
                "VAR previousPeriodStart = LOOKUPVALUE('D_Time Hierarchy'[Fiscal Period Start Date], 'D_Time Hierarchy'[Fiscal Period], previousPeriod)",
                "VAR previousPeriodEnd = LOOKUPVALUE('D_Time Hierarchy'[Fiscal Period End Date], 'D_Time Hierarchy'[Fiscal Period], previousPeriod)",
                "var endOfWeek = LOOKUPVALUE('D_Time Hierarchy'[Fiscal Week End Date], 'D_Time Hierarchy'[Full Date], curDay)",
                "Return",
                "UNION(",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], curDay , -1, DAY), \"Relative Time Prompt\", \"Today\", \"Order\", \"00\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], curDay - 1, -1, DAY), \"Relative Time Prompt\", \"Yesterday\", \"Order\", \"01\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], endOfWeek, DATEDIFF(endOfWeek, startOfWeek,DAY) - 1, DAY), \"Relative Time Prompt\", \"Current Week\", \"Order\", \"02\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], startOfWeek - 1, -7,DAY), \"Relative Time Prompt\", \"Previous Week\", \"Order\", \"03\"), ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], startOfWeek - 8, -7,DAY), \"Relative Time Prompt\", \"Week Before Last\", \"Order\", \"04\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], endOfWeek, DATEDIFF(endOfWeek, startOfWeek,DAY) - 8, DAY), \"Relative Week Prompt\", \"This week and Last Week\", \"Order\", \"05\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], startOfWeek - 1, -28, DAY), \"Relative Time Prompt\", \"Last 4 weeks\", \"Order\", \"06\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], startOfWeek - 1, -84, DAY), \"Relative Time Prompt\", \"Last 12 weeks\", \"Order\", \"07\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], startOfWeek - 1, -91, DAY), \"Relative Time Prompt\", \"Last 13 weeks\", \"Order\", \"08\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], startOfWeek - 1, -182, DAY), \"Relative Time Prompt\", \"Last 26 weeks\", \"Order\", \"09\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], startOfWeek - 1, -364, DAY), \"Relative Time Prompt\", \"Last 52 weeks\", \"Order\", \"10\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], startOfWeek - 1, -735, DAY), \"Relative Time Prompt\", \"Last 105 weeks\", \"Order\", \"11\"),",
                "\tADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], previousPeriodStart, DATEDIFF(previousPeriodStart, previousPeriodEnd, DAY) + 1, DAY), \"Relative Time Prompt\", \"Previous Period\", \"Order\", \"12\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], startOfWeek - 1, DATEDIFF(startOfWeek - 1, startOfPeriod,DAY) - 1, DAY), \"Relative Time Prompt\", \"Start of Period to LW (PTW)\", \"Order\", \"13\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], startOfWeek - 1, DATEDIFF(startOfWeek - 1, _startOfQuarter,DAY ) - 1, DAY), \"Relative Time Prompt\", \"Start of Quarter to LW (QTW)\", \"Order\", \"14\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], startOfWeek - 1, DATEDIFF(startOfWeek - 1, _startOfYear, DAY) - 1, DAY), \"Relative Time Prompt\", \"Start of Year to LW (YTW)\", \"Order\", \"15\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], curDay, DATEDIFF(curDay, _startOfYear, DAY) - 1, DAY), \"Relative Time Prompt\", \"Start of Year to Today (YTD)\", \"Order\", \"16\"),",
                "    ADDCOLUMNS(DATESINPERIOD('D_Time Hierarchy'[Full Date], STARTOFYEAR('D_Time Hierarchy'[Full Date],2018), +10, YEAR), \"Relative Time Prompt\", \"All\", \"Order\", \"17\")",
                "    ",
                "    )"
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_Id",
            "value": "7aa51f86749041ec83babb5c35476ac8"
          }
        ]
