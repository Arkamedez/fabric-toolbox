              }
            ]
          },
          {
            "name": "Not Shipped %(Unauth)",
            "description": "Not shipped case quantity % {Specific to ship error group unauthorized} (date is less than today) (day level)",
            "expression": [
              "DIVIDE (",
              "    [Not Shipped(Unauth)],",
              "    [Ordered Case  Qty],",
              "    0",
              ")"
            ],
