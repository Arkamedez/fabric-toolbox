          {
            "type": "calculated",
            "name": "Previous Week with Week Ending",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": [
              "",
              " VAR _Date = TODAY() - WEEKDAY(TODAY(),1) + 1 ",
              "RETURN",
              " IF('D_Time Hierarchy'[Full Date] >=  _Date - 7 && 'D_Time Hierarchy'[Full Date] <=  _Date - 1, \"Previous Week\", 'D_Time Hierarchy'[Week Ending])"
            ],
            "sortByColumn": "Fiscal Week End Date",
            "lineageTag": "22a663e0-2a41-47e6-9408-3c1d103d8ec4",
            "summarizeBy": "none",
            "changedProperties": [
              {
                "property": "SortByColumn"
              }
            ],
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          }
