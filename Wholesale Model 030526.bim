          {
            "name": "Cost + Freight",
            "expression": "[Ext Whse Sales Amt] + [Ext Freight Amt]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Sales",
            "lineageTag": "88b69f71-ccb9-45c0-95af-a49b69a10ff6"
          },
          {
            "name": "Ext Freight Amt",
            "expression": "sum('F_FD.Sales'[Extended Freight Amt])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Sales",
            "lineageTag": "fc764af1-0be9-4a88-94f7-08b92c77039d"
          },
          {
            "name": "Ext Freight Amt Var % to LY (<Today)",
            "expression": "DIVIDE([Ext Freight Amt] - [LY Ext Freight Amt (<Today)],[LY Ext Freight Amt (<Today)],0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Sales",
            "lineageTag": "a6b66e34-4ad2-4e84-b1e7-9e7af43163d1"
          },
          {
            "name": "Gross Margin %",
            "expression": "DIVIDE([Retail Amt] - [Ext Whse Sales Amt], [Retail Amt])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Sales",
            "lineageTag": "990c2d51-bfaa-49ff-a5bc-94b3916097a0"
          },
          {
            "name": "LY Ext Freight Amt",
            "expression": [
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales'[Extended Freight Amt]),",
              "   FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[Date ID LY] )",
              "    ),",
              "   all('D_Relative Time Slicer')",
              ")"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Sales",
            "lineageTag": "7ab0928d-03b0-4f08-9aba-da7570d5f486"
          },
          {
            "name": "LY Ext Freight Amt (<Today)",
            "expression": [
              "CALCULATE (",
              "    [LY Ext Freight Amt],",
              "    FILTER ( 'D_Time Hierarchy', 'D_Time Hierarchy'[Full Date] <= TODAY () ))"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Sales",
            "lineageTag": "c1055c33-6afd-4168-9a90-5067fd695fe8"
          },
          {
            "name": "Margin w/ Freight %",
            "expression": "DIVIDE([Retail Amt] - [Ext Whse Sales Amt] + [Ext Freight Amt], [Retail Amt])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Sales",
            "lineageTag": "607b275f-9db9-4c1a-a45f-a37569b3e4b1"
          },
