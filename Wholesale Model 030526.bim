        "partitions": [
          {
            "name": "F_Sales Bill Allowance",
            "mode": "directQuery",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Value.NativeQuery(Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"){[Name=EDW_Database]}[Data], \"WITH NON_ZERO_DC_SALES AS (",
                "SELECT",
                "dt.FISCAL_WEEK",
                ",h.Facility_id",
                ",f.FACILITY_PK",
                ",h.item_nbr",
                ",fi.item_key",
                " ,h.INVOICE_NBR",
                ",MIN(h.AD_ALLOW_AMT) as AD_ALLOW_AMT",
                ",sum(h.RANDOM_WGT) as RANDOM_WGT_HST",
                ",sum(h.SHIPPED_QTY) as SHIPPED_QTY_HST",
                ",SUM(h.EXT_PROMO_ALLW_AMT) Total_Amount_HST",
                ",SUM(h.UNITS_LBS_WHSE_QTY)",
                ",CASE",
                "    WHEN  SUM(h.RANDOM_WGT) > 0  AND h.FACILITY_ID::INT != 1 THEN SUM(h.SHIPPED_QTY*h.UNITS_LBS_WHSE_QTY) ",
                "    WHEN  SUM(h.RANDOM_WGT) > 0  AND h.FACILITY_ID::INT = 1 AND MIN(Random_wgt_flg) = 'R'  THEN SUM(h.EXT_RANDOM_WGT)",
                "    WHEN  SUM(h.RANDOM_WGT) > 0  AND h.FACILITY_ID::INT = 1 AND MIN(Random_wgt_flg) != 'R'  THEN SUM(h.SHIPPED_QTY)",
                "    WHEN  SUM(h.SHIPPED_QTY) > 0  AND h.FACILITY_ID::INT != 1 THEN SUM(h.SHIPPED_QTY)",
                "    WHEN  SUM(h.SHIPPED_QTY) > 0  AND h.FACILITY_ID::INT = 1  THEN SUM(h.SHIPPED_QTY)    ",
                "END AS ACCURATE_QTY_HST",
                "",
                "from FD.DC_SALES_HST h",
                "INNER JOIN FD.FD_ITEM_VW fi ON fi.FACILITY_ID = h.FACILITY_ID AND fi.ITEM_NBR = h.ITEM_NBR AND current_flg = 1",
                "Inner join FD.FD_facility_vw f on f.FACILITY_PK = h.facility_id",
                "inner join MDM.date_dim dt on h.transaction_dt=dt.full_date",
                "where ",
                "h.transaction_dt >= DATE_TRUNC('week',DATEADD(DAY, -365, TO_DATE(CURRENT_DATE()))) and h.transaction_dt < date_trunc('week',dateadd(day,7,CURRENT_DATE()))/*Last Two Years 105 Fiscal Weeks excluding current week*/",
                "and",
                "f.PLATFORM_TYPE not in ('MDV') /*Excluding Military DCs*/",
                "AND (EXT_PROMO_ALLW_AMT <> 0 OR EXT_PROMO_ALLW_AMT IS NULL) /*Excluding Zero Promotion amount sales*/",
                "AND SALES_REC_FLG = 'Y' /*Default Filters*/",
                "AND ORDER_TYPE_CD != 'CR' /*Default Filters*/",
                "AND fi.CURRENT_FLG = 1 AND (fi.PURCH_STATUS IS NULL OR fi.PURCH_STATUS NOT IN ('Z') ) /*Default Filters*/",
                "",
                "group by 1,2,3,4,5,6",
                ")",
                ",",
                "Allw_from_vend AS",
                "(",
                "    select",
                "    s.BILLING_TMSP::DATE AS BILLING_TMSP,",
                "s.Facility_id,",
                "s.item_nbr,",
                "fi.item_key,",
                "s.INVOICE_NM as INVOICE_ID,",
                "s.ALLOWANCE_DEAL_NM as DEAL_ID,",
                "s.CUSTOMER_ID,",
                "sum(s.SELLING_WEIGHT) as SELLING_WEIGHT,",
                "",
                "CASE",
                "    WHEN SUM(s.SELLING_WEIGHT) > 0 THEN ROUND(SUM(s.SELLING_WEIGHT*PA_RATE.EDITED_PA_RATE), 2)   ",
                "    ELSE ROUND(SUM(s.SHIPPED_QTY*PA_RATE.EDITED_PA_RATE),2)",
                "END AS ALLOWANCE_AMT,",
                "MIN(PA_RATE.EDITED_PA_RATE) AS EDITED_PA_RATE,",
                "MIN(DC_SALES.AD_ALLOW_AMT) AS AD_ALLOW_AMT,",
                "CASE",
                "    WHEN  SUM(s.SELLING_WEIGHT) > 0 AND s.FACILITY_ID::INT != 1  THEN SUM(s.SELLING_WEIGHT*PA_RATE.EDITED_PA_RATE)/MIN(DC_SALES.AD_ALLOW_AMT)",
                "    WHEN  SUM(s.SELLING_WEIGHT) > 0 AND s.FACILITY_ID::INT = 1  THEN SUM(s.SELLING_WEIGHT)",
                "",
                "    WHEN  SUM(s.SHIPPED_QTY) > 0 AND s.FACILITY_ID::INT != 1  THEN SUM(s.SHIPPED_QTY*PA_RATE.EDITED_PA_RATE)/MIN(DC_SALES.AD_ALLOW_AMT)",
                "    WHEN  SUM(s.SHIPPED_QTY) > 0 AND s.FACILITY_ID::INT = 1  THEN SUM(s.SHIPPED_QTY)",
                "END AS SHIPPED_QTY,",
                "",
                "",
                "from promos.sales_bill_allowance s",
                "inner join MDM.date_dim dt on s.billing_tmsp::date=dt.full_date",
                "INNER JOIN FD.FD_ITEM_VW fi ON fi.FACILITY_ID = s.FACILITY_ID AND fi.ITEM_NBR = s.ITEM_NBR AND fi.current_flg = 1",
                "Inner join FD.FD_facility_vw f on f.FACILITY_PK = s.facility_id",
                "",
                "LEFT JOIN (",
                "SELECT",
                "    DEAL_ID,",
                "    FACILITY_ID,",
                "    ITEM_CD,",
                "    EDITED_PA_RATE,",
                "    DEAL_UID,",
                "    ROW_NUMBER() OVER(PARTITION BY FACILITY_ID,  DEAL_ID, ITEM_CD ORDER BY DEAL_UID DESC ) AS ROWNUM",
                "FROM (",
                "    SELECT DEAL_ID, FACILITY_ID, ITEM_CD, EDITED_PA_RATE, DEAL_UID",
                "    FROM EDL.SNX.BB_DEAL_ITEM",
                "    UNION",
                "    SELECT DEAL_ID, FACILITY_ID, ITEM_CD, EDITED_PA_RATE, DEAL_UID",
                "    FROM EDL.SNX.PA_ACCRUAL_ITEM",
                ")",
                ") PA_RATE ON s.ALLOWANCE_DEAL_NM = PA_RATE.DEAL_ID AND s.FACILITY_ID::INT = PA_RATE.FACILITY_ID::INT  AND s.ITEM_NBR::INT = PA_RATE.ITEM_CD::INT  AND ROWNUM = 1",
                "LEFT JOIN NON_ZERO_DC_SALES DC_SALES ON  s.FACILITY_ID = DC_SALES.FACILITY_ID AND s.ITEM_NBR = DC_SALES.ITEM_NBR AND s.INVOICE_NM = DC_SALES.INVOICE_NBR AND DT.FISCAL_WEEK = DC_SALES.FISCAL_WEEK",
                "",
                "",
                "where",
                "s.billing_tmsp >= DATE_TRUNC('week',DATEADD(DAY, -365, TO_DATE(CURRENT_DATE()))) and s.billing_tmsp < date_trunc('week',dateadd(day,7,CURRENT_DATE())) /*Last Two Years 105 Fiscal Weeks excluding current week*/",
                "AND ",
                "f.PLATFORM_TYPE not in ('MDV') /*Excluding Military DCs*/",
                "AND ALLOWANCE_REFLECTED_FLG = 'Y'",
                " ",
                "group by 1,2,3,4,5,6,7",
                "",
                "",
                ")",
                "",
                "",
                ", DC_SALES_SNX_INVOICE AS (",
                "select",
                "s.BILLING_TMSP",
                ",s.FACILITY_ID",
                ",TO_CHAR(s.ITEM_NBR) AS ITEM_NBR",
                ",TO_CHAR(s.INVOICE_ID) AS INVOICE",
                ",TO_CHAR(s.item_key) AS item_key",
                ",DEAL_ID",
                ",C.CUSTOMER_NBR_DESC",
                ",SUM(s.SELLING_WEIGHT) AS SELLING_WEIGHT",
                ",SUM(SHIPPED_QTY) SHIPPED_QTY",
                ",SUM(s.ALLOWANCE_AMT) AS ALLOWANCE_AMT",
                "",
                "from Allw_from_vend s",
                "LEFT JOIN (SELECT DISTINCT FACILITY_ID,CUSTOMER_NBR_STND,CUSTOMER_NBR_DESC FROM FD.FD_CUSTOMER_VW WHERE  current_flg = 1) C ON s.CUSTOMER_ID = C.CUSTOMER_NBR_STND AND s.FACILITY_ID = C.FACILITY_ID",
                "",
                "GROUP BY 1,2,3,4, 5, 6, 7",
                ") SELECT * FROM DC_SALES_SNX_INVOICE\", null, [EnableFolding=true])",
                "in",
                "    Source"
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
