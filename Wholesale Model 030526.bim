          {
            "name": "F_Short Dated Inventory-f5672ca5-7c87-4a35-b917-6efc86755b2b",
            "mode": "directQuery",
            "queryGroup": "Others",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_DEV_Database = Source{[Name=\"EDW_DEV\",Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_DEV_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    SHORT_DATED_INVENTORY_VW_View = FD_Schema{[Name=\"SHORT_DATED_INVENTORY_VW\",Kind=\"View\"]}[Data],",
                "    #\"Removed Other Columns\" = Table.SelectColumns(SHORT_DATED_INVENTORY_VW_View,{\"FACILITY_ID\", \"FACILITY_NBR_DESC\", \"FACILITY_NAME\", \"BUYER_NBR\", \"LEAD_USER_ID\", \"BUYER_NAME\", \"BUYER_NBR_DESC\", \"WAREHOUSE_CD\", \"ITEM_DEPT_ID\", \"ITEM_NBR_HS\", \"ITEM_DESCRIP\", \"UPC_CASE\", \"STORE_PACK_CASE\", \"LIST_COST\", \"CURRENT_LOCATION\", \"RUN_DT\", \"INVENTORY_TOTAL\", \"PROD_QTY\", \"CLOSED_DATED_QTY\", \"RECEIPT_TMSP\", \"PROD_CD_DT\", \"PULL_DT\", \"CALENDAR_PULLDAYSLEFT\", \"CASES_PER_WEEK\", \"DAILY_CASE_FORECAST_QTY\", \"ESTIMATED_DAY_QTY\", \"MASTER_VENDOR_ID_DESC\", \"VENDOR_NBR\", \"VENDOR_NAME\", \"VENDOR_DETAIL_NBR\", \"DISTRESS_DAYS\", \"SHELF_LIFE\", \"INVENTORY_PROMOTION\", \"ON_ORDER_PROMOTION\", \"RESERVE_COMMITTED\", \"RESERVE_UNCOMMITTED\", \"PURCH_STATUS\", \"BILLING_STATUS\", \"MERCH_DEPT_GRP\", \"MERCH_DEPT_GRP_DESC\", \"MDSE_DEPT_GROUP\", \"MERCH_DEPT\", \"MERCH_DEPT_DESC\", \"MDSE_DEPT\", \"MERCH_GRP\", \"MERCH_GRP_DESC\", \"MDSE_GROUP\", \"MERCH_CAT\", \"MERCH_CAT_DESC\", \"MDSE_CATALOG\", \"MERCH_CLASS\", \"MERCH_CLASS_DESC\", \"MDSE_CLASS\", \"ITEM_RISK_CASES_CNT\", \"ITEM_RISK_DOLLARS_AMT\", \"ITEM_AT_RISK_FLG\"})",
                "in",
                "    #\"Removed Other Columns\""
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
