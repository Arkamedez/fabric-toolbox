        "partitions": [
          {
            "name": "D_Shipper Component",
            "mode": "directQuery",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database= Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    FD_ITEM_Table = FD_Schema{[Name=\"SHIPPER_COMPONENT\",Kind=\"Table\"]}[Data],",
                "    #\"Renamed Columns\" = Table.RenameColumns(FD_ITEM_Table,{{\"FACILITY_ID\", \"Facility ID\"}, {\"SHIPPER_UPC_CASE\", \"Shipper UPC Case\"}, {\"SHIPPER_UPC_UNIT\", \"Shipper UPC Unit\"}, {\"SHIPPER_ITEM_NBR\", \"Shipper Item Nbr\"}, {\"SHIPPER_DESC\", \"Shipper Description\"}, {\"SHIPPER_PACK_ID\", \"Shipper Pack ID\"}, {\"SHIPPER_SIZE_QTY\", \"Shipper Size Qty\"}, {\"SHIPPER_UOM_CD\", \"Shipper UOM Code\"}, {\"COMPONENT_UPC_CASE\", \"Component UPC Case\"}, {\"COMPONENT_UPC_UNIT\", \"Component UPC Unit\"}, {\"COMPONENT_ITEM_NBR\", \"Component Item Nbr\"}, {\"COMPONENT_DESC\", \"Component Description\"}, {\"COMPONENT_PACK_ID\", \"Component Pack ID\"}, {\"COMPONENT_SIZE_QTY\", \"Component Size Qty\"}, {\"COMPONENT_UOM_CD\", \"Component UOM Code\"}, {\"SHIPPER_COMPONENT_QTY\", \"Shipper Component Qty\"}, {\"SUGGESTED_RETAIL_PRICE_UNIT_CNT\", \"Suggested Retail Price Unit Cnt\"}, {\"SUGGESTED_RETAIL_PRICE_AMT\", \"Suggest Retail Price Amt\"}, {\"CURRENT_UNBURDENED_COST_0_AMT\", \"Current Unburdened Cost 0 Amt\"}, {\"CURRENT_UNBURDENED_COST_1_AMT\", \"Current Unburdened Cost 1 Amt\"}, {\"CURRENT_UNBURDENED_COST_2_AMT\", \"Current Unburdened Cost 2 Amt\"}, {\"CURRENT_UNBURDENED_COST_3_AMT\", \"Current Unburdened Cost 3 Amt\"}, {\"CURRENT_BURDENED_COST_0_AMT\", \"Current Burdened Cost 0 Amt\"}, {\"CURRENT_BURDENED_COST_1_AMT\", \"Current Burdened Cost 1 Amt\"}, {\"CURRENT_BURDENED_COST_2_AMT\", \"Current Burdened Cost 2 Amt\"}, {\"CURRENT_BURDENED_COST_3_AMT\", \"Current Burdened Cost 3 Amt\"}, {\"FUTURE_UNBURDENED_COST_0_AMT\", \"Future Unburdened Cost 0 Amt\"}, {\"FUTURE_UNBURDENED_COST_1_AMT\", \"Future Unburdened Cost 1 Amt\"}, {\"FUTURE_UNBURDENED_COST_2_AMT\", \"Future Unburdened Cost 2 Amt\"}, {\"FUTURE_UNBURDENED_COST_3_AMT\", \"Future Unburdened Cost 3 Amt\"}, {\"FUTURE_BURDENED_COST_0_AMT\", \"Future Burdened Cost 0 Amt\"}, {\"FUTURE_BURDENED_COST_1_AMT\", \"Future Burdened Cost 1 Amt\"}, {\"FUTURE_BURDENED_COST_2_AMT\", \"Future Burdened Cost 2 Amt\"}, {\"FUTURE_BURDENED_COST_3_AMT\", \"Future Burdened Cost 3 Amt\"}, {\"UNBURDENED_COST_EFFECTIVE_DT\", \"Unburdened Cost Effective Date\"}, {\"SIZE_CD\", \"Size Code\"}, {\"RETAIL_UNIT_AMT\", \"Retail Unit Amount\"}, {\"RETAIL_UNIT_CD\", \"Retail Unit Code\"}, {\"BRAND_CD\", \"Brand Code\"}, {\"BRAND_DESC\", \"Brand Description\"}, {\"PRE_PRICE_UNIT_CNT\", \"Pre Price Unit Cnt\"}, {\"PRE_PRICE_AMT\", \"Pre Price Amt\"}, {\"AVAILABLE_DT\", \"Available Date\"}, {\"WEIGHT_DEAL_PCT\", \"Weight Deal Pct\"}, {\"PRIMARY_ITEM_FLG\", \"Primary Item Flag\"}, {\"DEPT_GROUP_CD\", \"Dept Group Code\"}, {\"DEPT_CD\", \"Dept Code\"}, {\"MERCH_GROUP_CD\", \"Merch Group Code\"}, {\"MERCH_CATEGORY_CD\", \"Merch Category Code\"}, {\"MERCH_CLASS_CD\", \"Merch Class Code\"}, {\"POS_ITEM_DESC\", \"POS Item Description\"}, {\"RETAIL_ITEM_DESC\", \"Retail Item Description\"}, {\"SHIPPER_UPC_UNIT_CD\", \"Shipper UPC Unit CD\"}, {\"COMPONENT_UPC_UNIT_CD\", \"Component UPC Unit CD\"}, {\"CURRENT_FLG\", \"Current Flag\"}, {\"ITEM_KEY\", \"Item Key\"}}),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Renamed Columns\",{\"CREATE_TMSP\", \"UPDATE_TMSP\", \"ORIGIN\"})",
                "in",
                "    #\"Removed Columns\""
              ]
            }
          }
        ],
