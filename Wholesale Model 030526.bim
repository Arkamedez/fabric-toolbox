                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    SHIP_REJECT_Table = FD_Schema{[Name=\"SHIP_REJECT\",Kind=\"Table\"]}[Data],",
                "    #\"Renamed Columns\" = Table.RenameColumns(SHIP_REJECT_Table,{{\"CREATE_TMSP\", \"Create Timestamp\"}, {\"FACILITY_ID\", \"Facility ID\"}, {\"ORIGIN\", \"Origin\"}, {\"SHIP_REJECT_CD\", \"Ship Reject Code\"}, {\"SHIP_REJECT_DESC\", \"Ship Reject\"}, {\"SHIP_REJECT_PK\", \"Ship Reject Key\"}, {\"UPDATE_TMSP\", \"Update Timestamp\"}, {\"SHIP_ERROR_GRP_CD\", \"Ship Error Group Code\"}}),",
                "    #\"Removed Other Columns\" = Table.SelectColumns(#\"Renamed Columns\",{\"Ship Reject Key\", \"Facility ID\", \"Ship Reject Code\", \"Ship Reject\", \"Ship Error Group Code\"})",
                "in",
                "    #\"Removed Other Columns\""
              ]
            }
