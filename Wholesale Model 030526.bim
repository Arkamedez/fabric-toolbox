                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "LY Shipped Case Qty - Not Ship MK (Rolling YTW)",
            "description": "Last year shipped case quantity for not shipped markout rolling - year to week",
            "expression": [
              "",
              "VAR startdate =",
              "    MAX ( 'D_Time Hierarchy'[Full Date] )",
              "VAR startOfWeek2 =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Week End Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR yy =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Year Start Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR lasd1 =",
              "   CALCULATETABLE(DATESBETWEEN ( 'D_Time Hierarchy'[Full Date], yy, startOfWeek2), REMOVEFILTERS('D_Time Hierarchy'))",
              "VAR result1 =",
              "    CALCULATE (",
              "        [LY Shipped Qty Agg]-[LY Not Shipped Case Qty (Markout)],",
              "        REMOVEFILTERS ( 'D_Time Hierarchy' ),",
              "        REMOVEFILTERS('D_Relative Time Slicer'),",
              "        KEEPFILTERS ( lasd1 )",
              "    )",
              "RETURN",
              "    result1"
            ],
            "formatString": "#,0",
            "displayFolder": "Aggregated Measures",
            "lineageTag": "55c04449-8bd4-4614-aaad-67d17671b793",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "LY Not Shipped Case Qty (Rolling YTW)",
            "description": "Last year not shipped cast quantity for rolling - year to week",
            "expression": [
              "",
              "VAR startdate =",
              "    MAX ( 'D_Time Hierarchy'[Full Date] )",
              "VAR startOfWeek2 =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Week End Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR yy =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Year Start Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR lasd1 =",
              "    CALCULATETABLE(DATESBETWEEN ( 'D_Time Hierarchy'[Full Date], yy, startOfWeek2), REMOVEFILTERS('D_Time Hierarchy'))",
              "VAR result1 =",
              "    CALCULATE (",
              "        [LY Not Shipped Case Qty],",
              "        REMOVEFILTERS ( 'D_Time Hierarchy' ),",
              "        REMOVEFILTERS('D_Relative Time Slicer'),",
              "        KEEPFILTERS ( lasd1 )",
              "    )",
              "RETURN",
              "    result1"
            ],
            "formatString": "#,0",
            "displayFolder": "Sales",
            "lineageTag": "d75c603e-982d-4578-8534-006cfd27e2c5",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
