              }
            ]
          },
          {
            "name": "Dollar Ship - LY CY ",
            "description": "Dollar ship for last year CY",
            "expression": [
              "VAR seleWeek =",
              "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
              "VAR seleYear =",
              "    MIN ( 'D_Time Hierarchy'[Fiscal Year Start Date] )",
              "RETURN",
              "    CALCULATE (",
              "        [LY Dollar Ship],",
              "        FILTER (",
              "            ALL ( 'D_Time Hierarchy' ),",
              "            'D_Time Hierarchy'[Fiscal Week Start Date] >= seleYear",
              "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
              "        ),",
              "        ALL ( 'D_Relative Time Slicer' )",
              "    )"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Sales",
            "lineageTag": "a3376faa-e78c-4635-8d34-420f56520dae",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
