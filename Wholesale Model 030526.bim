        "partitions": [
          {
            "name": "D_Fiscal Week Last 12 Weeks",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Value.NativeQuery(Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"){[Name=\"EDW_DEV\"]}[Data], \"SELECT DISTINCT DT2.FISCAL_WEEK#(lf),DT2.WEEK_ENDING_DESC#(lf),DATEDIFF(DAY,TO_DATE(DT2.FISCAL_WEEK_END_DT), CURRENT_DATE()) AS FISCAL_WEEK_END_DT_TODAY_DIFF#(lf),CASE#(lf)    WHEN DATEDIFF(DAY,TO_DATE(DT2.FISCAL_WEEK_END_DT), CURRENT_DATE()) BETWEEN 0 AND 6 THEN 'Previous Week'#(lf)    ELSE DT2.WEEK_ENDING_DESC#(lf)    END AS WEEK_ENDING_DESC_PREV_WK#(lf),DT.FISCAL_WEEK_END_DT AS FISCAL_WEEK_END_DT_LAST_12_WEEKS#(lf),DT.WEEK_ENDING_DESC AS WEEK_ENDING_DESC_LAST_12_WEEKS #(lf)FROM MDM.DATE_DIM_VW DT#(lf)JOIN  MDM.DATE_DIM_VW DT2 ON DT.FISCAL_WEEK_END_DT <= DT2.FISCAL_WEEK_END_DT #(lf)AND  DT.FISCAL_WEEK_END_DT >= DATEADD(DAY, -83,TO_DATE(DT2.FISCAL_WEEK_END_DT))#(lf)ORDER BY #(lf)DT2.FISCAL_WEEK#(lf),DT2.WEEK_ENDING_DESC#(lf),DT.FISCAL_WEEK_END_DT\", null, [EnableFolding=true])",
                "in",
                "    Source"
              ]
            }
          }
        ],
        "changedProperties": [
          {
            "property": "Name"
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
