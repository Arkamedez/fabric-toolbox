            "lineageTag": "f518f4ed-7a39-4678-9579-c551efb13d6a"
          },
          {
            "name": "Dollar Ship CY Var (GR PA Gross)",
            "expression": "[Dollar Ship - CY (GR PA Gross)] - [Dollar Ship - LY CY ]",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "b7bae3b2-4d9a-4701-a7f9-128fcb262aaf"
          },
          {
            "name": "Dollar ship CY Var% (GR PA Gross)",
            "expression": "DIVIDE ( [Dollar Ship - CY (GR PA Gross)] - [Dollar Ship - LY CY ], [Dollar Ship - LY CY ] )",
            "formatString": "0.00%;-0.00%;0.00%",
