        "partitions": [
          {
            "name": "D_PO Vendor",
            "mode": "directQuery",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    FD_VENDOR_VW_View = FD_Schema{[Name=\"FD_VENDOR_VW\",Kind=\"View\"]}[Data],",
                "    #\"Filtered Rows\" = Table.SelectRows(FD_VENDOR_VW_View, each ([CURRENT_FLG] = 1)),",
                "    #\"Removed Other Columns\"= Table.SelectColumns(#\"Filtered Rows\",{\"VENDOR_HST_PK\", \"FACILITY_ID\", \"VENDOR_NBR\", \"CURRENT_FLG\", \"ASN_APPROVED_FLG\", \"BUYER_NBR\", \"VENDOR_GROUP\", \"STATUS\", \"BROKER_NUMBER\", \"TERMS_PERCENT\", \"TERMS_DAYS\", \"TERMS_NET_DAYS\", \"WAREHOUSE_CODE_X\", \"FLAG_PREPAID\", \"FLAG_PREPAY_AND_ADD\", \"FLAG_FREIGHT_BILL\", \"FLAG_BACKHAUL\", \"AFE_FAX_NUMBER\", \"AFE_FAX_NUMBER_2\", \"DUNS_REMIT_NO\", \"TRANSIT_DAYS\", \"LAG_DAYS\", \"MILITARY_VEND\", \"CREATE_DATE\", \"MASTER_VENDOR_DESC\", \"MASTER_BROKER\", \"ASN_EXEMPTION_FLG\", \"LEAD_TIME_STATED_WEEKS\", \"DEALMGMT_FLG\", \"VENDOR_NAME\", \"ADDRESS_1\", \"ADDRESS_2\", \"CITY\", \"STATE\", \"ZIP\", \"PHONE\", \"CONTACT\", \"VENDOR_TYPE\", \"MASTER_VENDOR\", \"VENDOR_NBR_NUM\", \"PAYABLE_VENDOR_NBR_NUM\", \"BILL_METHOD_DESC\", \"GROUP_DESC\", \"VENDOR_KEY\", \"VENDOR_DETAIL_DESC\", \"FACILITY_SEGMT_ID\", \"WAREHOUSE_DESC\", \"VENDOR_DETAIL_NBR\", \"MASTER_VENDOR_ID_DESC\", \"FACILITY_NBR_DESC\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Removed Other Columns\",{{\"VENDOR_HST_PK\", \"Vendor Hst Key\"},{\"CURRENT_FLG\", \"Current Flag\"}, {\"BUYER_NBR\", \"Buyer Nbr\"}, {\"VENDOR_GROUP\", \"Vendor Group\"}, {\"STATUS\", \"Status\"}, {\"MASTER_VENDOR_DESC\", \"Master Vendor\"}, {\"MASTER_BROKER\", \"Master Broker Nbr\"}, {\"VENDOR_NAME\", \"Vendor\"}, {\"VENDOR_TYPE\", \"Vendor Type\"}, {\"MASTER_VENDOR\", \"Master Vendor ID\"}, {\"VENDOR_NBR_NUM\", \"Vendor ID\"}, {\"PAYABLE_VENDOR_NBR_NUM\", \"Payable Vendor Nbr\"}, {\"GROUP_DESC\", \"Customer Group\"}, {\"VENDOR_KEY\", \"Vendor Key\"}, {\"ASN_APPROVED_FLG\", \"ASN Approved Flag\"}, {\"BROKER_NUMBER\", \"Broker Nbr\"}, {\"DUNS_REMIT_NO\", \"DUNS Remit Nbr\"}, {\"CREATE_DATE\", \"Create Date\"}, {\"ASN_EXEMPTION_FLG\", \"ASN Exemption Flag\"}, {\"DEALMGMT_FLG\", \"Deal Management Flag\"}, {\"ADDRESS_1\", \"Address 1\"}, {\"ADDRESS_2\", \"Address 2\"}, {\"CITY\", \"City\"}, {\"STATE\", \"State\"}, {\"ZIP\", \"Zip\"}, {\"PHONE\", \"Phone\"}, {\"CONTACT\", \"Contact\"}, {\"BILL_METHOD_DESC\", \"Bill Method\"}, {\"FACILITY_ID\", \"Facility ID\"}, {\"VENDOR_DETAIL_DESC\", \"Vendor Detail\"}, {\"AFE_FAX_NUMBER_2\", \"AAFES Fax Nbr 2\"}, {\"AFE_FAX_NUMBER\", \"AAFES Fax Nbr\"}, {\"VENDOR_NBR\", \"Vendor Nbr\"}, {\"WAREHOUSE_CODE_X\", \"WHSE Code X\"}, {\"WAREHOUSE_DESC\", \"WHSE\"}, {\"FACILITY_SEGMT_ID\", \"Facility Segment ID\"}, {\"MILITARY_VEND\", \"Military Vendor\"}, {\"VENDOR_DETAIL_NBR\", \"Vendor Detail Nbr\"}, {\"MASTER_VENDOR_ID_DESC\", \"Master Vendor Detail\"}, {\"FACILITY_NBR_DESC\", \"Facility Nbr Desc\"}}),",
                "    #\"Added Conditional Column\" = Table.AddColumn(#\"Renamed Columns\", \"Custom\", each if [FLAG_PREPAID] = \"Y\" then \"PP\" else if [FLAG_PREPAY_AND_ADD] = \"Y\" then \"PP+\" else if [FLAG_FREIGHT_BILL] = \"Y\" then \"FB\" else if [FLAG_BACKHAUL] = \"Y\" then \"BH\" else \"NULL\"),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Added Conditional Column\",{{\"Custom\", \"Transportation\"}, {\"TRANSIT_DAYS\", \"Transit Days\"}, {\"LAG_DAYS\", \"Lag Days\"}, {\"TERMS_PERCENT\", \"Terms Percent\"}, {\"TERMS_DAYS\", \"Terms Days\"}, {\"TERMS_NET_DAYS\", \"Terms Net Days\"}, {\"FLAG_PREPAID\", \"Flag Prepaid\"}, {\"FLAG_PREPAY_AND_ADD\", \"Flag Prepay And Add\"}, {\"FLAG_BACKHAUL\", \"Flag Backhaul\"}, {\"FLAG_FREIGHT_BILL\", \"Flag Freight Bill\"}}),",
                "    #\"Replaced Value\" = Table.ReplaceValue(#\"Renamed Columns1\",null,\"N\",Replacer.ReplaceValue,{\"ASN Exemption Flag\"}),",
