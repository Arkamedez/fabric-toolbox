            "description": "Not shipped case quantity {Specific to ship error group buyer}",
            "expression": [
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales Outs'[Not Ship Case Qty] ),",
              "    'D_Ship Error'[Ship Error Group Code] = \"1\"",
