          },
          {
            "name": "Caito % of Sales",
            "expression": [
              "",
              " -- calculates percentage of total sales for each master customer",
              " divide([Caito Sales Amount],CALCULATE(sum('F_Caito Sales'[Extended Price Amount]), all('D_Caito Customer'[Master Customer Name]), all('D_Caito Customer'[Master Customer Nbr])))"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Caito\\Sales\\Customer Ranking",
            "lineageTag": "296628ae-5d3f-424c-9a5c-680c07acc355"
          },
          {
            "name": "Caito Budget Sales Amount",
            "expression": "sum('F_Caito Day Forecast Budget'[Budget Sales Amount])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Caito\\Budget/Forecast",
            "lineageTag": "2e8c75a1-c6a2-46a4-8a64-0251f83bba11"
          },
          {
            "name": "Caito Budget Ship Case Cost",
            "expression": "DIVIDE([Caito Budget Sales Amount], [Caito Budget Ship Case Qty])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Caito\\Budget/Forecast",
            "lineageTag": "a360f3ac-f43d-42c8-b069-bdf82b8f47fd"
          },
          {
            "name": "Caito Budget Ship Case Qty",
            "expression": "sum('F_Caito Day Forecast Budget'[Budget Case Qty])",
            "formatString": "#,0",
            "displayFolder": "Caito\\Budget/Forecast",
            "lineageTag": "de2a720e-d570-4bb8-924a-b4f9ff7ebe20"
          },
          {
            "name": "Caito Case Ship Var to Budget",
            "expression": "[Caito Cases Shipped Qty] - [Caito Budget Ship Case Qty]",
