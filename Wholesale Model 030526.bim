              }
            ]
          },
          {
            "name": "Lead Time",
            "expression": "SUM(D_Vendor[LEAD_TIME_STATED_WEEKS])*7",
            "formatString": "#,##0;(#,##0)",
            "displayFolder": "Procurement",
            "lineageTag": "c9727142-c356-4a9e-b4f1-6d6a9cb181e8",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "InDate Range",
            "expression": [
              "",
              "Var RangeStart=FIRSTDATE('F_Layer History'[Layer File Date])",
              "Var RangeEnd=LASTDATE('F_Layer History'[Layer File Date])",
              "Return",
              "if(",
              "SELECTEDVALUE('F_Layer History'[Item Nbr])>=RangeStart",
              "&&",
              "SELECTEDVALUE('F_Layer History'[Layer File Date])<=RangeEnd",
              "&",
              "SELECTEDVALUE('F_Layer History'[Layer File Date])<>BLANK(),",
              "1,0)"
            ],
            "formatString": "0",
            "displayFolder": "Inventory",
            "lineageTag": "c3a86450-8820-46da-9e34-dc334901ff3e"
          },
          {
            "name": "Inv QOH",
            "expression": "SUM('F_Layer History'[Inventory Turn Cnt])+SUM('F_Layer History'[Inventory Promotion Cnt])+SUM('F_Layer History'[Inventory Forward Buy Cnt])",
            "formatString": "#,##0;(#,##0)",
            "displayFolder": "Inventory",
            "lineageTag": "07ac27b2-8a23-474b-a6b2-4ca2fb6bb7d6",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "PO's Late",
