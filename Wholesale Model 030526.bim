          },
          {
            "name": "Sales (PA Gross)",
            "expression": "sum('F_FD.Sales'[Total Sales Amt]) + sum('F_FD.Sales'[Extended Promotion Allowance Amt])",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "36e6a5bb-da96-4a7f-aa0a-fe00b6f42328",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ]
          },
          {
            "name": "Sales (GR PA Gross)",
            "expression": [
              "",
              "VAR BaseSales = SUM('F_FD.Sales'[Total Sales Amt])",
              " ",
              "VAR PA_Adjustment = ",
              "    CALCULATE(",
              "        SUM('F_FD.Sales'[Extended Promotion Allowance Amt]),",
              "        'F_FD.Sales'[facility id] = 1,",
              "        'F_FD.Sales'[transaction date] >= DATE(2026, 2, 1)",
              "    )",
              " ",
              "RETURN",
              "BaseSales + COALESCE(PA_Adjustment, BLANK())"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "99e78142-fe5c-4f08-809a-f2a99117408f"
          },
          {
            "name": "AVG Cases Sell Variance (GR PA Gross)",
            "expression": "[TY AVG Cases Sell (GR PA Gross)]-[LY AVG Case Sell]",
            "formatString": "#,0.00",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "8840aeb4-975b-4ef0-966f-f72677b73ea0"
          },
          {
            "name": "Bill Out Variance (GR PA Gross)",
            "expression": "[TY Bill Out % (GR PA Gross)]-[LY Bill Out %]",
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "bca98d43-b9a0-4309-8408-59e7624d8f37",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "Cents per lb (GR PA Gross)",
            "expression": [
              "",
              "DIVIDE([Sales (GR PA Gross)] - [Cost of Sales], [Ext Price Weight Measure])"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "0516a03e-f173-485f-8772-7a8d7e7284a3"
          },
