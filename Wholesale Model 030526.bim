          {
            "name": "LY Ext Cust Fee Amt 1",
            "description": "Extended customer fee amount for last year",
            "expression": [
              "var eq = CALCULATE (",
              "    SUM ( 'F_FD.Sales'[Extended Customer Fee Amt] ),",
              "    FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[DATE ID LY] )",
              "    ),ALL('D_Relative Time Slicer')",
              ")",
              "return",
              "IF(eq=0,BLANK(),eq)"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Sales",
            "lineageTag": "8a4bddb9-27e1-447b-84a8-66570cda10c9",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "LY Not Shipped Case Qty (Markout)",
            "description": "Not shipped case quantity for last year {Specific to ship error code markout}",
            "expression": [
              "",
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales Outs'[Not Ship Case Qty] ),",
              "    FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[DATE ID LY] )",
              "    ),",
              "    ALL ('D_Relative Time Slicer'),",
              "    FILTER ( 'D_Ship Error', 'D_Ship Error'[Ship Error Code] = \"MK\" )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Sales",
            "lineageTag": "0dabebd6-1703-4e22-a56f-1d2851b5c7af",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "LY Not Shipped Case Qty",
            "description": "Not shipped case quantity for last year{excluding ship error group code 6}",
            "expression": [
              "",
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales Outs'[Not Ship Case Qty] ),",
              "    FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[DATE ID LY] )",
              "    ),",
              "    FILTER ( 'D_Ship Error', 'D_Ship Error'[Ship Error Group Code] <> \"6\" ),",
              "    ALL ('D_Relative Time Slicer')",
              ")"
            ],
            "formatString": "#,###.##;(#,###.##)",
            "displayFolder": "Sales",
            "lineageTag": "1a7955f3-dc98-45b9-a6a5-071f54d4bbc3",
            "changedProperties": [
