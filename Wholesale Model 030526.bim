              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=\"EDW\",Kind=\"Database\"]}[Data],",
                "    RTL_Schema = EDW_Database{[Name=\"RTL\",Kind=\"Schema\"]}[Data],",
                "    STORE_HIERARCHY_DIM_VW_View = RTL_Schema{[Name=\"STORE_HIERARCHY_DIM_VW\",Kind=\"View\"]}[Data],",
                "    #\"Renamed Columns\" = Table.RenameColumns(STORE_HIERARCHY_DIM_VW_View,{{\"STORE_NBR\", \"Store Number\"}, {\"STORE_DESC\", \"Store Description\"}, {\"SUNDAY_SALES_FLG\", \"Sunday Sales Flag\"}, {\"STORE_OPEN_FLG\", \"Store Open Flag\"}, {\"STORE_TYPE\", \"Store Type\"}, {\"SALES_SITE_ID\", \"Sales Site ID\"}, {\"SALES_SITE_DESC\", \"Sales Site Description\"}, {\"SITE_SHORT_DESC\", \"Site Short Description\"}, {\"FORMAT_TYPE_ID\", \"Format Type ID\"}, {\"FORMAT_TYPE_DESC\", \"Format Type Description\"}, {\"MKTG_CHAIN_ID\", \"MKTG Chain ID\"}, {\"MKTG_CHAIN_DESC\", \"MKTG Chain Description\"}, {\"SALES_CHAIN_ID\", \"Sales Chain ID\"}, {\"SALES_CHAIN_DESC\", \"Sales Chain Description\"}, {\"ENTERPRISE_ID\", \"Enterprise ID\"}, {\"ENTERPRISE_DESC\", \"Enterprise Description\"}, {\"DISTRICT_ID\", \"District ID\"}, {\"DISTRICT_DESC\", \"District Description\"}, {\"DISTRICT_MANAGER\", \"District Manager\"}, {\"REGION_ID\", \"Region ID\"}, {\"REGION_NM\", \"Region Name\"}, {\"DIVISION_ID\", \"Division ID\"}, {\"DIVISION_NAME\", \"Division Name\"}, {\"OPEN_DT\", \"Open Date\"}, {\"CLOSE_DT\", \"Close Date\"}})",
                "in",
                "    #\"Renamed Columns\""
              ]
            }
          }
        ],
