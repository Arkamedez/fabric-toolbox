                "    #\"Filtered Rows\" = Table.SelectRows(ALLOWANCE_FACT_VW_View, each ([CURRENT_FLG] = 1)),",
                "    #\"Removed Other Columns\" = Table.SelectColumns(#\"Filtered Rows\",{\"CUSTOMER_NBR\", \"CUSTOMER_KEY\", \"FACILITY_ID\", \"ITEM_NBR\", \"ITEM_KEY\", \"ALLOWANCE_TYPE_CD\", \"ALLOWANCE_DESC\", \"ALLOWANCE_CUSTOMER_GRP_CD\", \"ALLOWANCE_START_DT\", \"ALLOWANCE_END_DT\", \"ALLOWANCE_AMT\", \"ALLOWANCE_STATUS_CD\", \"START_DT\", \"END_DT\", \"CURRENT_FLG\", \"DEAL_NBR\", \"CORPORATION_FLG\", \"UPC_UNIT_CD\", \"ACOUSTIC_CONTROL_NBR\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Removed Other Columns\",{{\"FACILITY_ID\", \"Facility ID\"}, {\"ITEM_NBR\", \"Item Nbr\"}, {\"ITEM_KEY\", \"Item Key\"}, {\"ALLOWANCE_TYPE_CD\", \"Allowance Type Code\"}, {\"ALLOWANCE_DESC\", \"Allowance\"}, {\"ALLOWANCE_CUSTOMER_GRP_CD\", \"Allowance Customer Group Code\"}, {\"ALLOWANCE_START_DT\", \"Allowance Effective Date\"}, {\"ALLOWANCE_END_DT\", \"Allowance Exp Date\"}, {\"ALLOWANCE_AMT\", \"Allowance Amt\"}, {\"ALLOWANCE_STATUS_CD\", \"Allowance Status Code\"}, {\"START_DT\", \"Start Date\"}, {\"END_DT\", \"End Date\"}, {\"CURRENT_FLG\", \"Current Flag\"}, {\"UPC_UNIT_CD\", \"UPC Unit Code\"}, {\"CUSTOMER_KEY\", \"Customer Key\"}, {\"CUSTOMER_NBR\", \"Customer Nbr\"}, {\"CORPORATION_FLG\", \"Corporation Flag\"}, {\"DEAL_NBR\", \"Deal Nbr\"}, {\"ACOUSTIC_CONTROL_NBR\", \"Acoustics Control Number\"}})",
                "in",
                "    #\"Renamed Columns\""
              ]
            }
          }
        ],
        "annotations": [
