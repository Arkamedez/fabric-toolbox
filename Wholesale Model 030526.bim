      {
        "name": "O_Ad-hoc Measures",
        "lineageTag": "70dce521-e7e8-4494-9b2a-1be2f5a23a12",
        "partitions": [
          {
            "name": "O_Ad-hoc Measures-a0c4675b-ec06-4305-b0cc-560cdbfe2ad2",
            "mode": "import",
            "queryGroup": "Others",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText(\"\", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [#\"Measure Name\" = _t, #\"Measure ID\" = _t, #\"Measure ID.1\" = _t, #\"Measure Name.1\" = _t]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"Measure ID\", Int64.Type}, {\"Measure ID.1\", Int64.Type}}),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Changed Type\",{\"Measure ID\", \"Measure ID.1\", \"Measure Name\", \"Measure Name.1\"})",
                "in",
                "    #\"Removed Columns\""
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Total Sales Amount",
            "description": "Total sales amount (date is less than today) (day level)",
            "expression": [
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales'[Total Sales Amt] ),",
              "    FILTER ( 'D_Time Hierarchy', 'D_Time Hierarchy'[Full Date] <= TODAY () )",
              ")"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "3127c1ce-6a2c-4a73-9017-b8c2b9d51668",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "LY Total Sales Amount",
            "description": "Total sales amount for last year",
            "expression": [
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales'[Total Sales Amt] ),",
              "   FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[Date ID LY] )",
              "    ),",
              "    ALL('D_Relative Time Slicer')",
              "    )",
              ""
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "2749e1bd-7232-4eef-834e-f6c5c903cca4",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ]
          },
          {
            "name": "Shipped  Qty",
            "description": "Shipped quantity",
            "expression": "CALCULATE(SUM ( 'F_FD.Sales'[Shipped Qty]))",
            "formatString": "##,###;(##,###)",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "aac29e16-9101-45ee-a3c7-69937142b754",
            "changedProperties": [
              {
                "property": "IsHidden"
              },
              {
                "property": "FormatString"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "Var LY % Total Sales Amount",
            "description": "Total sales amount % variance for last year",
            "expression": [
              "DIVIDE (",
              "    ( [Total Sales Amount] - [LY Total Sales Amount] ),",
              "    [LY Total Sales Amount],",
              "    0",
              ")"
            ],
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "34fbc5c2-1c98-4714-ad9f-1ffeb096c71d",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Var % Shipped  Qty",
            "description": "Shipped quantity % variance to last year",
            "expression": "DIVIDE ( ( [Shipped  Qty] - [LY Shipped  Qty] ), [LY Shipped  Qty] )",
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "3dd96141-52d6-4c00-847c-dde80584a5ab",
            "changedProperties": [
              {
                "property": "IsHidden"
              },
              {
                "property": "FormatString"
              }
            ]
          },
