          {
            "name": "YTD Shipped Qty (000’s) MK",
            "description": "Shipped quantity for markout - year to date",
            "expression": [
              "",
              "VAR seleWeek =",
              "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
              "VAR seleYear =",
              "    MIN ( 'D_Time Hierarchy'[Fiscal Year Start Date] )",
              "RETURN",
              "    CALCULATE (",
              "        [Shipped Case Qty - Not Ship MK < today],",
              "        FILTER (",
              "            ALL ( 'D_Time Hierarchy' ),",
              "            'D_Time Hierarchy'[Fiscal Week Start Date] >= seleYear",
              "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
              "        ),all('D_Relative Time Slicer')",
              "    ) / 1000"
            ],
            "formatString": "#,0",
            "displayFolder": "Sales",
            "lineageTag": "006ab281-d1c8-4705-a252-811ef05d67dd",
            "changedProperties": [
