          {
            "name": "Gap to Comp (GR PA Gross)",
            "expression": "([Dollar ship CY Var% (GR PA Gross)]-[Dollar ship CY Var%(Total)(GR PA Gross)]) * [Dollar Ship - CY (GR PA Gross)]",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "782aacb1-ef6d-419c-b562-c532750b04a6"
          },
          {
            "name": "Gap to Comp-MDSE Group (GR PA Gross)",
            "expression": "([Dollar ship CY Var% (GR PA Gross)]-[Dollar ship CY Var%(MDSE Total)(GR PA Gross)])*[Dollar Ship - CY (GR PA Gross)]",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "76a6f084-a5b5-4235-863d-c56364c75117"
          },
          {
            "name": "LY Sales (GR PA Gross)",
            "expression": [
              "CALCULATE (",
              "    [Sales (GR PA Gross)],",
              "   FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[Date ID LY] )",
              "    ),",
              "    ALL('D_Relative Time Slicer')",
              "    )",
              ""
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "edd984b3-bb25-446a-8391-53f69e00df6c"
          },
          {
            "name": "Pre Price Amt",
            "expression": "sum('D_Shipper Component'[Pre Price Amt])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Purchase Measures\\Inventory",
            "lineageTag": "7075f792-dc2f-4b44-860c-0eeef712745a"
          },
          {
            "name": "PTD Total Sales Amt (000’s) (GR PA Gross)",
            "expression": [
              "VAR seleWeek =",
              "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
              "VAR selePeriod =",
              "    MIN ( 'D_Time Hierarchy'[Fiscal Period Start Date] )",
              "RETURN",
              "    CALCULATE (",
              "        [Sales 000's (GR PA Gross)],",
              "        FILTER (",
              "            ALL ( 'D_Time Hierarchy' ),",
              "            'D_Time Hierarchy'[Fiscal Week Start Date] >= selePeriod",
              "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
              "        ),All('D_Relative Time Slicer')",
              "    )"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "05b249d8-dfd1-485f-9e3e-a49d6333a23d"
          },
          {
            "name": "QTD Total Sales Amt (000’s) (GR PA Gross)",
            "expression": [
              "VAR seleWeek =",
              "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
              "VAR seleQuarter =",
              "    MIN ( 'D_Time Hierarchy'[Fiscal Quarter Start Date] )",
              "RETURN",
              "    CALCULATE (",
              "        [Sales 000's (GR PA Gross)],",
              "        FILTER (",
              "            ALL ( 'D_Time Hierarchy' ),",
              "            'D_Time Hierarchy'[Fiscal Week Start Date] >= seleQuarter",
              "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
              "        ),All('D_Relative Time Slicer')",
              "    )"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "761601ed-44cf-4e91-89a4-ed6556cee5cf"
          },
          {
            "name": "Qty Short",
            "expression": "sum('F_Purchase Detail'[Original Cnt]) - sum('F_Purchase Detail'[Received Count])",
            "formatString": "#,0",
            "displayFolder": "Ad-hoc Wholesale Purchase Measures\\Purchases-Item Level",
            "lineageTag": "127b92d3-78c0-46b1-ada8-9fabb978708a"
          },
          {
            "name": "Retail Unit Amt",
            "expression": "sum('D_Shipper Component'[Retail Unit Amount])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Purchase Measures\\Inventory",
            "lineageTag": "ef1b1c9a-bff4-4e62-b8e5-a164c95686d2"
          },
          {
            "name": "Sales 000's (GR PA Gross)",
            "expression": "[Sales (GR PA Gross)] * 0.001",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "4e6def9a-b6b3-41be-9479-dbb8ab9ac72f"
          },
          {
            "name": "Sales Profit % (GR PA Gross)",
            "expression": "DIVIDE([Profit], [Sales (GR PA Gross)], 0) ",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "e4f02c87-6771-4328-87ef-6a44ecff14d9"
          },
          {
            "name": "Sales Var to Budg (GR PA Gross)",
            "expression": [
              "",
              "[Sales (GR PA Gross)] - [Budg Sales Amt]"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "628ec7d8-8680-4d80-b125-44c47021091b"
          },
          {
            "name": "Sales Var to Fcst (GR PA Gross)",
            "expression": [
              "",
              "[Sales (GR PA Gross)] - [Fcst Sales Amt.]"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "cb0a9f94-0d49-4848-a89c-90ebb0931736"
          },
          {
            "name": "Suggested Retail Price Amt",
            "expression": "sum('D_Shipper Component'[Suggest Retail Price Amt])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Purchase Measures\\Inventory",
            "lineageTag": "e7ff89dc-9256-4e65-8f4d-a405be7f20ac"
          },
          {
            "name": "Total Sales Amt (Rolling YTW)(GR PA Gross)",
            "expression": [
              "",
              "VAR startdate =",
              "    MAX ( 'D_Time Hierarchy'[Full Date] )",
              "VAR startOfWeek2 =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Week End Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR yy =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Year Start Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR lasd1 =",
              "    CALCULATETABLE(DATESBETWEEN ( 'D_Time Hierarchy'[Full Date], yy, startOfWeek2), REMOVEFILTERS('D_Time Hierarchy'))",
              "VAR result1 =",
              "    CALCULATE (",
              "        [Sales (GR PA Gross)],",
              "        REMOVEFILTERS ( 'D_Time Hierarchy' ),",
              "        REMOVEFILTERS('D_Relative Time Slicer'),",
              "        KEEPFILTERS ( lasd1 )",
              "    )",
              "RETURN",
              "    result1",
              ""
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "1c37e3b2-cfba-49b3-af05-41488af0c515"
          },
          {
            "name": "TY AVG Cases Sell (GR PA Gross)",
            "expression": "DIVIDE([Dollar Ship (GR PA Gross)],[Cases Sold])",
            "formatString": "#,0.00",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "409cb0cc-f93c-434c-9302-f24bfe2a6f3c"
          },
          {
            "name": "TY Bill Out % (GR PA Gross)",
            "expression": [
              "",
              "CALCULATE(",
              "    var A1 = [Dollar Ship (GR PA Gross)]",
              "    var A2 = SUM('F_FD.Sales'[Total Ext Layer Cost])-SUM('F_FD.Sales'[Total Ext Ad Allowance Amt])",
              "    var A3 = A1 - A2",
              "    return",
              "    DIVIDE(A3,A1))"
            ],
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "ea0c1fac-d150-4d89-8ac6-cba2dd5a80b0",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "Var LY % Total Sales Amount (GR PA Gross)",
            "expression": [
              "DIVIDE (",
              "    ( [Sales (GR PA Gross)] - [LY Total Sales Amount] ),",
              "    [LY Total Sales Amount],",
              "    0",
              ")"
            ],
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "a9ae7d0f-d3f0-4ffd-8140-adafe33577b6",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "Var LY% PTD Total Sales (GR PA Gross)",
            "expression": [
              "DIVIDE (",
              "    [PTD Total Sales Amt (000’s) (GR PA Gross)] - [LY PTD Total Sales Amt (000’s)],",
              "    [LY PTD Total Sales Amt (000’s)]",
              ")"
            ],
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "52764738-69d4-4711-9a51-17441d630231",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "Var LY% QTD Total Sales (GR PA Gross)",
            "expression": [
              "DIVIDE (",
              "    [QTD Total Sales Amt (000’s) (GR PA Gross)] - [LY QTD Total Sales (000’s)],",
              "    [LY QTD Total Sales (000’s)]",
              ")"
            ],
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "a53e759a-3fc1-4831-add5-a3f289da57dd",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "Var LY% YTD Total Sales (GR PA Gross)",
            "expression": [
              "DIVIDE (",
              "    [YTD Total Sales Amt (000’s) (GR PA Gross)] - [LY YTD Total Sales Amt (000’s)],",
              "    [LY YTD Total Sales Amt (000’s)]",
              ")"
            ],
            "formatString": "0.00%;(0.00%)",
            "displayFolder": "Ad-hoc Wholesale Sales Measures\\GR Sales",
            "lineageTag": "67cd082d-0761-4ab7-94f6-3871292a3e12",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
