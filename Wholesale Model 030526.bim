          {
            "name": "Selected Report Scope",
            "expression": "SELECTEDVALUE('CARE Report Scope'[Report Scope])",
            "displayFolder": "Report Label",
            "lineageTag": "cb6320f5-90c1-4616-87e4-7ebbfa4a06bc",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "CARE Report Scope",
            "expression": "COMBINEVALUES(\" - \",[List of Facility],[Selected Report Scope])",
            "displayFolder": "Report Label",
            "lineageTag": "14314c83-b7ea-43e0-9ed4-370fd5d022d0",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "List of Facility",
            "expression": [
              "",
              "VAR __DISTINCT_VALUES_COUNT = DISTINCTCOUNT('D_Facility Segment'[Facility])",
              "VAR __MAX_VALUES_TO_SHOW = 1",
              "RETURN",
              "\tIF(",
              "\t\t__DISTINCT_VALUES_COUNT > __MAX_VALUES_TO_SHOW,",
              "\t\tCONCATENATE(",
              "\t\t\tCONCATENATEX(",
              "\t\t\t\tTOPN(",
              "\t\t\t\t\t__MAX_VALUES_TO_SHOW,",
              "\t\t\t\t\tVALUES('D_Facility Segment'[Facility]),",
              "\t\t\t\t\t'D_Facility Segment'[Facility],",
              "\t\t\t\t\tASC",
              "\t\t\t\t),",
              "\t\t\t\t'D_Facility Segment'[Facility],",
              "\t\t\t\t\", \",",
              "\t\t\t\t'D_Facility Segment'[Facility],",
              "\t\t\t\tASC",
              "\t\t\t),",
              "\t\t\t\", etc.\"",
              "\t\t),",
              "\t\tCONCATENATEX(",
              "\t\t\tVALUES('D_Facility Segment'[Facility]),",
              "\t\t\t'D_Facility Segment'[Facility],",
              "\t\t\t\", \",",
              "\t\t\t'D_Facility Segment'[Facility],",
              "\t\t\tASC",
              "\t\t)",
              "\t)"
            ],
            "displayFolder": "Report Label",
            "lineageTag": "9fd26073-f069-46f1-a1da-98aa588fbba3",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
