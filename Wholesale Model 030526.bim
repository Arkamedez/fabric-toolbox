          {
            "name": "Top N",
            "description": "Top 'N' Sales",
            "expression": [
              "",
              "VAR SelectedTop =",
              "    SELECTEDVALUE ( 'O_TopN'[TopN] )",
              "RETURN",
              "    SWITCH (",
              "        TRUE (),",
              "        SelectedTop = 0, 'O_Report Measure'[YTD Total Sales Amt (000’s)],",
              "        RANKX (",
              "            ALLSELECTED ( D_Customer[Corporation] ),",
              "            'O_Report Measure'[YTD Total Sales Amt (000’s)],",
              "            ,",
              "            DESC,",
              "            DENSE",
              "        ) <= SelectedTop, 'O_Report Measure'[YTD Total Sales Amt (000’s)]",
              "    )"
            ],
            "formatString": "0",
            "displayFolder": "Sales",
            "lineageTag": "60d58126-5af1-4609-a1ee-00f1ad02476f",
            "changedProperties": [
              {
                "property": "IsHidden"
              },
              {
                "property": "FormatString"
              }
            ]
          },
          {
            "name": "Total Sales Amt(000's) - Last 4 Wks",
            "description": "Total Sales for last 4 weeks",
            "expression": [
              "",
              "VAR CurrentDate =",
              "    MAX ( 'D_Time Hierarchy'[Full Date] )",
              "VAR PreviousDate =",
              "    CurrentDate - 27",
              "RETURN",
              "    (",
              "        CALCULATE (",
              "            [Total Sales Amt (000’s)],",
              "            FILTER (",
              "                ALL ( 'D_Time Hierarchy' ),",
              "                'D_Time Hierarchy'[FULL DATE] >= PreviousDate",
              "                    && 'D_Time Hierarchy'[FULL DATE] <= CurrentDate",
              "            ), all('D_Relative Time Slicer')",
              "        )",
              "    )"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Sales",
            "lineageTag": "1dcd7577-69b6-4360-b6b5-bebf2d1171c9",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ]
          },
