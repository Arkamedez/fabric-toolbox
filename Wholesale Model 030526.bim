          },
          {
            "name": "Dollar ship CY Var%(MDSE Total)(GR PA Gross)",
            "expression": "Calculate(DIVIDE([Dollar Ship - CY (GR PA Gross)]-[Dollar Ship - LY CY ],[Dollar Ship - LY CY ]),ALL('D_Item'[MDSE Group]))",
            "formatString": "0.00%;-0.00%;0.00%",
