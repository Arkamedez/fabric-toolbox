          {
            "name": "Cases Shipped Qty(000's)",
            "description": "Cases shipped quantity (sales in thousands)",
            "expression": "SUM ( 'F_FD.Sales'[Shipped Qty] ) * 0.001",
            "formatString": "#,0",
