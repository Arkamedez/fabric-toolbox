          },
          {
            "name": "Adjust Item Qty",
            "expression": "CALCULATE(sum('F_PO Payment Detail'[Adjust Item Qty]), USERELATIONSHIP('F_PO Payment Detail'[ITEM_KEY], D_Item[Item Key]))",
            "formatString": "#,0",
