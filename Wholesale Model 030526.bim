          {
            "name": "Not Shipped Qty (Shipped Error Group Code 6)",
            "expression": [
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales Outs'[Not Ship Case Qty] ),",
              "    FILTER ( 'D_Time Hierarchy', 'D_Time Hierarchy'[Full Date] <= TODAY () ),",
              "    FILTER (",
              "        'D_Ship Error',",
              "        'D_Ship Error'[Ship Error Group Code]  = \"6\")",
              ")"
            ],
            "formatString": "##,###;(##,###)",
            "displayFolder": "Sales",
            "lineageTag": "11bbe18d-0bc6-406a-ad71-34d398b04a3b",
