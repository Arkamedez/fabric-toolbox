          },
          {
            "name": "Sales by Representative",
            "expression": [
              "",
              "",
              "VAR mult_dept_rep_types = {5, 6, 7, 11, 12, 15} ",
              "",
              "VAR rep_name =",
              "SELECTEDVALUE('D_Retail Representative Customer'[Retail Representative])",
              " ",
              "VAR cur_type = SELECTEDVALUE('D_Retail Representative Customer'[Retail Representative Type Nbr])",
              "",
              "VAR cur_dept = SELECTEDVALUE('D_Retail Representative Customer'[MDSE Dept Code])",
              "",
              "RETURN",
              "IF(rep_name = BLANK(), [Total Sales Amount], ",
              "IF(cur_type = 1, CALCULATE(sum('F_FD.Sales'[Total Sales Amt]), CROSSFILTER('D_Retail Representative Customer'[MDSE Dept Code], 'O_MDSE Dept Bridge'[New Key], OneWay)),",
              "IF(cur_type in mult_dept_rep_types, [Total Sales Amount],",
              "IF(cur_dept <> BLANK(), [Total Sales Amount]))))"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "696a7cac-1a62-49af-a73f-d8c79b4d0851"
          },
          {
            "name": "Sales with Representatives",
            "expression": [
              "",
              "VAR valid_types = {1,5,6,7,11,12,13,15}",
              "",
              "VAR cur_type = SELECTEDVALUE('D_Retail Representative Customer'[Retail Representative Type Nbr])",
              "",
              "VAR custs = CALCULATETABLE(DISTINCT('D_Retail Representative Customer'[Customer Nbr]))",
              "",
              "RETURN",
              "IF(cur_type in valid_types, CALCULATE([Total Sales Amount], D_Customer[Customer Nbr] in custs, CROSSFILTER('D_Retail Representative Customer'[MDSE Dept Code], 'O_MDSE Dept Bridge'[New Key], None)))"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Sales Measures",
            "lineageTag": "55b62be5-8dc3-40cd-bc5a-acad106b7285"
          },
