          },
          {
            "name": "Count ASN PO'S",
            "expression": "Count('F_ASN PO Header'[PO_NBR])",
            "formatString": "0",
            "displayFolder": "Procurement\\ASN",
            "lineageTag": "a80a5127-41f5-41b1-9522-a44f9e570e98"
          },
          {
            "name": "MAX_INVENTORY",
            "expression": [
              "",
              "sum('D_Item'[SAFETY_STOCK])+SUM('D_Item'[CYCLE_STOCK])+",
              "SUMX('D_Item', CEILING(IF('D_Item'[ORDER_INTERVAL_WEEKS]=0,1,'D_Item'[ORDER_INTERVAL_WEEKS])*",
              "IF(ISBLANK('D_Item'[Cases per week]),0,'D_Item'[Cases per week])/7,1))+SUM('D_Item'[Cases per week])",
              "+sum('D_Item'[IN_PROCESS_REG_AMT])+sum('D_Item'[IN_PROCESS_PROMO])+sum('D_Item'[Reserve Committed])+",
              "sum('D_Item'[Reserve Uncommitted])+sum('D_Item'[Storage Committed])+sum('D_Item'[Storage Uncommitted])+sum('F_Purchase Detail'[Purchase Qty])+sum('D_Item'[ORDER_POINT])+SUMX('D_Item',CEILING(IF(ISBLANK('D_Item'[Cases per week]),0,'D_Item'[Cases per week])*0.5,1)*'D_Item'[List Cost])",
              ""
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Inventory",
            "lineageTag": "da1c9d9f-b85f-4884-ae03-8638c0a573b0",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ]
          },
          {
            "name": "EXCESS_INVENTORY_CASES_CHK",
            "expression": [
              "",
              "MAXX(",
              "    'D_Item',",
              "    (",
              "        (SUM('D_Item'[Inventory Total]) + SUM('D_Item'[On Order Total])) -",
              "        (SUM('D_Item'[ORDER_POINT]) + SUM('D_Item'[IN_PROCESS_REG_AMT])) +",
              "        SUM('F_Purchase Detail'[Purchase Qty]) +",
              "        SUM('D_Item'[Reserve Committed]) +",
              "        SUM('D_Item'[Reserve Uncommitted]) +",
              "        SUM('D_Item'[Storage Committed]) +",
              "        SUM('D_Item'[Storage Uncommitted]) +",
              "        CEILING(",
              "            IF('D_Item'[ORDER_INTERVAL_WEEKS] = 0, 1, 'D_Item'[ORDER_INTERVAL_WEEKS]) * 7 *",
              "            IF(ISBLANK('D_Item'[Cases per week]), 0, 'D_Item'[Cases per week] / 7),",
              "            1",
              "        ) +",
              "        SUM('D_Item'[Inventory Promotion]) +",
              "        SUM('D_Item'[Inventory Forward Buy]) +",
              "        SUM('D_Item'[On Order Forward Buy]) +",
              "        SUM('D_Item'[Inventory Promotion]) -",
              "        CEILING(SUM('D_Item'[Cases per week]) * 0.5, 1)",
              "    )",
              ")",
              ""
            ],
            "formatString": "#,0",
            "displayFolder": "Inventory",
            "lineageTag": "30b163a5-7323-4a92-99d1-cfd73026fb9f",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ]
          },
          {
            "name": "EXCESS_CHECK",
            "expression": [
              "",
              "SUMX(",
              "    'D_Item',",
              "    IF(",
              "        'D_Item'[IN_OUT_FLAG] = \"Y\",",
              "        \"N\",",
              "        IF(",
              "            (",
              "                (",
              "                    (",
              "                        (",
              "                            (",
              "                                'D_Item'[Inventory Total] + 'D_Item'[On Order Total]",
              "                            ) - ('D_Item'[ORDER_POINT] + 'D_Item'[IN_PROCESS_REG_AMT] + 'D_Item'[IN_PROCESS_PROMO] +",
              "                            'D_Item'[Reserve Committed] + 'D_Item'[Reserve Uncommitted] + 'D_Item'[Storage Committed] + 'D_Item'[Storage Uncommitted] +",
              "                            (",
              "                                CEILING(",
              "                                    IF('D_Item'[ORDER_INTERVAL_WEEKS] = 0, 1, 'D_Item'[ORDER_INTERVAL_WEEKS]) *",
              "                                    7 * (IF(ISBLANK('D_Item'[Cases per week]), 0, 'D_Item'[Cases per week] / 7))",
              "                                    , 1",
              "                                )",
              "                            )",
              "                            ) +",
              "                            'D_Item'[Inventory Promotion] + 'D_Item'[Inventory Forward Buy] + 'D_Item'[On Order Forward Buy] + 'D_Item'[Inventory Promotion]",
              "                        ) - CEILING('D_Item'[Cases per week] * 0.5, 1)",
              "                    ) -'D_Item'[MAX_INVENTORY_CASES]",
              "                )",
              "            ) > 0,",
              "            1,",
              "            0",
              "        )",
              "    )",
              ")",
              ""
            ],
            "formatString": "0",
            "displayFolder": "Inventory",
            "lineageTag": "87796680-39b3-482d-ac97-df8f69fcbebb",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ]
          },
          {
            "name": "EXCESS_INVENTORY_CHK",
            "expression": [
              "",
              "MAXX(",
              "    'D_Item',",
              "    (",
              "        (SUM('D_Item'[Inventory Total]) + SUM('D_Item'[On Order Total])) -",
              "        (SUM('D_Item'[ORDER_POINT]) + SUM('D_Item'[IN_PROCESS_REG_AMT])) +",
              "        SUM('F_Purchase Detail'[Purchase Qty]) +",
              "        SUM('D_Item'[Reserve Committed]) +",
              "        SUM('D_Item'[Reserve Uncommitted]) +",
              "        SUM('D_Item'[Storage Committed]) +",
              "        SUM('D_Item'[Storage Uncommitted]) +",
              "        CEILING(",
              "            IF('D_Item'[ORDER_INTERVAL_WEEKS] = 0, 1, 'D_Item'[ORDER_INTERVAL_WEEKS]) * 7 *",
              "            IF(ISBLANK('D_Item'[Cases per week]), 0, 'D_Item'[Cases per week] / 7),",
              "            1",
              "        ) +",
              "        SUM('D_Item'[Inventory Promotion]) +",
              "        SUM('D_Item'[Inventory Forward Buy]) +",
              "        SUM('D_Item'[On Order Forward Buy]) +",
              "        SUM('D_Item'[Inventory Promotion]) -",
              "        CEILING(SUM('D_Item'[Cases per week]) * 0.5, 1)",
              "        * 'D_Item'[List Cost])",
              "    )"
            ],
            "formatString": "#,0.00",
            "displayFolder": "Inventory",
            "lineageTag": "8468d726-10f5-4d5b-a2fd-b62b3a7eed8e",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ]
          },
          {
            "name": "COTC LY",
            "expression": [
              "",
              "\tVAR LYOROTQ = CALCULATE(SUM('F_PO Compliance'[Po Ontime Received Qty]),DATEADD('D_Time Hierarchy'[Full Date],-1,YEAR))",
              "\tVAR LYPOORQ = CALCULATE(SUM('F_PO Compliance'[Po Original Order Qty]),DATEADD('D_Time Hierarchy'[Full Date],-1,YEAR))",
              "\tVAR EQ =",
              "\tIF(",
              "\t   DIVIDE(LYOROTQ,LYPOORQ,0)>1.0,1.0,",
              "\t   DIVIDE(LYOROTQ,LYPOORQ,0)",
              "\t)",
              "VAR CODE = SELECTEDVALUE('F_PO Compliance'[Final COTC Code])",
              "",
              "VAR LYORQ = CALCULATE(SUM('F_PO Compliance'[Po Order Received Qty]),DATEADD('D_Time Hierarchy'[Full Date], -1,YEAR))",
              "VAR FILL_RATE = ",
              "IF(",
              "    DIVIDE(LYORQ,LYPOORQ,0)>1.0,1.0,",
              "    DIVIDE(LYORQ,LYPOORQ,0)",
              ")",
              "",
              "RETURN",
              "    SWITCH (TRUE(),",
              "    CODE = \"Late\",0,",
              "    CODE = \"OnTime\", FILL_RATE,",
              "    EQ)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement\\COTC",
            "lineageTag": "5ad571cd-75b7-43e6-bf84-195de9b079a7",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ]
          },
          {
            "name": "Fill Rate LY",
            "expression": [
              "",
              "\tVAR LYORQ = CALCULATE(SUM('F_PO Compliance'[Po Order Received Qty]),DATEADD('D_Time Hierarchy'[Full Date],-1,YEAR))",
              "\tVAR LYPOORQ = CALCULATE(SUM('F_PO Compliance'[Po Original Order Qty]),DATEADD('D_Time Hierarchy'[Full Date],-1,YEAR))",
              "\tRETURN",
              "\tIF(",
              "\t   DIVIDE(LYORQ,LYPOORQ,0)>1.0,1.0,",
              "\t   DIVIDE(LYORQ,LYPOORQ,0)",
              "\t)",
              ""
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement",
            "lineageTag": "1aa46d3a-56c7-4b6f-9b20-01dde9407dc7",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ]
          },
          {
            "name": "Rank of Master Vendor",
            "expression": [
              "",
              "",
              "VAR PO_Orders_Short = SUM('F_PO Compliance'[Po Order Qty])-SUM('F_PO Compliance'[Po Order Received Qty])",
              "",
              "RETURN",
              "",
              " RANKX(",
              "",
              "    D_Item,",
              "",
              "    CALCULATE(",
              "",
              "        PO_Orders_Short",
              "",
              "    ),,DESC,Dense",
              "",
              ")",
              ""
            ],
            "formatString": "0",
            "displayFolder": "Procurement",
            "lineageTag": "1d8a6874-272d-4af7-985a-dd22a2817cbb"
          },
          {
            "name": "Rank of Late Prepaid",
            "expression": [
              "",
              "",
              "VAR Orders_Received_Late_Quantity = SUM('F_PO Compliance'[Po Order Received Qty])-SUM('F_PO Compliance'[Po Ontime Received Qty])",
              "",
              "RETURN",
              "",
              "RANKX(",
              "",
              "    D_Item,",
              "",
              "    CALCULATE(",
              "",
              "        Orders_Received_Late_Quantity",
              "",
              "    ),,DESC,Dense",
              "",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Procurement",
            "lineageTag": "202e8fb2-36d9-4e26-b8e4-acbdcfd4ddc8"
          },
          {
            "name": "Rank of Late Managed",
            "expression": [
              "",
              "",
              "VAR Orders_Received_Late_Quantity = SUM('F_PO Compliance'[Po Order Received Qty])-SUM('F_PO Compliance'[Po Ontime Received Qty])",
              "",
              "RETURN",
              "",
              "RANKX(",
              "",
              "    D_Item,",
              "",
              "    CALCULATE(",
              "",
              "        Orders_Received_Late_Quantity",
              "",
              "    ),,DESC,Dense",
              "",
              ")"
            ],
            "formatString": "0",
            "displayFolder": "Procurement",
            "lineageTag": "fa96aac1-0963-40a3-b267-d0ee6a6f5f1c"
          },
          {
            "name": "COTC TY",
            "expression": [
              "",
              "//VAR CurrentYear = YEAR(TODAY()) // Get the current year",
              "VAR TYOROTQ = CALCULATE(SUM('F_PO Compliance'[Po Ontime Received Qty]))",
              "VAR TYPOORQ = CALCULATE(SUM('F_PO Compliance'[Po Original Order Qty]))",
              "VAR EQ =",
              "IF(",
              "    DIVIDE(TYOROTQ, TYPOORQ, 0) > 1.0,",
              "    1.0,",
              "    DIVIDE(TYOROTQ, TYPOORQ, 0)",
              ")",
              "VAR CODE = SELECTEDVALUE('F_PO Compliance'[Final COTC Code])",
              "",
              "VAR TYORQ = CALCULATE(SUM('F_PO Compliance'[Po Order Received Qty]))",
              "VAR FILL_RATE =",
              "IF(",
              "    DIVIDE(TYORQ,TYPOORQ,0)>1.0,1.0,",
              "    DIVIDE(TYORQ,TYPOORQ,0)",
              ")",
              "",
              "RETURN",
              "    SWITCH (TRUE(),",
              "    CODE = \"Late\",0,",
              "    CODE = \"OnTime\", FILL_RATE,",
              "    EQ)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement\\COTC",
            "lineageTag": "c5c0ab36-6bb4-44e3-a493-86f1ab693d8c",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ]
          },
          {
            "name": "Fill Rate TY",
            "expression": [
              "",
              "//VAR CurrentYear = YEAR(TODAY()) // Get the current year",
              "VAR TYORQ = CALCULATE(SUM('F_PO Compliance'[Po Order Received Qty]))",
              "VAR TYPOORQ = CALCULATE(SUM('F_PO Compliance'[Po Original Order Qty]))",
              "RETURN",
              "IF(",
              "    DIVIDE(TYORQ, TYPOORQ, 0) > 1.0,",
              "    1.0,",
              "    DIVIDE(TYORQ, TYPOORQ, 0)",
              ")"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement",
            "lineageTag": "7b5bcf29-ea74-4929-9d8f-75507aa2a542",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ]
          },
