                "    #\"Renamed Columns\" = Table.RenameColumns(SALES_PLAN_SELL_HST_VW_View,{{\"FACILITY_ID\", \"Facility Id\"}, {\"CUSTOMER_NBR\", \"Customer Nbr\"}, {\"VENDOR_NBR\", \"Vendor Nbr\"}, {\"ITEM_NBR\", \"Item Nbr\"}, {\"UNBURDENED_COST_CASE_AMT\", \"Unburdened Cost Case Amt\"}, {\"BURDENED_COST_UNIT_AMT\", \"Burdened Cost Unit Amt\"}, {\"UNBURDENED_COST_UNIT_AMT_UR\", \"Unburdened Cost Unit Amt UR\"}, {\"UNBURDENED_COST_CASE_AMT_UR\", \"Unburdened Cost Case Amt UR\"}, {\"BURDENED_COST_CASE_AMT_UR\", \"Burdened Cost Case Amt UR\"}, {\"UNBURDENED_COST_UNIT_NET_AMT\", \"Unburdened Cost Unit Net Amt\"}, {\"UNBURDENED_COST_CASE_NET_AMT\", \"Unburdened Cost Case Net Amt\"}, {\"BURDENED_COST_CASE_NET_AMT\", \"Burdened Cost Case Net Amt\"}, {\"UNBURDENED_COST_CASE_AMT_NET_UR\", \"Unburdened Cost Case Amt Net UR\"}, {\"BURDENED_COST_CASE_AMT_NET_UR\", \"Burdened Cost Case Amt Net UR\"}, {\"OI_ALLOWANCE_START_DT\", \"OI Allowance Start Date\"}, {\"OI_ALLOWANCE_END_DT\", \"OI Allowance End Date\"}, {\"OI_ALLOWANCE_AMT\", \"OI Allowance Amt\"}, {\"PA_ALLOWANCE_START_DT\", \"PA Allowance Start Date\"}, {\"PA_ALLOWANCE_END_DT\", \"PA Allowance End Date\"}, {\"PA_ALLOWANCE_AMT\", \"PA Allowance Amt\"},  {\"ITEM_KEY\", \"Item Key\"}, {\"CUSTOMER_KEY\", \"Customer Key\"}, {\"VENDOR_KEY\", \"Vendor Key\"}, {\"CUST_MERCH_KEY\", \"Customer Merch Key\"}, {\"CUST_PRIVATE_KEY\", \"Customer Private Key\"}, {\"ITEM_CUST_KEY\", \"Item Cust Key\"}, {\"CORP_AUTH_FLG\", \"Corp Auth Flag\"}, {\"UPC_UNIT_CD\", \"UPC Unit Code\"}, {\"SALES_PLAN_CNT\", \"Sales Plan\"}, {\"SALES_PLAN_SELL_AMT\", \"Sales Plan Sell Amt\"}, {\"BURDENED_COST_CASE_AMT\", \"Burdened Cost Case Amt\"}, {\"UNBURDENED_COST_UNIT_AMT\", \"Unburdened Cost Unit Amt\"}, {\"BURDENED_COST_UNIT_AMT_UR\", \"Burdened Cost Unit Amt UR\"}, {\"BURDENED_COST_UNIT_AMT_NET_UR\", \"Burdened Cost Unit Amt Net UR\"}, {\"UNBURDENED_COST_UNIT_AMT_NET_UR\", \"Unburdened Cost Unit Amt Net UR\"}, {\"BURDENED_COST_FLG\", \"Burdened Cost Flag\"}, {\"BURDENED_COST_UNIT_NET_AMT\", \"Burdened Cost Unit Net Amt\"}, {\"SALES_PLAN_CD\", \"Sales Plan Code\"}}),",
                "    #\"Removed Other Columns\" = Table.SelectColumns(#\"Renamed Columns\",{\"Facility Id\", \"Item Nbr\", \"Sales Plan Code\", \"SELL_PRICE_START_DT\", \"Sales Plan Sell Amt\", \"Item Key\", \"Customer Nbr\", \"Vendor Nbr\", \"UPC Unit Code\", \"Sales Plan\", \"Unburdened Cost Case Amt\", \"Burdened Cost Unit Amt\", \"Burdened Cost Case Amt\", \"Unburdened Cost Unit Amt UR\", \"Unburdened Cost Case Amt UR\", \"Burdened Cost Case Amt UR\", \"Unburdened Cost Unit Net Amt\", \"Unburdened Cost Case Net Amt\", \"Burdened Cost Case Net Amt\", \"Unburdened Cost Case Amt Net UR\", \"Burdened Cost Case Amt Net UR\", \"Unburdened Cost Unit Amt\", \"Burdened Cost Unit Amt UR\", \"Burdened Cost Unit Amt Net UR\", \"Unburdened Cost Unit Amt Net UR\", \"Burdened Cost Unit Net Amt\", \"Burdened Cost Flag\", \"OI Allowance Start Date\", \"OI Allowance End Date\", \"OI Allowance Amt\", \"PA Allowance Start Date\", \"PA Allowance End Date\", \"PA Allowance Amt\", \"Customer Key\", \"Vendor Key\", \"Customer Merch Key\", \"Customer Private Key\", \"Item Cust Key\", \"Corp Auth Flag\"})",
                "in",
