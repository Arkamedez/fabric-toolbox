          {
            "name": "PO Ordered Quantity",
            "expression": "SUM('F_PO Compliance'[Po Original Order Qty])",
            "formatString": "#,##0;(#,##0)",
            "displayFolder": "Procurement",
            "lineageTag": "c90c8faf-e73d-4c7e-8d38-0c433d717a8a",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isCustom\":true}"
              }
            ]
          },
          {
            "name": "COTC",
            "expression": [
              "",
              "VAR OROTQ = SUM('F_PO Compliance'[Po Ontime Received Qty])",
              "VAR POORQ = SUM('F_PO Compliance'[Po Original Order Qty])",
              "VAR EQ =",
              "IF(",
              "    DIVIDE(OROTQ,POORQ,0)>1.0,1.0,",
              "    DIVIDE(OROTQ,POORQ,0)",
              ")",
              "VAR CODE = SELECTEDVALUE('F_PO Compliance'[Final COTC Code])",
              "",
              "VAR ORQ = SUM('F_PO Compliance'[Po Order Received Qty])",
              "VAR FILL_RATE = ",
              "IF(",
              "    DIVIDE(ORQ,POORQ,0)>1.0,1.0,",
              "    DIVIDE(ORQ,POORQ,0)",
              ")",
              "RETURN",
              "    SWITCH (TRUE(),",
              "    CODE = \"Late\",0,",
              "    CODE = \"OnTime\", FILL_RATE,",
              "    EQ)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement\\COTC",
            "lineageTag": "20168da3-d213-41c4-818a-96bb93e1e4fd"
          },
          {
            "name": "% On Time Arrival",
            "expression": "DIVIDE([Order Recieved On Time Quantity],[Order Recieved Quantity])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement",
            "lineageTag": "a22bcfc5-9acc-4fbd-b02c-e94c5f7ad722"
          },
          {
            "name": "Fill Rate",
            "expression": [
              "",
              "VAR ORQ = SUM('F_PO Compliance'[Po Order Received Qty])",
              "VAR POORQ = SUM('F_PO Compliance'[Po Original Order Qty])",
              "RETURN",
              "IF(",
              "    DIVIDE(ORQ,POORQ,0)>1.0,1.0,",
              "    DIVIDE(ORQ,POORQ,0)",
              ")",
              ""
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement",
            "lineageTag": "6aeb6957-0994-4e25-a4a6-70f911066d94"
          },
