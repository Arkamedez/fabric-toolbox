              }
            ]
          },
          {
            "name": "At Risk $$$",
            "expression": "[At Risk Cases]*SUM(D_ITEM[List Cost])",
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "displayFolder": "Inventory",
            "lineageTag": "bc5836de-527c-4357-a0a3-9f80c5c1c88a"
          },
          {
            "name": "At Risk Cases",
            "expression": "IF([Calendar Pull Days Left]<0, [Qty On Hand],IF([Calendar Pull Days Left]>0,([Qty On Hand]-[Calendar Pull Days Left]),\"Null\"))",
            "formatString": "#,0",
            "displayFolder": "Inventory",
            "lineageTag": "35ad9646-3c35-43e0-83f9-1dd48bed1269"
          },
          {
            "name": "Calendar Pull Days Left",
            "expression": "DATEDIFF([PullDate], TODAY(), DAY)",
            "formatString": "0",
            "displayFolder": "Inventory",
            "lineageTag": "4456dce7-be22-4377-a0d5-bce72804d811"
          },
          {
            "name": "Margin Loss",
            "expression": "DIVIDE(SUM('D_Item'[Base Sell])-TRUNC(SUM('D_Item'[List Cost])),SUM('D_Item'[Base Sell]))",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Sales",
            "lineageTag": "c4d63787-038c-45e7-8c97-ff0656c0b33d"
          },
          {
            "name": "Catalog Price",
            "expression": "SUM('D_Item'[Catalog Price])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Inventory",
            "lineageTag": "1f8460db-37e0-4ad0-bdfd-ad398bfa4b83",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ]
          },
          {
            "name": "Sales Plan Sell",
            "expression": "SUM('F_Sales Plan Sell History'[Sales Plan Sell Amt])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Procurement",
            "lineageTag": "bfd3dacf-d4eb-4ff4-b3bc-a9b8ee63756f"
          },
          {
            "name": "Future Sell",
            "expression": [
              "IF(CONTAINS(D_Item,",
              "D_Item[Facility ID],1,",
              "D_Item[Facility ID],2,",
              "D_Item[Facility ID],3,",
              "D_Item[Facility ID],5,",
              "D_Item[Facility ID],8,",
              "D_Item[Facility ID],9,",
              "D_Item[Facility ID],40,",
              "D_Item[Facility ID],54),",
              "'O_Report Measure'[Catalog Price],",
              "'O_Report Measure'[Sales Plan Sell])"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Procurement",
            "lineageTag": "960b1a36-742c-4504-bbfb-9c2458a3569d"
          },
          {
            "name": "Qty On Hand 1",
            "expression": "SUM(D_Item[Inventory Total])",
            "formatString": "#,##0;(#,##0)",
            "displayFolder": "Inventory",
            "lineageTag": "4a8f9856-6cfe-4792-a44b-d942f8b1437f",
            "annotations": [
