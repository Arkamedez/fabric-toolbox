          {
            "type": "calculated",
            "name": "Total Promo Amount HST",
            "dataType": "double",
            "isDataTypeInferred": true,
            "isHidden": true,
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    'F_FD.Sales'[Facility ID] = 1 && 'F_FD.Sales'[Random Weight Flag] = \"R\", 'F_FD.Sales'[Extended Promotion Allowance Amt],",
              "    'F_FD.Sales'[Facility ID] = 1 && 'F_FD.Sales'[Random Weight Flag] <> \"R\", 'F_FD.Sales'[Extended Promotion Allowance Amt],",
              "    'F_FD.Sales'[Facility ID] <> 1 && 'F_FD.Sales'[Random Weight Flag] = \"R\", 'F_FD.Sales'[Extended Promotion Allowance Amt]* 'F_FD.Sales'[Random Weight],",
              "    'F_FD.Sales'[Facility ID] <> 1 && 'F_FD.Sales'[Random Weight Flag] <> \"R\", 'F_FD.Sales'[Extended Promotion Allowance Amt]",
              ")"
            ],
            "lineageTag": "ae9aad74-063f-43ab-b2f4-9bd9127f691d",
            "summarizeBy": "sum",
            "changedProperties": [
              {
