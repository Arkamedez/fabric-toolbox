        "partitions": [
          {
            "name": "F_Order Detail-8f9082a3-63a6-43b5-9c46-c22aebf4ab7f",
            "mode": "directQuery",
            "queryGroup": "Fact Queries",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    ORDER_DTL_VW_View = FD_Schema{[Name=\"ORDER_DTL_VW\",Kind=\"View\"]}[Data],",
                "    #\"Renamed Columns\" = Table.RenameColumns(ORDER_DTL_VW_View,{{\"BILLING_DT\", \"Billing Date\"}, {\"BOOKING_NBR\", \"Booking Nbr\"}, {\"CUSTOMER_NBR\", \"Customer Nbr\"}, {\"FACILITY_ID\", \"Facility ID\"}, {\"ITEM_NBR\", \"Item Nbr\"}, {\"ITEM_HST_ID\", \"Item History ID\"}, {\"NET_QTY\", \"Net Qty\"}, {\"ORDER_ID\", \"Order ID\"}, {\"ORDER_QTY\", \"Order Qty\"}, {\"ORDER_RECVD_DT\", \"Order Received Date\"}, {\"ORDER_STATUS\", \"Order Status\"}, {\"ORDER_STATUS_CD\", \"Order Status Code\"}, {\"ORDER_TYPE_CD\", \"Order Type Code\"}, {\"RESERVE_DT\", \"Reserve Date\"}, {\"SHIP_DT\", \"Ship Date\"}, {\"ITEM_KEY\", \"Item Key\"}, {\"CUSTOMER_KEY\", \"Customer Key\"}, {\"ORIGIN\", \"Origin\"}}),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Renamed Columns\",{{\"Ship Date\", type date}}),",
                "    #\"Removed Other Columns\" = Table.SelectColumns(#\"Changed Type\",{\"Billing Date\", \"Booking Nbr\", \"Customer Nbr\", \"Facility ID\", \"Item Nbr\", \"Item History ID\", \"Net Qty\", \"Order ID\", \"Order Qty\", \"Order Received Date\", \"Order Status\", \"Order Status Code\", \"Order Type Code\", \"Reserve Date\", \"Ship Date\", \"Item Key\", \"Customer Key\", \"ORDER_NBR\", \"BIG_DEAL_FLG\", \"SEQ_NBR\", \"INVOICE_NBR\", \"TRIP_NBR\", \"STOP_NBR\", \"SUBMIT_TMSP\", \"CONFIRMATION_NBR\", \"RTL_ORDER_ID\", \"DC_ORDER_ID\", \"LINE_ITEM_ID\", \"UPLOAD_TO_BILL_CD\", \"DC_AREA_CD\", \"OMS_SERVER_TYPE\", \"ORIGIN_APP_NM\", \"RO_ORIGIN_CD\", \"SUPPLIER_PRICE_AMT\", \"SUPPLIER_PRICE_SRC_NM\", \"OVERRIDE_PRICE_REASON_CD\", \"RTL_PO_CD\", \"ORDER_RECVD_TMSP\", \"LAST_CHG_TMSP\", \"DELIVERY_ID\", \"DELIV_REQUESTED_DT\", \"ITEM_REQ_NBR\", \"ITEM_REQ_HS_NBR\", \"FACILITY_REQ_ID\", \"RETAIL_PRICE_AMT\", \"RFB_NBR\", \"INVENTORY_FLG\", \"OMS_RFB_COMMENTS_TXT\", \"Origin\", \"CREATE_TMSP\", \"UPDATE_TMSP\"}),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Removed Other Columns\",{{\"BIG_DEAL_FLG\", \"Big Deal Flg\"}, {\"CONFIRMATION_NBR\", \"Confirmation Nbr\"}, {\"CREATE_TMSP\", \"Create Tmsp\"}, {\"DC_AREA_CD\", \"Dc Area CD\"}, {\"DC_ORDER_ID\", \"Dc Order ID\"}, {\"DELIV_REQUESTED_DT\", \"Deliv Requested Dt\"}, {\"DELIVERY_ID\", \"Delivery ID\"}, {\"FACILITY_REQ_ID\", \"Facility Req ID\"}, {\"INVENTORY_FLG\", \"Inventory Flg\"}, {\"INVOICE_NBR\", \"Invoice Nbr\"}, {\"ITEM_REQ_HS_NBR\", \"Item Req Hs Nbr\"}, {\"ITEM_REQ_NBR\", \"Item Req Nbr\"}, {\"LAST_CHG_TMSP\", \"Last Chg Tmsp\"}, {\"LINE_ITEM_ID\", \"Line Item ID\"}, {\"OMS_RFB_COMMENTS_TXT\", \"OMS Reb Comments\"}, {\"OMS_SERVER_TYPE\", \"OMS Serve Type\"}, {\"ORDER_NBR\", \"Order Nbr\"}, {\"ORDER_RECVD_TMSP\", \"Order Recvd Tmsp\"}, {\"ORIGIN_APP_NM\", \"Origin App Nm\"}, {\"OVERRIDE_PRICE_REASON_CD\", \"Override Price Reason CD\"}, {\"RETAIL_PRICE_AMT\", \"Retail Price Amt\"}, {\"RFB_NBR\", \"Rfb Nbr\"}, {\"RO_ORIGIN_CD\", \"Ro Origin CD\"}, {\"RTL_ORDER_ID\", \"Rtl Order ID\"}, {\"RTL_PO_CD\", \"Rtl Po CD\"}, {\"SEQ_NBR\", \"Seq Nbr\"}, {\"STOP_NBR\", \"Stop Nbr\"}, {\"SUBMIT_TMSP\", \"Submit Tmsp\"}, {\"SUPPLIER_PRICE_AMT\", \"Supplier Price Amt\"}, {\"SUPPLIER_PRICE_SRC_NM\", \"Supplier Price Src Nm\"}, {\"TRIP_NBR\", \"Trip Nbr\"}, {\"UPDATE_TMSP\", \"Update Tmsp\"}, {\"UPLOAD_TO_BILL_CD\", \"Upload To Bill CD\"}})",
                "in",
                "    #\"Renamed Columns1\""
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Selected Filters-OMS",
            "expression": [
              "",
              "",
              "VAR OMS = \"",
              "\"",
              "",
              "VAR FiscalYear = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Year]),",
              "                 \"Fiscal Year= \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Year]), 'D_Time Hierarchy'[Fiscal Year], \", \") & OMS, \"\")",
              "",
              "VAR FiscalQuaterdetail = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Quarter Detail]),",
              "                 \"Fiscal Quarter Detail= \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Quarter Detail]), 'D_Time Hierarchy'[Fiscal Quarter Detail], \", \") & OMS, \"\")",
              "",
              "",
              "VAR FiscalPeriodwithEndDate = IF(ISFILTERED('D_Time Hierarchy'[Fiscal Period with End Date]),",
              "                 \"Fiscal Period with End Date= \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Fiscal Period with End Date]), 'D_Time Hierarchy'[Fiscal Period with End Date], \", \") & OMS, \"\")",
              "",
              "VAR Weekending = IF(ISFILTERED('D_Time Hierarchy'[Week Ending]),",
              "                 \"Week Ending= \" & CONCATENATEX(ALLSELECTED('D_Time Hierarchy'[Week Ending]), 'D_Time Hierarchy'[Week Ending], \", \") & OMS, \"\")",
              "",
              "VAR RelativeTimePrompt = IF(ISFILTERED('D_Relative Time Slicer'[Relative Time Prompt]),",
              "                 \"Relative Time Prompt= \" & CONCATENATEX(ALLSELECTED('D_Relative Time Slicer'[Relative Time Prompt]), 'D_Relative Time Slicer'[Relative Time Prompt], \", \") & OMS, \"\")",
              "",
              "",
              "VAR ShipDate = IF(ISFILTERED('F_Order Detail'[Ship Date]),",
              "              \"Ship Date = \" & CONCATENATEX(ALLSELECTED('F_Order Detail'[Ship Date]), 'F_Order Detail'[Ship Date], \", \") & OMS, \"\")",
              "",
              "",
              "VAR FacilityID = IF(ISFILTERED('D_Item'[Facility Nbr Desc]),",
              "             \"Facility = \" & CONCATENATEX(ALLSELECTED('D_Item'[Facility Nbr Desc]), 'D_Item'[Facility Nbr Desc], \", \") & OMS, \"\")",
              "",
              "VAR OrderID = IF(ISFILTERED('F_Order Detail'[Order ID]),",
              "           \"Order ID = \" & CONCATENATEX(ALLSELECTED('F_Order Detail'[Order ID]), 'F_Order Detail'[Order ID], \", \") & OMS, \"\")",
              "",
              "VAR OrderTypeCode = IF(ISFILTERED('F_Order Detail'[Order Type Code]),",
              "             \"Order Type Code = \" & CONCATENATEX(ALLSELECTED('F_Order Detail'[Order Type Code]), 'F_Order Detail'[Order Type Code], \", \") & OMS, \"\")",
              "",
              "VAR OrderStatus = IF(ISFILTERED('F_Order Detail'[Order Status]),",
              "             \"Order Status = \" & CONCATENATEX(ALLSELECTED('F_Order Detail'[Order Status]), 'F_Order Detail'[Order Status], \", \") & OMS, \"\")",
              "",
              "VAR ItemNbr = IF(ISFILTERED('F_Order Detail'[Item Nbr]),",
              "            \"Item Nbr = \" & CONCATENATEX(ALLSELECTED('F_Order Detail'[Item Nbr]), 'F_Order Detail'[Item Nbr], \", \") & OMS, \"\")",
              "",
              "",
              "",
              "Return",
              "FiscalYear&FiscalQuaterdetail&FiscalPeriodwithEndDate&Weekending&RelativeTimePrompt&ShipDate&FacilityID&OrderID&OrderTypeCode&OrderStatus&ItemNbr"
            ],
            "isHidden": true,
            "lineageTag": "cc35d3ce-2288-4bce-8d96-8201756692a5",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          }
        ],
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
