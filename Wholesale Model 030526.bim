              }
            ]
          },
          {
            "name": "Commodity Count Agg",
            "description": "Report Group Count",
            "expression": [
              "",
              "CALCULATE (",
              "    DISTINCTCOUNT ( D_Customer[Report Group] ),",
              "    GROUPBY ( D_Facility, D_Facility[Facility] ),",
              "    FILTER ( 'F_Agg_Sales', 'F_Agg_Sales'[FACILITY_ID] )",
              ")",
              ""
            ],
            "formatString": "0",
            "displayFolder": "Aggregated Measures",
            "lineageTag": "72fb66d3-fb8d-45eb-a74e-14cb5fe099c0",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "Shipped var % to LY Agg",
            "description": "Shipped quantity % variance",
            "expression": [
              "",
              "DIVIDE (",
              "    ( 'O_Report Measure'[Shipped Qty Agg] - [LY Shipped Qty Agg] ),",
              "    [LY Shipped Qty Agg]",
              ")",
              ""
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Aggregated Measures",
            "lineageTag": "c99abc4a-8a0c-4fa1-b64c-9d8e61a725cc",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "Var LY % Total Sales Agg",
            "description": "Total sales amount % variance",
            "expression": [
              "",
              "DIVIDE (",
              "    ( [Total Sales Amt Agg] - [LY Total Sales Amt Agg] ),",
              "    [LY Total Sales Amt Agg],",
              "    0",
              ")",
              ""
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Aggregated Measures",
            "lineageTag": "2cd0541d-9403-47b3-a62f-639ab3b64f35",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
