          },
          {
            "name": "Extended Credit Memo",
            "expression": "[Ext Pure Sell] + [Extended Markup] + [Extended Taxes]",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "displayFolder": "Ad-hoc Wholesale Finance Measures",
            "lineageTag": "8466fdf4-4f1b-4f4f-89b4-5a6d3b1742c4"
          },
          {
            "name": "Extended State Sales Tax",
            "expression": "[Qty For Extension] * [State Sales Tax]",
