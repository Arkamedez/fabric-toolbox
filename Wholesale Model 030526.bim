          {
            "name": "Ext Loss per Case",
            "description": "Extended loss per case",
            "expression": [
              "",
              "VAR Ext_Net_Price_Amt = SUM('F_FD.Sales'[Extended Net Price Amt])",
              "VAR EXT_Fwd_Cost_Amt = SUM('F_FD.Sales'[Extended Forward Cost Amt])",
              "VAR EXT_Original_Price_Amt = SUM('F_FD.Sales'[Extended Original Sales Amt])",
              "VAR EXT_Anticipated_sell = IF(MIN(D_Facility[Facility Nbr]) = 1, EXT_Fwd_Cost_Amt,EXT_Original_Price_Amt)",
              "VAR EXT_Cash_Disc_Amt = SUM('F_FD.Sales'[Extended Cash Discount Amt])",
              "VAR EXT_Promo_Allw_Amt = SUM('F_FD.Sales'[Extended Promotion Allowance Amt])",
              "VAR EXT_Reflect_Amt = SUM('F_FD.Sales'[Extended Reflect Amt])",
              "VAR EXT_SELL_DEAL = IF((MIN(D_Facility[Facility Nbr]) = 1), ((EXT_Anticipated_sell - EXT_Cash_Disc_Amt) - EXT_Promo_Allw_Amt), ((EXT_Anticipated_sell - EXT_PROMO_ALLW_AMT) - EXT_Reflect_Amt))",
              "RETURN",
              "CALCULATE(Ext_Net_Price_Amt-EXT_SELL_DEAL)"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "displayFolder": "Sales",
            "lineageTag": "7177a59e-cedf-4b4b-8735-023fb5fb1e4c",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ],
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ]
          },
          {
            "name": "Commodity Count",
            "description": "Commodity count",
            "expression": "CALCULATE(DISTINCTCOUNT(D_Customer[Report Group]), GROUPBY(D_Facility, D_Facility[Facility]), FILTER('F_FD.Sales','F_FD.Sales'[Facility ID]))",
            "formatString": "0",
