            "type": "calculated",
            "name": "Date and Day Name",
            "dataType": "string",
            "isDataTypeInferred": true,
            "expression": "'D_Time Hierarchy'[Full Date] & UNICHAR(10) & 'D_Time Hierarchy'[Day Name]",
            "lineageTag": "124f3413-1ab2-47d8-868d-65cde02be3fb",
            "summarizeBy": "none",
