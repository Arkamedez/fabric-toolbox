          {
            "name": "COTC(LY)",
            "expression": [
              "CALCULATE(IF((DIVIDE([Order Recieved On Time Quantity],[PO Ordered Quantity]) > 1.0),1.0,(DIVIDE([Order Recieved On Time Quantity],[PO Ordered Quantity]))), FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[Date ID LY] )",
              "    ),",
              "    ALL ( 'D_Time Hierarchy')",
              ")"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Procurement\\COTC",
            "lineageTag": "19f8a734-4589-4755-aaff-fe673d805916",
            "changedProperties": [
              {
                "property": "FormatString"
              }
            ]
          },
