          {
            "name": "F_Customer Order Status-54de9ac2-861d-4527-a6e9-59dbed0dd7af",
            "mode": "import",
            "queryGroup": "Fact Queries",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Snowflake.Databases(\"spartannash.east-us-2.azure.snowflakecomputing.com\",\"ITG_LARGE_WH\"),",
                "    EDW_Database = Source{[Name=EDW_Database,Kind=\"Database\"]}[Data],",
                "    FD_Schema = EDW_Database{[Name=\"FD\",Kind=\"Schema\"]}[Data],",
                "    CUST_ORDER_STATUS_Table = FD_Schema{[Name=\"CUST_ORDER_STATUS\",Kind=\"Table\"]}[Data],",
                "    #\"Renamed Columns\" = Table.RenameColumns(CUST_ORDER_STATUS_Table,{{\"CREATE_TMSP\", \"Create Timestamp\"}, {\"TRANSACTION_DT\", \"Transaction Date\"}, {\"CUSTOMER_NBR\", \"Customer Nbr\"}, {\"CUSTOMER_HST_ID\", \"Customer History ID\"}, {\"INVOICE_NBR\", \"Invoice Nbr\"}, {\"FACILITY_ID\", \"Facility ID\"}, {\"DELIVERY_DT\", \"Delivery Date\"}, {\"ORDER_DUE_TMSP\", \"Order Due Timestamp\"}, {\"ORDER_RECEIVED_TMSP\", \"Order Received Timestamp\"}, {\"MINUTES_LATE_CNT\", \"Late Count Minutes\"}, {\"ORIGIN\", \"Origin\"}, {\"UPDATE_TMSP\", \"Update Timestamp\"}, {\"ORDER_CASE_CNT\", \"Order Case Count\"}, {\"LATE_STATUS_CD\", \"Late status Code\"}, {\"ORDER_CNT\", \"Order Count\"}, {\"ORDER_STATUS_DESC\", \"Order Status\"}}),",
                "    #\"Removed Other Columns\" = Table.SelectColumns(#\"Renamed Columns\",{\"Transaction Date\", \"Customer Nbr\", \"Customer History ID\", \"Invoice Nbr\", \"Facility ID\", \"Delivery Date\", \"Order Due Timestamp\", \"Order Received Timestamp\", \"Late Count Minutes\", \"Order Status\", \"Order Count\", \"Late status Code\", \"Order Case Count\", \"COMMODITY_CD\", \"WHOLESALE_DEPT_ID\", \"DEPT_FIN_GRP_KEY\"}),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Removed Other Columns\",{{\"COMMODITY_CD\", \"Commodity Code\"}, {\"WHOLESALE_DEPT_ID\", \"Wholesale Dept ID\"}, {\"DEPT_FIN_GRP_KEY\", \"Financial Dept Group Key\"}})",
                "in",
                "    #\"Renamed Columns1\""
              ]
            }
          }
        ],
        "annotations": [
          {
