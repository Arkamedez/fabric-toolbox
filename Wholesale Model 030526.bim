            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              },
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "type": "calculated",
            "name": "Reflected Accurate Quantity DC Sales",
            "dataType": "double",
            "isDataTypeInferred": true,
            "isHidden": true,
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    'F_FD.Sales'[Random Weight] > 0 && 'F_FD.Sales'[Facility ID] <> 1, 'F_FD.Sales'[Shipped Qty]*'F_FD.Sales'[Unit Pounds Warehouse Qty],",
              "    'F_FD.Sales'[Random Weight] > 0 && 'F_FD.Sales'[Facility ID] = 1 && 'F_FD.Sales'[Random Weight Flag] = \"R\",'F_FD.Sales'[Random Weight],",
              "    'F_FD.Sales'[Random Weight] > 0 && 'F_FD.Sales'[Facility ID] = 1 && 'F_FD.Sales'[Random Weight Flag] <> \"R\",'F_FD.Sales'[Shipped Qty],",
              "    'F_FD.Sales'[Shipped Qty] > 0 && 'F_FD.Sales'[Facility ID] <> 1,'F_FD.Sales'[Shipped Qty],",
              "    'F_FD.Sales'[Shipped Qty] > 0 && 'F_FD.Sales'[Facility ID] = 1,'F_FD.Sales'[Shipped Qty]",
              ")"
            ],
            "lineageTag": "dd307c30-c773-4d5f-8d84-a36465dd3ec1",
            "summarizeBy": "sum",
            "changedProperties": [
