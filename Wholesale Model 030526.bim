          {
            "name": "Not shipped (Vendor)",
            "description": "Not shipped case quantity % {Specific to ship error group vendor and shipped} ",
            "expression": [
              "",
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales Outs'[Not Ship Case Qty] ),",
              "    'D_Ship Error'[Ship Error Group Code] IN {\"4\",\"5\"}, NOT('D_Ship Error'[Ship Error Code]) in  {\"DPO\",\"PHS\"}, 'D_Ship Reject'[Ship Error Group Code] <> 6",
              ")"
            ],
            "formatString": "#,0",
