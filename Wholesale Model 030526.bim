          {
            "name": "Not Shipped Case Qty",
            "description": "Not shipped case qty {excluding Ship error group code 6}(date is less than today) (day level)",
            "expression": [
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales Outs'[Not Ship Case Qty] ),",
              "    FILTER ( 'D_Time Hierarchy', 'D_Time Hierarchy'[Full Date] <= TODAY () ),",
              "    FILTER (",
              "        'D_Ship Error',",
              "        NOT ( 'D_Ship Error'[Ship Error Group Code] ) IN { \"6\" }",
              "    )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Fill Rate",
            "lineageTag": "2f93ee9b-b76d-4d6e-bc9a-b426e760d7bf",
