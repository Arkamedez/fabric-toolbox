          {
            "name": "Not Shipped (Unauth) (<today)",
            "description": " \"Unauthoriized\"  unshipped cases",
            "expression": [
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales Outs'[Not Ship Case Qty] ),",
              "    FILTER ( 'D_Time Hierarchy', 'D_Time Hierarchy'[Full Date] <= TODAY () ),",
              "    FILTER (",
              "        'D_Ship Error',",
              "        'D_Ship Error'[Ship Error Group Code] = \"3\"",
              "    )",
              ")"
            ],
            "formatString": "#,0",
            "displayFolder": "Sales",
            "lineageTag": "38ad975e-fcad-4529-9bd2-b1dc2bf582af",
            "changedProperties": [
