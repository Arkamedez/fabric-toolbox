                        "Property": "Commodity Sub Class Name"
                      }
                    }
                  ],
                  "version": 0
                }
              }
            ],
            "changedProperties": [
              {
                "property": "SortByColumn"
              }
            ],
            "annotations": [
              {
                "name": "GroupingDesignState",
                "value": "{\"Version\":0,\"Sources\":[{\"Name\":\"d\",\"Entity\":\"D_Caito Item\"}],\"GroupedColumns\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"d\"}},\"Property\":\"Commodity Sub Class Name\"}}],\"GroupItems\":[{\"DisplayName\":\"(Blank)\",\"BlankDefaultPlaceholder\":true},{\"DisplayName\":\"Floral\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"d\"}},\"Property\":\"Commodity Sub Class Name\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'Floral'\"}}],[{\"Literal\":{\"Value\":\"'Non-Perishable'\"}}]]}}},{\"DisplayName\":\"Fruit\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"d\"}},\"Property\":\"Commodity Sub Class Name\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'Fruit'\"}}],[{\"Literal\":{\"Value\":\"'Organic Fruit'\"}}]]}}},{\"DisplayName\":\"Garden Highway\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"d\"}},\"Property\":\"Commodity Sub Class Name\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'Garden Highway'\"}}]]}}},{\"DisplayName\":\"Other\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"d\"}},\"Property\":\"Commodity Sub Class Name\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'Dairy'\"}}],[{\"Literal\":{\"Value\":\"'Deli'\"}}],[{\"Literal\":{\"Value\":\"'Fees'\"}}],[{\"Literal\":{\"Value\":\"'Healthy Alternatives'\"}}],[{\"Literal\":{\"Value\":\"'Meat'\"}}],[{\"Literal\":{\"Value\":\"'Other'\"}}],[{\"Literal\":{\"Value\":\"'Services'\"}}],[{\"Literal\":{\"Value\":\"'Supplies'\"}}],[{\"Literal\":{\"Value\":\"'USDA'\"}}]]}}},{\"DisplayName\":\"Vegetable\",\"Expression\":{\"In\":{\"Expressions\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"d\"}},\"Property\":\"Commodity Sub Class Name\"}}],\"Values\":[[{\"Literal\":{\"Value\":\"'Organic Veg'\"}}],[{\"Literal\":{\"Value\":\"'Vegetable'\"}}]]}}}]}"
