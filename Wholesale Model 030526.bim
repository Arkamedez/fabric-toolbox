            "displayFolder": "Procurement\\ASN",
            "lineageTag": "3075bdee-f7c9-4a49-91a2-492a64208a46"
          },
          {
            "name": "PO Count Adjusted Late",
            "expression": "CALCULATE(COUNT('F_PO Compliance'[Po Nbr]),'F_PO Compliance'[Adjusted Po Ontime Received Flag]=\"N\")",
