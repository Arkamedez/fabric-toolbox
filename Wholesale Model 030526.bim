              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Year Start Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR lasd1 =",
              "    CALCULATETABLE(DATESBETWEEN ( 'D_Time Hierarchy'[Full Date], yy, startOfWeek2), REMOVEFILTERS('D_Time Hierarchy'))",
              "VAR result1 =",
              "    CALCULATE (",
              "        [Shipped Qty Agg],",
              "        REMOVEFILTERS ( 'D_Time Hierarchy' ),",
              "        REMOVEFILTERS('D_Relative Time Slicer'),",
              "        KEEPFILTERS ( lasd1 )",
              "    )",
              "RETURN",
              "    result1"
            ],
            "formatString": "#,0",
            "displayFolder": "Aggregated Measures",
            "lineageTag": "eae315e8-f0af-41f1-92ce-bd65eec6e6c4",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "LY Shipped Qty (Rolling YTW)",
            "description": "Last year shipped quantity for rolling - year to week",
            "expression": [
              "",
              "VAR startdate =",
              "    MAX ( 'D_Time Hierarchy'[Full Date] )",
              "VAR startOfWeek2 =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Week End Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR yy =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Year Start Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR y1 =",
              "    LOOKUPVALUE (",
              "        'D_Time Hierarchy'[Fiscal Year End Date],",
              "        'D_Time Hierarchy'[Full Date], startdate",
              "    )",
              "VAR lasd1 =",
              "    CALCULATETABLE(DATESBETWEEN ( 'D_Time Hierarchy'[Full Date], yy, startOfWeek2), REMOVEFILTERS('D_Time Hierarchy'))",
              "VAR result1 =",
              "    CALCULATE (",
              "        [LY Shipped Qty Agg],",
              "        REMOVEFILTERS ( 'D_Time Hierarchy' ),",
              "        REMOVEFILTERS('D_Relative Time Slicer'),",
              "        KEEPFILTERS ( lasd1 )",
              "    )",
              "RETURN",
              "    result1"
            ],
            "formatString": "#,0",
            "displayFolder": "Aggregated Measures",
            "lineageTag": "b1b98332-008b-48d0-9a77-0c9239c88d5c",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "LY Shipped Qty (000's)",
            "description": "Shipped quantity for last year (sales in thousands)",
            "expression": [
              "CALCULATE (",
              "    SUM ( 'F_FD.Sales'[Shipped Qty] ),",
              "    FILTER (",
              "        ALL ( 'D_Time Hierarchy' ),",
              "        'D_Time Hierarchy'[Date Key] IN VALUES ( 'D_Time Hierarchy'[DATE ID LY] )",
              "    ),ALL('D_Relative Time Slicer')",
              ") * 0.001 "
            ],
            "formatString": "#,0",
            "displayFolder": "Sales",
            "lineageTag": "3ec1da11-938f-4838-a8ca-1ad4388d4250",
            "changedProperties": [
              {
                "property": "FormatString"
              },
              {
                "property": "IsHidden"
              }
            ]
          },
          {
            "name": "Shipped Qty (000's)",
            "description": "Shipped quantity (sales in thousands)",
            "expression": "SUM ( 'F_FD.Sales'[Shipped Qty] ) * 0.001",
            "formatString": "#,0",
            "displayFolder": "Sales",
