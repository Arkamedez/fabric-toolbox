      {
        "name": "Time Intelligence",
        "lineageTag": "2cc4620a-6126-4a37-a304-aefbfbfb676b",
        "calculationGroup": {
          "calculationItems": [
            {
              "name": "PTD",
              "expression": [
                "VAR seleWeek =",
                "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
                "VAR selePeriod =",
                "    MIN ( 'D_Time Hierarchy'[Fiscal Period Start Date] )",
                "RETURN",
                "    CALCULATE (",
                "        SELECTEDMEASURE (),",
                "        FILTER (",
                "            ALL ( 'D_Time Hierarchy' ),",
                "            'D_Time Hierarchy'[Fiscal Week Start Date] >= selePeriod",
                "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
                "        ),",
                "      ALL( 'D_Relative Time Slicer')",
                "    )"
              ],
              "ordinal": 2
            },
            {
              "name": "QTD",
              "expression": [
                "VAR seleWeek =",
                "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
                "VAR seleQuarter =",
                "    MIN ( 'D_Time Hierarchy'[Fiscal Quarter Start Date] )",
                "RETURN",
                "    CALCULATE (",
                "        SELECTEDMEASURE (),",
                "        FILTER (",
                "            ALL ( 'D_Time Hierarchy' ),",
                "            'D_Time Hierarchy'[Fiscal Week Start Date] >= seleQuarter",
                "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
                "        ),",
                "      ALL( 'D_Relative Time Slicer')",
                "    )"
              ],
              "ordinal": 3
            },
            {
              "name": "YTD",
              "expression": [
                "VAR seleWeek =",
                "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
                "VAR seleYear =",
                "    MIN ( 'D_Time Hierarchy'[Fiscal Year Start Date] )",
                "RETURN",
                "    CALCULATE (",
                "        SELECTEDMEASURE (),",
                "        FILTER (",
                "            ALL ( 'D_Time Hierarchy' ),",
                "            'D_Time Hierarchy'[Fiscal Week Start Date] >= seleYear",
                "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
                "        ),",
                "      ALL( 'D_Relative Time Slicer')",
                "    )"
              ],
              "ordinal": 4
            },
            {
              "name": "WTD",
              "expression": [
                "VAR seleWeek =",
                "    MAX ( 'D_Time Hierarchy'[Fiscal Week End Date] )",
                "VAR seleWeekmin =",
                "    MIN ( 'D_Time Hierarchy'[Fiscal Week Start Date] )",
                "RETURN",
                "    CALCULATE (",
                "        SELECTEDMEASURE (),",
                "        FILTER (",
                "            ALL ( 'D_Time Hierarchy' ),",
                "            'D_Time Hierarchy'[Fiscal Week Start Date] >= seleWeekmin",
                "                && 'D_Time Hierarchy'[Fiscal Week Start Date] <= seleWeek",
                "        ),",
                "      ALL( 'D_Relative Time Slicer')",
                "    )"
              ],
              "ordinal": 1
            }
          ]
        },
        "columns": [
          {
            "name": "Name",
            "dataType": "string",
