            "formatString": "#,0.00",
            "displayFolder": "Labor",
            "lineageTag": "49f9defe-9df9-472a-aa7b-eeaff0b7677e"
          },
          {
            "name": "DC Labor Overtime % (Wk)",
            "expression": "([DC Labor Overtime Hr (Wk)] / [DC Total Labor Hr (Wk)])",
            "formatString": "0.00%;-0.00%;0.00%",
            "displayFolder": "Labor",
            "lineageTag": "71fd2e0d-625c-45eb-9f37-009c84f89100"
          },
          {
            "name": "DC Labor Overtime Hr (DY)",
            "expression": [
              "",
              "CALCULATE(",
              "        SUM('F_DC Day Labor'[Work Hours Qty])",
              "        ,'F_DC Day Labor'[Earn Code Id] IN {\"OT1\",\"OT2\"}",
              "    )"
            ],
            "formatString": "#,0",
