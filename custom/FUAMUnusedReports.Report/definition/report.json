{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/report/3.1.0/schema.json",
  "themeCollection": {
    "baseTheme": {
      "name": "CY25SU12",
      "reportVersionAtImport": {
        "visual": "2.5.0",
        "report": "3.1.0",
        "page": "2.3.0"
      },
      "type": "SharedResources"
    }
  },
  "filterConfig": {
    "filters": [
      {
        "name": "filter_report_type_only",
        "displayName": "Item Type = Report",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "active_items"
              }
            },
            "Property": "type"
          }
        },
        "type": "Categorical",
        "filter": {
          "Version": 2,
          "From": [
            {
              "Name": "ai",
              "Entity": "active_items",
              "Type": 0
            }
          ],
          "Where": [
            {
              "Condition": {
                "In": {
                  "Expressions": [
                    {
                      "Column": {
                        "Expression": {
                          "SourceRef": {
                            "Source": "ai"
                          }
                        },
                        "Property": "type"
                      }
                    }
                  ],
                  "Values": [
                    [
                      {
                        "Literal": {
                          "Value": "'Report'"
                        }
                      }
                    ]
                  ]
                }
              }
            }
          ]
        },
        "howCreated": "User",
        "isLockedInViewMode": true
      },
      {
        "name": "filter_exclude_deleted",
        "displayName": "Exclude Deleted Reports",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "active_items"
              }
            },
            "Property": "fuam_deleted"
          }
        },
        "type": "Categorical",
        "filter": {
          "Version": 2,
          "From": [
            {
              "Name": "ai",
              "Entity": "active_items",
              "Type": 0
            }
          ],
          "Where": [
            {
              "Condition": {
                "Comparison": {
                  "ComparisonKind": 0,
                  "Left": {
                    "Column": {
                      "Expression": {
                        "SourceRef": {
                          "Source": "ai"
                        }
                      },
                      "Property": "fuam_deleted"
                    }
                  },
                  "Right": {
                    "Literal": {
                      "Value": "false"
                    }
                  }
                }
              }
            }
          ]
        },
        "howCreated": "User",
        "isLockedInViewMode": true
      },
      {
        "name": "filter_workspace_type",
        "displayName": "Workspace Type",
        "field": {
          "Column": {
            "Expression": {
              "SourceRef": {
                "Entity": "workspaces"
              }
            },
            "Property": "Type"
          }
        },
        "type": "Categorical",
        "howCreated": "User"
      }
    ]
  },
  "objects": {
    "section": [
      {
        "properties": {
          "verticalAlignment": {
            "expr": {
              "Literal": {
                "Value": "'Top'"
              }
            }
          }
        }
      }
    ],
    "outspacePane": [
      {
        "properties": {
          "expanded": {
            "expr": {
              "Literal": {
                "Value": "false"
              }
            }
          }
        }
      }
    ]
  },
  "resourcePackages": [
    {
      "name": "SharedResources",
      "type": "SharedResources",
      "items": [
        {
          "name": "CY25SU12",
          "path": "BaseThemes/CY25SU12.json",
          "type": "BaseTheme"
        }
      ]
    }
  ],
  "settings": {
    "useStylableVisualContainerHeader": true,
    "exportDataMode": "AllowSummarized",
    "defaultDrillFilterOtherVisuals": true,
    "allowChangeFilterTypes": true,
    "useEnhancedTooltips": true,
    "useDefaultAggregateDisplayName": true
  }
}