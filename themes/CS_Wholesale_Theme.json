          "fontSize": [{ "value": 10 }],
          "fontFamily": [{ "value": "Segoe UI" }],
          "labelColor": [{ "solid": { "color": "#252423" } }],
          "gridlineColor": [{ "solid": { "color": "#F3F2F1" } }]
        }]
