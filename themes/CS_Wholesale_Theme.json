{
  "name": "C&S Wholesale Grocers",
  "dataColors": [
    "#A6192E",
    "#002C77",
    "#FFB81C",
    "#4A0E1A",
    "#1A4399",
    "#C87D0E",
    "#D94F5C",
    "#3D5FA3",
    "#E5A62B",
    "#7A1020"
  ],
  "good": "#2E7D32",
  "neutral": "#FFB81C",
  "bad": "#A6192E",
  "maximum": "#002C77",
  "minimum": "#D94F5C",
  "null": "#C8C6C4",
  "background": "#FFFFFF",
  "foreground": "#252423",
  "tableAccent": "#A6192E",
  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI Semibold",
      "color": "#A6192E"
    },
    "title": {
      "fontSize": 16,
      "fontFace": "Segoe UI Semibold",
      "color": "#002C77"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#252423"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#252423"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "fontFamily": [{ "value": "Segoe UI" }],
        "fontSize": [{ "value": 11 }]
      }
    },
    "card": {
      "*": {
        "calloutValue": [{
          "fontSize": 28,
          "labelDisplayUnits": 0,
          "color": { "solid": { "color": "#A6192E" } }
        }],
        "categoryLabel": [{
          "show": true,
          "fontSize": 11,
          "color": { "solid": { "color": "#252423" } }
        }]
      }
    },
    "tableEx": {
      "*": {
        "header": [{
          "fontFamily": "Segoe UI Semibold",
          "fontSize": 11,
          "fontColor": { "solid": { "color": "#FFFFFF" } },
          "backColor": { "solid": { "color": "#A6192E" } },
          "outline": "BottomOnly",
          "alignment": "Left"
        }],
        "rows": [{
          "fontFamily": "Segoe UI",
          "fontSize": 10,
          "fontColor": { "solid": { "color": "#252423" } },
          "backColor": { "solid": { "color": "#FFFFFF" } },
          "outline": "None",
          "stepped": false,
          "bandedRowHeaders": false,
          "valuesOnRow": false
        }],
        "total": [{
          "fontFamily": "Segoe UI Semibold",
          "fontSize": 11,
          "fontColor": { "solid": { "color": "#FFFFFF" } },
          "backColor": { "solid": { "color": "#002C77" } },
          "outline": "TopOnly"
        }]
      }
    },
    "pivotTable": {
      "*": {
        "columnHeaders": [{
          "fontFamily": "Segoe UI Semibold",
          "fontSize": 11,
          "fontColor": { "solid": { "color": "#FFFFFF" } },
          "backColor": { "solid": { "color": "#A6192E" } },
          "outline": "BottomOnly"
        }],
        "rowHeaders": [{
          "fontFamily": "Segoe UI Semibold",
          "fontSize": 11,
          "fontColor": { "solid": { "color": "#FFFFFF" } },
          "backColor": { "solid": { "color": "#002C77" } },
          "outline": "RightOnly",
          "stepped": true,
          "steppedLayoutIndentation": 10,
          "urlIcon": false
        }],
        "values": [{
          "fontFamily": "Segoe UI",
          "fontSize": 10,
          "fontColor": { "solid": { "color": "#252423" } },
          "backColor": { "solid": { "color": "#FFFFFF" } },
          "outline": "None"
        }],
        "total": [{
          "fontFamily": "Segoe UI Semibold",
          "fontSize": 11,
          "fontColor": { "solid": { "color": "#FFFFFF" } },
          "backColor": { "solid": { "color": "#002C77" } },
          "outline": "TopOnly",
          "applyToHeaders": true
        }],
        "subTotals": [{
          "fontFamily": "Segoe UI Semibold",
          "fontSize": 10,
          "fontColor": { "solid": { "color": "#252423" } },
          "backColor": { "solid": { "color": "#F3F2F1" } },
          "rowSubtotals": true,
          "columnSubtotals": true
        }]
      }
    },
    "slicer": {
      "*": {
        "data": [{
          "fontFamily": "Segoe UI",
          "fontSize": 11,
          "fontColor": { "solid": { "color": "#252423" } }
        }],
        "header": [{
          "show": true,
          "fontFamily": "Segoe UI Semibold",
          "fontSize": 11,
          "fontColor": { "solid": { "color": "#002C77" } },
          "background": { "solid": { "color": "#FFFFFF" } },
          "outline": "BottomOnly",
          "borderColor": { "solid": { "color": "#A6192E" } }
        }],
        "general": [{
          "outlineColor": { "solid": { "color": "#A6192E" } },
          "outlineWeight": 1
        }]
      }
    },
    "gauge": {
      "*": {
        "dataPoint": [{
          "fill": { "solid": { "color": "#A6192E" } }
        }],
        "calloutValue": [{
          "color": { "solid": { "color": "#252423" } },
          "fontSize": 20
        }]
      }
    },
    "waterfallChart": {
      "*": {
        "sentimentColors": [{
          "increaseFill": { "solid": { "color": "#2E7D32" } },
          "decreaseFill": { "solid": { "color": "#A6192E" } },
          "totalFill": { "solid": { "color": "#002C77" } }
        }]
      }
    }
  }
}
