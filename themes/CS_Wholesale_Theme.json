{
  "name": "C&S Wholesale Grocers",
  "dataColors": [
    "#A6192E",
    "#002C77",
    "#FFB81C",
    "#4A0E1A",
    "#1A4399",
    "#C87D0E",
    "#D94F5C",
    "#3D5FA3",
    "#E5A62B",
    "#7A1020"
  ],

  "good": "#2E7D32",
  "neutral": "#FFB81C",
  "bad": "#A6192E",
  "maximum": "#002C77",
  "minimum": "#D94F5C",
  "null": "#C8C6C4",

  "background": "#FFFFFF",
  "foreground": "#252423",
  "tableAccent": "#A6192E",

