  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI Semibold",
      "color": "#A6192E"
    },
    "title": {
      "fontSize": 16,
      "fontFace": "Segoe UI Semibold",
      "color": "#002C77"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#252423"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#252423"
    }
  },

  "visualSingleElementStyleInstances": {
    "visualTitle": {
      "fontSize": 14,
      "fontFamily": "Segoe UI Semibold",
      "color": "#002C77",
      "showTitle": true,
      "borderBottom": "#A6192E",
      "borderBottomType": "line"
    },
    "background": {
      "color": "#FFFFFF",
      "transparency": 0
    },
    "border": {
      "show": true,
      "color": "#F3F2F1",
      "radius": 2
    },
    "dropShadow": {
      "show": true
    },
    "header": {
      "show": true,
      "foregroundColor": "#002C77",
      "backgroundColor": "#FFFFFF",
      "outline": "Bottom",
      "fontFamily": "Segoe UI Semibold",
