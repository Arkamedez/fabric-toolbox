    },

    "textbox": {
      "*": {
        "background": [{ "show": false }],
        "border": [{ "show": false }]
      }
    },

    "image": {
      "*": {
        "background": [{ "show": false }],
        "border": [{ "show": false }]
      }
    },

    "shape": {
      "*": {
        "line": [{ "lineColor": [{ "solid": { "color": "#A6192E" } }] }]
      }
