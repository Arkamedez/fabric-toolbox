          "decreaseFill": [{ "solid": { "color": "#A6192E" } }],
          "totalFill": [{ "solid": { "color": "#002C77" } }]
        }],
        "categoryAxis": [{
          "fontSize": [{ "value": 10 }],
          "labelColor": [{ "solid": { "color": "#252423" } }]
        }]
